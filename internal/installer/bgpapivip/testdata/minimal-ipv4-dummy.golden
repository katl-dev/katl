--- /etc/katl/apps/bgp-api-vip/config.yaml
apiVersion: apps.katl.dev/v1alpha1
kind: BGPAPIEndpoint
spec:
    endpoint:
        host: api.home.example
        port: 6443
        vip: 10.40.0.10/32
        addressFamily: ipv4
        tlsServerName: api.home.example
        provenance: platform-host
    vipInterface:
        kind: dummy
        name: katl-api0
        mtu: 1500
    routing:
        daemon: bird
        protocolBoundary: bgp
        routerID: 10.0.0.11
        localASN: 64512
        sourceAddress: 10.0.0.11
        sourceInterface: enp1s0
        exportPolicy:
            communities:
                - 64512:100
            localPreference: 100
    advertiseOn:
        roles:
            - control-plane
    fabricPeers:
        - name: router-a
          address: 10.0.0.1
          asn: 64500
          localASN: 64512
          kind: fabric
          allowedExportPrefixes:
            - 10.40.0.10/32
          sourceAddress: 10.0.0.11
          sourceInterface: enp1s0
    advertisement:
        enabled: true
        startWithdrawn: true
        advertiseAfterHealthy: true
        withdrawOnFailure: true
    health:
        probe: readyz
        scheme: https
        host: 10.40.0.10
        port: 6443
        path: /readyz
        interval: 2s
        timeout: 1s
        successThreshold: 2
        failureThreshold: 3
        caRef: kube-apiserver-ca
        tlsServerName: api.home.example
    status:
        liveStatusPath: /run/katl/apps/bgp-api-vip/status.json
        operationStatusPath: /var/lib/katl/operations/<operation-id>/apps/bgp-api-vip/status.json
--- /etc/katl/apps/bird/bird.conf
# Generated by Katl bgp-api-vip. Do not edit.
router id 10.0.0.11;

ipv4 table katl_fabric;

protocol device katl_device {}

protocol static katl_api {
  disabled;
  ipv4 { table katl_fabric; };
  route 10.40.0.10/32 blackhole;
}

filter katl_export_katl_fabric_router_a {
  if source = RTS_STATIC && net = 10.40.0.10/32 then accept;
  reject;
}

protocol bgp katl_fabric_router_a {
  local as 64512;
  neighbor 10.0.0.1 as 64500;
  source address 10.0.0.11;
  ipv4 {
    table katl_fabric;
    import none;
    export filter katl_export_katl_fabric_router_a;
  };
}

--- /etc/systemd/network/05-katl-bgp-api-vip.netdev
[NetDev]
Name=katl-api0
Kind=dummy
--- /etc/systemd/network/05-katl-bgp-api-vip.network
[Match]
Name=katl-api0

[Network]
Address=10.40.0.10/32
MTUBytes=1500
--- /etc/systemd/system/katl-app-bgp-api-vip.service.d/10-katl-config.conf
[Service]
Environment=KATL_BGP_API_VIP_CONFIG=/etc/katl/apps/bgp-api-vip/config.yaml
Environment=KATL_BGP_API_VIP_STATUS=/run/katl/apps/bgp-api-vip/status.json
--- /etc/systemd/system/katl-app-bird.service.d/20-katl-bgp-api-vip.conf
[Unit]
After=network-online.target

[Service]
Environment=KATL_BIRD_CONFIG=/etc/katl/apps/bird/bird.conf
--- /etc/systemd/system/kubelet.service.d/20-katl-control-plane-endpoint.conf
[Unit]
Wants=katl-app-bgp-api-vip.service
After=katl-app-bgp-api-vip.service
