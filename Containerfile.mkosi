FROM registry.fedoraproject.org/fedora:44

RUN dnf5 -y install \
        bash \
        ca-certificates \
        cpio \
        dnf5 \
        dosfstools \
        e2fsprogs \
        erofs-utils \
        findutils \
        git-core \
        golang \
        jq \
        kmod \
        mkosi \
        mtools \
        opensc \
        openssl \
        rpm \
        squashfs-tools \
        systemd \
        systemd-boot-unsigned \
        systemd-ukify \
        tar \
        util-linux \
        xfsprogs \
        xorriso \
        zstd \
    && dnf5 clean all

WORKDIR /work
