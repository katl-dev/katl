{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://install.katl.dev/schemas/install-manifest-v1alpha1.schema.json",
  "title": "Katl install manifest v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "node",
    "install",
    "artifacts"
  ],
  "properties": {
    "apiVersion": {
      "const": "install.katl.dev/v1alpha1"
    },
    "kind": {
      "const": "InstallManifest"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/dnsLabel"
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity"
      ],
      "properties": {
        "identity": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "hostname",
            "ssh"
          ],
          "properties": {
            "hostname": {
              "$ref": "#/$defs/dnsLabel"
            },
            "ssh": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "authorizedKeys"
              ],
              "properties": {
                "authorizedKeys": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": {
                    "$ref": "#/$defs/sshAuthorizedKey"
                  }
                }
              }
            }
          }
        }
      }
    },
    "install": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowDestructiveInstall",
        "targetDisk"
      ],
      "properties": {
        "allowDestructiveInstall": {
          "description": "Must be explicitly true before katlos-install may wipe or repartition the target root disk.",
          "const": true
        },
        "targetDisk": {
          "$ref": "#/$defs/diskSelector"
        },
        "extraDisks": {
          "type": "array",
          "default": [],
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/extraDisk"
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtimeRoot"
      ],
      "properties": {
        "runtimeRoot": {
          "$ref": "#/$defs/artifact"
        },
        "uki": {
          "$ref": "#/$defs/artifact"
        },
        "sysexts": {
          "type": "array",
          "default": [],
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/namedArtifact"
          }
        }
      }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url",
        "sha256"
      ],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "diskSelector": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "byID": {
          "type": "string",
          "pattern": "^/dev/disk/by-id/[^/]+$"
        },
        "wwn": {
          "type": "string",
          "minLength": 1
        },
        "serial": {
          "type": "string",
          "minLength": 1
        },
        "minSizeMiB": {
          "type": "integer",
          "minimum": 8192
        }
      },
      "oneOf": [
        {
          "required": [
            "byID"
          ]
        },
        {
          "required": [
            "wwn"
          ]
        },
        {
          "required": [
            "serial"
          ]
        }
      ]
    },
    "dnsLabel": {
      "type": "string",
      "minLength": 1,
      "maxLength": 63,
      "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
    },
    "extraDisk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "selector",
        "filesystem",
        "mount"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/dnsLabel"
        },
        "selector": {
          "$ref": "#/$defs/diskSelector"
        },
        "filesystem": {
          "enum": [
            "ext4",
            "xfs"
          ]
        },
        "mount": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path"
          ],
          "properties": {
            "path": {
              "type": "string",
              "pattern": "^/(srv|var/lib/katl/extra)/[A-Za-z0-9._-]+(/[A-Za-z0-9._-]+)*$"
            }
          }
        },
        "wipe": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "namedArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "url",
        "sha256"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/dnsLabel"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "sshAuthorizedKey": {
      "type": "string",
      "pattern": "^(ssh-ed25519|ssh-rsa|ecdsa-sha2-nistp256|sk-ssh-ed25519@openssh.com) [A-Za-z0-9+/=]+( .*)?$"
    }
  }
}
