{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://install.katl.dev/schemas/install-manifest-v1alpha1.schema.json",
  "title": "Katl install manifest v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "node",
    "install",
    "katlosImage"
  ],
  "properties": {
    "apiVersion": {
      "const": "install.katl.dev/v1alpha1"
    },
    "kind": {
      "const": "InstallManifest"
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity",
        "systemRole"
      ],
      "properties": {
        "identity": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "hostname",
            "ssh"
          ],
          "properties": {
            "hostname": {
              "$ref": "#/$defs/dnsLabel"
            },
            "ssh": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "authorizedKeys"
              ],
              "properties": {
                "authorizedKeys": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": {
                    "$ref": "#/$defs/sshAuthorizedKey"
                  }
                }
              }
            }
          }
        },
        "systemRole": {
          "enum": [
            "control-plane",
            "worker"
          ]
        },
        "networkd": {
          "$ref": "#/$defs/networkdConfig"
        },
        "kubernetes": {
          "$ref": "#/$defs/kubernetesConfig"
        },
        "bootstrap": {
          "$ref": "#/$defs/bootstrapIntent"
        }
      }
    },
    "install": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowDestructiveInstall",
        "targetDisk"
      ],
      "properties": {
        "allowDestructiveInstall": {
          "description": "Must be explicitly true before katlos-install may wipe or repartition the target root disk.",
          "const": true
        },
        "targetDisk": {
          "$ref": "#/$defs/diskSelector"
        },
        "extraDisks": {
          "type": "array",
          "default": [],
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/extraDisk"
          }
        }
      }
    },
    "katlosImage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sha256",
        "sizeBytes",
        "version",
        "architecture",
        "role"
      ],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^[A-Za-z][A-Za-z0-9+.-]*://[^/\\s]+.*$"
        },
        "localRef": {
          "$ref": "#/$defs/relativePath"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 1
        },
        "version": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "architecture": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "runtimeInterface": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "role": {
          "const": "install"
        }
      },
      "oneOf": [
        {
          "required": [
            "url"
          ],
          "not": {
            "required": [
              "localRef"
            ]
          }
        },
        {
          "required": [
            "localRef"
          ],
          "not": {
            "required": [
              "url"
            ]
          }
        }
      ]
    }
  },
  "$defs": {
    "diskSelector": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "byID": {
          "type": "string",
          "pattern": "^/dev/disk/by-id/[^/]+$"
        },
        "wwn": {
          "type": "string",
          "minLength": 1
        },
        "serial": {
          "type": "string",
          "minLength": 1
        },
        "minSizeMiB": {
          "type": "integer",
          "minimum": 8192
        }
      },
      "oneOf": [
        {
          "required": [
            "byID"
          ]
        },
        {
          "required": [
            "wwn"
          ]
        },
        {
          "required": [
            "serial"
          ]
        }
      ]
    },
    "dnsLabel": {
      "type": "string",
      "minLength": 1,
      "maxLength": 63,
      "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
    },
    "extraDisk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "selector",
        "filesystem",
        "mount"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/dnsLabel"
        },
        "selector": {
          "$ref": "#/$defs/diskSelector"
        },
        "filesystem": {
          "enum": [
            "ext4",
            "xfs"
          ]
        },
        "mount": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path"
          ],
          "properties": {
            "path": {
              "type": "string",
              "pattern": "^/(srv|var/lib/katl/extra)/[A-Za-z0-9._-]+(/[A-Za-z0-9._-]+)*$"
            }
          }
        },
        "wipe": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "bootstrapIntent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "clusterName": {
          "$ref": "#/$defs/dnsLabel"
        },
        "inventoryNodeName": {
          "$ref": "#/$defs/dnsLabel"
        },
        "nodeAddress": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "controlPlaneEndpoint": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "bootstrapProfileRef": {
          "$ref": "#/$defs/dnsLabel"
        },
        "profileResolvedID": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "kubernetesBundleSource": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "kubernetesBundleRef": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "access": {
          "$ref": "#/$defs/bootstrapAccess"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/labelValue"
          },
          "propertyNames": {
            "$ref": "#/$defs/labelKey"
          }
        },
        "taints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nodeTaint"
          }
        }
      }
    },
    "bootstrapAccess": {
      "type": "object",
      "additionalProperties": false,
      "dependentRequired": {
        "method": [
          "credentialRef"
        ],
        "user": [
          "method",
          "credentialRef"
        ],
        "credentialRef": [
          "method"
        ]
      },
      "properties": {
        "method": {
          "enum": [
            "ssh",
            "vsock",
            "agent"
          ]
        },
        "user": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "credentialRef": {
          "$ref": "#/$defs/credentialRef"
        }
      }
    },
    "nodeTaint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "effect"
      ],
      "properties": {
        "key": {
          "$ref": "#/$defs/labelKey"
        },
        "value": {
          "$ref": "#/$defs/labelValue"
        },
        "effect": {
          "enum": [
            "NoSchedule",
            "PreferNoSchedule",
            "NoExecute"
          ]
        }
      }
    },
    "kubernetesConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kubeadm": {
          "$ref": "#/$defs/kubeadmReference"
        }
      }
    },
    "kubeadmReference": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "configRef": {
          "$ref": "#/$defs/dnsLabel"
        }
      }
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "credentialRef": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          {
            "pattern": "\\n|\\r"
          },
          {
            "pattern": "-----BEGIN "
          },
          {
            "pattern": "^[a-z0-9]{6}\\.[a-z0-9]{16}$"
          }
        ]
      }
    },
    "relativePath": {
      "type": "string",
      "pattern": "^(?!.*(^|/)\\.\\.?($|/))[A-Za-z0-9._+-]+(/[A-Za-z0-9._+-]+)*$"
    },
    "networkdConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "files": {
          "type": "array",
          "default": [],
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/networkdFile"
          }
        }
      }
    },
    "networkdFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "content"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._@+-]+\\.(network|netdev|link)$"
        },
        "content": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        }
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "sshAuthorizedKey": {
      "type": "string",
      "pattern": "^ssh-ed25519 [A-Za-z0-9+/=]+( .*)?$"
    },
    "labelKey": {
      "type": "string",
      "minLength": 1,
      "pattern": "^([A-Za-z0-9]([-A-Za-z0-9.]*[A-Za-z0-9])?/)?[A-Za-z0-9]([-A-Za-z0-9_.]*[A-Za-z0-9])?$"
    },
    "labelValue": {
      "type": "string",
      "pattern": "^$|^[A-Za-z0-9]([-A-Za-z0-9_.]*[A-Za-z0-9])?$"
    }
  }
}
