#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
go_bin="${KATL_VMTEST_GO:-go}"
debug_bin="${KATL_VMTEST_DEBUG:-}"

if [[ -n "$debug_bin" ]]; then
    exec "$debug_bin" "$@"
fi
if command -v katl-vmtest-debug >/dev/null 2>&1; then
    exec katl-vmtest-debug "$@"
fi
cd "$repo_root"
exec "$go_bin" run ./cmd/katl-vmtest-debug "$@"
