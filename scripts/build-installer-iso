#!/usr/bin/env bash
set -euo pipefail

repo_root="${KATL_REPO_ROOT:-$(git rev-parse --show-toplevel)}"
build_dir="${KATL_MKOSI_BUILD_DIR:-$repo_root/_build/mkosi}"
installer="${KATL_INSTALLER_UKI:-$build_dir/katl-installer.efi}"
output="${KATL_INSTALLER_ISO:-$build_dir/katl-installer.iso}"

fail() {
    echo "error: $*" >&2
    exit 1
}

for tool in mkfs.vfat mcopy mmd truncate xorriso; do
    command -v "$tool" >/dev/null 2>&1 || fail "$tool is required to build the installer ISO"
done
[[ -f "$installer" ]] || fail "installer UKI not found: $installer"
[[ -s "$installer" ]] || fail "installer UKI is empty: $installer"
[[ -n "$output" && "$output" != / && "$output" != . ]] || fail "unsafe installer ISO output: $output"

mkdir -p "$(dirname "$output")"
work="$(mktemp -d "${TMPDIR:-/tmp}/katl-installer-iso.XXXXXX")"
trap 'rm -rf "$work"' EXIT

installer_size="$(stat -c %s "$installer")"
overhead=$((32 * 1024 * 1024))
mebibyte=$((1024 * 1024))
esp_size=$((((installer_size + overhead + mebibyte - 1) / mebibyte) * mebibyte))
esp="$work/efiboot.img"
tree="$work/iso"
temporary="$work/katl-installer.iso"

mkdir -p "$tree"
truncate -s "$esp_size" "$esp"
mkfs.vfat -F 32 -n KATLISOEFI "$esp" >/dev/null
mmd -i "$esp" ::/EFI ::/EFI/BOOT
mcopy -i "$esp" "$installer" ::/EFI/BOOT/BOOTX64.EFI
cp -- "$esp" "$tree/efiboot.img"

xorriso -as mkisofs \
    -quiet \
    -iso-level 3 \
    -full-iso9660-filenames \
    -volid KATL_INSTALLER \
    -e efiboot.img \
    -no-emul-boot \
    -isohybrid-gpt-basdat \
    -output "$temporary" \
    "$tree"

mv -- "$temporary" "$output"
printf '%s\n' "$output"
