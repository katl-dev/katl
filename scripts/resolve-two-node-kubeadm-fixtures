#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
run_id="${KATL_TWO_NODE_FIXTURES_RUN_ID:-$(date -u +%Y%m%dT%H%M%SZ)-$$}"
state_root="${KATL_TWO_NODE_FIXTURES_STATE_ROOT:-$repo_root/build/two-node-kubeadm-fixtures}"
state_dir="${KATL_TWO_NODE_FIXTURES_STATE_DIR:-$state_root/$run_id}"
env_file="${KATL_TWO_NODE_FIXTURES_ENV:-$state_dir/vmtest.env}"
run_script="$state_dir/run-two-node-kubeadm-join.sh"
manifest="$state_dir/fixtures.json"

cp_disk="${KATL_CONTROL_PLANE_INSTALLED_DISK:-}"
worker_disk="${KATL_WORKER_INSTALLED_DISK:-}"
cp_published_dir="${KATL_CONTROL_PLANE_PUBLISHED_FIXTURE_DIR:-}"
worker_published_dir="${KATL_WORKER_PUBLISHED_FIXTURE_DIR:-}"
shared_esp_artifacts="${KATL_INSTALLED_ESP_ARTIFACTS:-}"
cp_esp_artifacts="${KATL_CONTROL_PLANE_INSTALLED_ESP_ARTIFACTS:-$shared_esp_artifacts}"
worker_esp_artifacts="${KATL_WORKER_INSTALLED_ESP_ARTIFACTS:-$shared_esp_artifacts}"
cp_node_metadata="${KATL_CONTROL_PLANE_NODE_METADATA:-}"
worker_node_metadata="${KATL_WORKER_NODE_METADATA:-}"
cp_fixture_manifest="${KATL_CONTROL_PLANE_FIXTURE_MANIFEST:-}"
worker_fixture_manifest="${KATL_WORKER_FIXTURE_MANIFEST:-}"
cp_address="${KATL_CONTROL_PLANE_ADDRESS:-}"
worker_address="${KATL_WORKER_ADDRESS:-}"
cp_format="${KATL_CONTROL_PLANE_INSTALLED_DISK_FORMAT:-}"
worker_format="${KATL_WORKER_INSTALLED_DISK_FORMAT:-}"
kubernetes_version="${KATL_KUBERNETES_VERSION:-v1.36.1}"
bridge="${KATL_VMTEST_BRIDGE:-}"
bridge_helper="${KATL_QEMU_BRIDGE_HELPER:-}"
bridge_check="${KATL_TWO_NODE_FIXTURES_BRIDGE_CHECK:-on}"
vmtest_keep="${KATL_VMTEST_KEEP:-failed}"
vmtest_state_root="${KATL_VMTEST_STATE_ROOT:-$state_dir/vm-runs}"
env_file_set=0
check_only=0

usage() {
    cat <<'USAGE'
Usage: scripts/resolve-two-node-kubeadm-fixtures [options]

Resolve and preflight the installed runtime fixtures needed by the opt-in
two-node kubeadm join VM smoke. The control-plane disk must come from cp-1
install materials and the worker disk must come from worker-1 install materials.
The command does not mutate or build disks; it validates existing node-specific
disk paths, node metadata, bridge addresses, and ESP artifact trees, then writes
a sourceable env file plus a run wrapper under build/.

Options:
  --control-plane-published-dir DIR  Published first-install fixture directory for cp-1
  --worker-published-dir DIR         Published first-install fixture directory for worker-1
  --control-plane-disk PATH   Installed control-plane disk, or KATL_CONTROL_PLANE_INSTALLED_DISK
  --worker-disk PATH          Installed worker disk, or KATL_WORKER_INSTALLED_DISK
  --control-plane-esp DIR     Rendered cp-1 ESP artifact tree, or KATL_CONTROL_PLANE_INSTALLED_ESP_ARTIFACTS
  --worker-esp DIR            Rendered worker-1 ESP artifact tree, or KATL_WORKER_INSTALLED_ESP_ARTIFACTS
  --control-plane-metadata P  cp-1 /etc/katl/node.json, or KATL_CONTROL_PLANE_NODE_METADATA
  --worker-metadata P         worker-1 /etc/katl/node.json, or KATL_WORKER_NODE_METADATA
  --control-plane-fixture P   cp-1 fixture manifest binding disk/ESP/metadata checksums
  --worker-fixture P          worker-1 fixture manifest binding disk/ESP/metadata checksums
  --control-plane-address A   Bridge-reachable control-plane address, or KATL_CONTROL_PLANE_ADDRESS
  --worker-address A          Bridge-reachable worker address, or KATL_WORKER_ADDRESS
  --control-plane-format F    Control-plane disk format: raw or qcow2 (default: raw)
  --worker-format F           Worker disk format: raw or qcow2 (default: raw)
  --kubernetes-version V      Kubernetes payload version for the smoke inventory (default: v1.36.1)
  --bridge NAME               QEMU bridge name to export as KATL_VMTEST_BRIDGE
  --bridge-helper PATH        QEMU bridge helper to export as KATL_QEMU_BRIDGE_HELPER
  --state-dir DIR             Output directory for generated env, manifest, and ESP copies
  --env-file PATH             Sourceable env output path (default: <state-dir>/vmtest.env)
  --check-only                Validate inputs and preflight disks without writing wrappers
  -h, --help                  Show this help

After this command succeeds:
  source <state-dir>/vmtest.env
  <state-dir>/run-two-node-kubeadm-join.sh
USAGE
}

fail() {
    echo "error: $*" >&2
    exit 1
}

need_value() {
    local option="$1"
    local value="${2:-}"
    if [[ -z "$value" || "$value" == --* ]]; then
        fail "$option requires a value"
    fi
}

rel() {
    local path="$1"
    printf "%s" "${path#"$repo_root"/}"
}

json() {
    local value="$1"
    value="${value//\\/\\\\}"
    value="${value//\"/\\\"}"
    value="${value//$'\n'/\\n}"
    printf "%s" "$value"
}

real() {
    realpath -m "$1"
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --control-plane-published-dir)
            need_value "$1" "${2:-}"
            cp_published_dir="$2"
            shift 2
            ;;
        --worker-published-dir)
            need_value "$1" "${2:-}"
            worker_published_dir="$2"
            shift 2
            ;;
        --control-plane-disk)
            need_value "$1" "${2:-}"
            cp_disk="$2"
            shift 2
            ;;
        --worker-disk)
            need_value "$1" "${2:-}"
            worker_disk="$2"
            shift 2
            ;;
        --control-plane-esp)
            need_value "$1" "${2:-}"
            cp_esp_artifacts="$2"
            shift 2
            ;;
        --worker-esp)
            need_value "$1" "${2:-}"
            worker_esp_artifacts="$2"
            shift 2
            ;;
        --esp-artifacts)
            need_value "$1" "${2:-}"
            cp_esp_artifacts="$2"
            worker_esp_artifacts="$2"
            shift 2
            ;;
        --control-plane-metadata)
            need_value "$1" "${2:-}"
            cp_node_metadata="$2"
            shift 2
            ;;
        --worker-metadata)
            need_value "$1" "${2:-}"
            worker_node_metadata="$2"
            shift 2
            ;;
        --control-plane-fixture)
            need_value "$1" "${2:-}"
            cp_fixture_manifest="$2"
            shift 2
            ;;
        --worker-fixture)
            need_value "$1" "${2:-}"
            worker_fixture_manifest="$2"
            shift 2
            ;;
        --control-plane-address)
            need_value "$1" "${2:-}"
            cp_address="$2"
            shift 2
            ;;
        --worker-address)
            need_value "$1" "${2:-}"
            worker_address="$2"
            shift 2
            ;;
        --control-plane-format)
            need_value "$1" "${2:-}"
            cp_format="$2"
            shift 2
            ;;
        --worker-format)
            need_value "$1" "${2:-}"
            worker_format="$2"
            shift 2
            ;;
        --kubernetes-version)
            need_value "$1" "${2:-}"
            kubernetes_version="$2"
            shift 2
            ;;
        --bridge)
            need_value "$1" "${2:-}"
            bridge="$2"
            shift 2
            ;;
        --bridge-helper)
            need_value "$1" "${2:-}"
            bridge_helper="$2"
            shift 2
            ;;
        --state-dir)
            need_value "$1" "${2:-}"
            state_dir="$2"
            if [[ "$env_file_set" -eq 0 ]]; then
                env_file="$state_dir/vmtest.env"
            fi
            run_script="$state_dir/run-two-node-kubeadm-join.sh"
            manifest="$state_dir/fixtures.json"
            vmtest_state_root="$state_dir/vm-runs"
            shift 2
            ;;
        --env-file)
            need_value "$1" "${2:-}"
            env_file="$2"
            env_file_set=1
            shift 2
            ;;
        --check-only)
            check_only=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            usage >&2
            fail "unknown argument: $1"
            ;;
    esac
done

need() {
    command -v "$1" >/dev/null 2>&1 || fail "$1 is required"
}

need jq

published_path() {
    local dir="$1"
    local query="$2"
    local value
    value="$(jq -er "$query" "$dir/published-first-install-runtime-fixture.json")"
    if [[ "$value" == /* ]]; then
        real "$value"
    else
        real "$dir/$value"
    fi
}

check_published_digest() {
    local dir="$1"
    local label="$2"
    local field="$3"
    local fixture_query="$4"
    local published_manifest="$dir/published-first-install-runtime-fixture.json"
    local fixture_manifest got want
    if ! jq -e --arg field "$field" 'has($field)' "$published_manifest" >/dev/null; then
        return 0
    fi
    fixture_manifest="$(published_path "$dir" '.fixtureManifest // .sourceFixtureManifest')"
    [[ -f "$fixture_manifest" ]] || fail "$label fixture manifest not found: $(rel "$fixture_manifest")"
    got="$(jq -er --arg field "$field" '.[$field]' "$published_manifest")"
    want="$(jq -er "$fixture_query" "$fixture_manifest")"
    [[ "$got" == "$want" ]] || fail "$label published $field does not match packaged fixture manifest"
}

load_published_fixture() {
    local label="$1"
    local dir="$2"
    [[ -z "$dir" ]] && return 0
    [[ -d "$dir" ]] || fail "$label published fixture directory not found: $(rel "$dir")"
    dir="$(real "$dir")"
    [[ -f "$dir/published-first-install-runtime-fixture.json" ]] ||
        fail "$label published fixture manifest not found: $(rel "$dir/published-first-install-runtime-fixture.json")"
    jq -e '
        .apiVersion == "katl.dev/v1alpha1" and
        .kind == "PublishedFirstInstallRuntimeFixture" and
        (.disk | type == "string") and
        (.diskFormat | type == "string") and
        (.espArtifacts | type == "string") and
        (((.fixtureManifest // .sourceFixtureManifest) | type) == "string") and
        ((.diskSHA256 // "") | type == "string") and
        ((.espArtifactsTreeSHA256 // "") | type == "string") and
        ((.nodeMetadataSHA256 // "") | type == "string")
        ' "$dir/published-first-install-runtime-fixture.json" >/dev/null ||
        fail "$label published fixture manifest is invalid"
    check_published_digest "$dir" "$label" "diskSHA256" '.disk.sha256'
    check_published_digest "$dir" "$label" "espArtifactsTreeSHA256" '.espArtifacts.treeSHA256'
    check_published_digest "$dir" "$label" "nodeMetadataSHA256" '.nodeMetadata.sha256'
    case "$label" in
        control-plane)
            cp_disk="${cp_disk:-$(published_path "$dir" '.disk')}"
            cp_format="${cp_format:-$(jq -er '.diskFormat' "$dir/published-first-install-runtime-fixture.json")}"
            cp_esp_artifacts="${cp_esp_artifacts:-$(published_path "$dir" '.espArtifacts')}"
            cp_fixture_manifest="${cp_fixture_manifest:-$(published_path "$dir" '.fixtureManifest // .sourceFixtureManifest')}"
            if jq -e '(.nodeMetadata // "") != ""' "$dir/published-first-install-runtime-fixture.json" >/dev/null; then
                cp_node_metadata="${cp_node_metadata:-$(published_path "$dir" '.nodeMetadata')}"
            fi
            cp_published_dir="$dir"
            ;;
        worker)
            worker_disk="${worker_disk:-$(published_path "$dir" '.disk')}"
            worker_format="${worker_format:-$(jq -er '.diskFormat' "$dir/published-first-install-runtime-fixture.json")}"
            worker_esp_artifacts="${worker_esp_artifacts:-$(published_path "$dir" '.espArtifacts')}"
            worker_fixture_manifest="${worker_fixture_manifest:-$(published_path "$dir" '.fixtureManifest // .sourceFixtureManifest')}"
            if jq -e '(.nodeMetadata // "") != ""' "$dir/published-first-install-runtime-fixture.json" >/dev/null; then
                worker_node_metadata="${worker_node_metadata:-$(published_path "$dir" '.nodeMetadata')}"
            fi
            worker_published_dir="$dir"
            ;;
    esac
}

load_published_fixture "control-plane" "$cp_published_dir"
load_published_fixture "worker" "$worker_published_dir"

cp_format="${cp_format:-raw}"
worker_format="${worker_format:-raw}"

case "$cp_format" in
    qcow2|raw) ;;
    *) fail "--control-plane-format must be raw or qcow2" ;;
esac
case "$worker_format" in
    qcow2|raw) ;;
    *) fail "--worker-format must be raw or qcow2" ;;
esac

[[ -n "$cp_disk" ]] || fail "--control-plane-disk is required"
[[ -f "$cp_disk" ]] || fail "control-plane disk not found: $(rel "$cp_disk")"
[[ -n "$worker_disk" ]] || fail "--worker-disk is required"
[[ -f "$worker_disk" ]] || fail "worker disk not found: $(rel "$worker_disk")"
[[ -n "$cp_esp_artifacts" ]] || fail "--control-plane-esp is required"
[[ -d "$cp_esp_artifacts" ]] || fail "control-plane ESP artifacts directory not found: $(rel "$cp_esp_artifacts")"
[[ -n "$worker_esp_artifacts" ]] || fail "--worker-esp is required"
[[ -d "$worker_esp_artifacts" ]] || fail "worker ESP artifacts directory not found: $(rel "$worker_esp_artifacts")"
[[ -n "$cp_node_metadata" ]] || fail "--control-plane-metadata is required"
[[ -f "$cp_node_metadata" ]] || fail "control-plane node metadata not found: $(rel "$cp_node_metadata")"
[[ -n "$worker_node_metadata" ]] || fail "--worker-metadata is required"
[[ -f "$worker_node_metadata" ]] || fail "worker node metadata not found: $(rel "$worker_node_metadata")"
[[ -n "$cp_fixture_manifest" ]] || fail "--control-plane-fixture is required"
[[ -f "$cp_fixture_manifest" ]] || fail "control-plane fixture manifest not found: $(rel "$cp_fixture_manifest")"
[[ -n "$worker_fixture_manifest" ]] || fail "--worker-fixture is required"
[[ -f "$worker_fixture_manifest" ]] || fail "worker fixture manifest not found: $(rel "$worker_fixture_manifest")"
[[ -n "$cp_address" ]] || fail "--control-plane-address is required"
[[ -n "$worker_address" ]] || fail "--worker-address is required"
[[ -n "$kubernetes_version" ]] || fail "--kubernetes-version is required"
[[ -n "$bridge" ]] || fail "--bridge or KATL_VMTEST_BRIDGE is required"

cp_disk="$(real "$cp_disk")"
worker_disk="$(real "$worker_disk")"
cp_esp_artifacts="$(real "$cp_esp_artifacts")"
worker_esp_artifacts="$(real "$worker_esp_artifacts")"
cp_node_metadata="$(real "$cp_node_metadata")"
worker_node_metadata="$(real "$worker_node_metadata")"
cp_fixture_manifest="$(real "$cp_fixture_manifest")"
worker_fixture_manifest="$(real "$worker_fixture_manifest")"
state_dir="$(real "$state_dir")"
env_file="$(real "$env_file")"
run_script="$(real "$run_script")"
manifest="$(real "$manifest")"
vmtest_state_root="$(real "$vmtest_state_root")"

[[ "$cp_disk" != "$worker_disk" ]] || fail "control-plane and worker disks must be distinct"
[[ "$cp_esp_artifacts" != "$worker_esp_artifacts" ]] || fail "control-plane and worker ESP artifacts must be distinct"
[[ "$cp_node_metadata" != "$worker_node_metadata" ]] || fail "control-plane and worker node metadata must be distinct"
[[ "$cp_fixture_manifest" != "$worker_fixture_manifest" ]] || fail "control-plane and worker fixture manifests must be distinct"
[[ "$cp_address" != "$worker_address" ]] || fail "control-plane and worker addresses must be distinct"

need sha256sum

validate_address() {
    local label="$1"
    local address="$2"
    local octets IFS=.
    [[ "$address" =~ ^[0-9]+[.][0-9]+[.][0-9]+[.][0-9]+$ ]] ||
        fail "$label address must be an IPv4 address without scheme, path, or port: $address"
    read -r -a octets <<<"$address"
    for octet in "${octets[@]}"; do
        [[ "$octet" =~ ^[0-9]+$ ]] || fail "$label address is invalid: $address"
        ((octet >= 0 && octet <= 255)) || fail "$label address octet is out of range: $address"
    done
    if ((octets[0] == 0 || octets[0] == 127 || octets[0] >= 224)); then
        fail "$label address must not be unspecified, loopback, multicast, or reserved: $address"
    fi
    if ((octets[0] == 169 && octets[1] == 254)); then
        fail "$label address must not be link-local: $address"
    fi
    if ((octets[0] == 192 && octets[1] == 0 && octets[2] == 2)) ||
        ((octets[0] == 198 && octets[1] == 51 && octets[2] == 100)) ||
        ((octets[0] == 203 && octets[1] == 0 && octets[2] == 113)); then
        fail "$label address must not use documentation-only TEST-NET ranges: $address"
    fi
}

validate_bridge() {
    local label="$1"
    local value="$2"
    [[ -z "$value" ]] && return 0
    case "$value" in
        *[[:space:],]*)
            fail "$label must not contain whitespace or comma"
            ;;
    esac
}

validate_address "control-plane" "$cp_address"
validate_address "worker" "$worker_address"
validate_bridge "bridge name" "$bridge"
validate_bridge "bridge helper" "$bridge_helper"

ip_to_int() {
    local address="$1"
    local a b c d
    IFS=. read -r a b c d <<<"$address"
    printf '%u\n' "$(((a << 24) + (b << 16) + (c << 8) + d))"
}

file_sha() {
    sha256sum "$1" | awk '{print $1}'
}

tree_sha() {
    local root="$1"
    (
        cd "$root"
        while IFS= read -r -d '' path; do
            local rel_path="${path#./}"
            local mode
            mode="$(stat -c '%a' "$path")"
            if [[ -L "$path" ]]; then
                fail "ESP artifacts contain unsupported non-regular entry: $rel_path"
            elif [[ -d "$path" ]]; then
                printf 'dir %s %s\n' "$mode" "$rel_path"
            elif [[ -f "$path" ]]; then
                printf 'file %s %s %s\n' "$mode" "$(file_sha "$path")" "$rel_path"
            else
                fail "ESP artifacts contain unsupported non-regular entry: $rel_path"
            fi
        done < <(find . -mindepth 1 -print0 | sort -z)
    ) | sha256sum | awk '{print $1}'
}

address_in_cidr() {
    local address="$1"
    local cidr="$2"
    local network="${cidr%/*}"
    local prefix="${cidr#*/}"
    local address_int network_int mask
    [[ "$prefix" =~ ^[0-9]+$ ]] || return 1
    ((prefix >= 0 && prefix <= 32)) || return 1
    address_int="$(ip_to_int "$address")"
    network_int="$(ip_to_int "$network")"
    if ((prefix == 0)); then
        mask=0
    else
        mask=$((0xffffffff << (32 - prefix) & 0xffffffff))
    fi
    (((address_int & mask) == (network_int & mask)))
}

check_bridge_address() {
	local label="$1"
	local address="$2"
	local cidr matched=0
	local -a cidrs
	local address_int host network prefix network_int mask broadcast_int
    if [[ "$bridge_check" == off ]]; then
        return 0
    fi
    need ip
    [[ -d "/sys/class/net/$bridge/bridge" ]] || fail "bridge $bridge is not a Linux bridge"
    mapfile -t cidrs < <(ip -4 -o addr show dev "$bridge" scope global | awk '{print $4}')
    [[ "${#cidrs[@]}" -gt 0 ]] || fail "bridge $bridge has no global IPv4 address"
	for cidr in "${cidrs[@]}"; do
		host="${cidr%/*}"
		prefix="${cidr#*/}"
		if [[ "$address" == "$host" ]]; then
			fail "$label address $address is assigned to bridge $bridge"
		fi
		if address_in_cidr "$address" "$cidr"; then
			address_int="$(ip_to_int "$address")"
			network="${cidr%/*}"
			network_int="$(ip_to_int "$network")"
			if ((prefix == 0)); then
				mask=0
			else
				mask=$((0xffffffff << (32 - prefix) & 0xffffffff))
			fi
			network_int=$((network_int & mask))
			broadcast_int=$((network_int | (0xffffffff ^ mask)))
			if ((address_int == network_int || address_int == broadcast_int)); then
				fail "$label address $address is the network or broadcast address for $cidr"
			fi
			matched=1
			break
		fi
	done
    [[ "$matched" -eq 1 ]] || fail "$label address $address is not inside any IPv4 subnet on bridge $bridge"
}

check_node_metadata() {
    local path="$1"
    local node="$2"
    local role="$3"
    jq -e \
        --arg node "$node" \
        --arg role "$role" \
        --arg version "$kubernetes_version" '
        .apiVersion == "katl.dev/v1alpha1" and
        .kind == "NodeMetadata" and
        .identity.hostname == $node and
        .systemRole == $role and
        .kubeadm.configRef == $role and
        .kubeadm.configPath == ("/etc/katl/kubeadm/" + $role + "/config.yaml") and
        .kubeadm.intent == $role and
        .kubernetes.payloadVersion == $version
        ' "$path" >/dev/null ||
        fail "$path must be NodeMetadata for $node role=$role Kubernetes=$kubernetes_version"
}

manifest_path() {
    local manifest="$1"
    local query="$2"
    local value base
    value="$(jq -er "$query" "$manifest")"
    base="$(dirname "$manifest")"
    if [[ "$value" == /* ]]; then
        real "$value"
    else
        real "$base/$value"
    fi
}

check_fixture_manifest() {
    local manifest="$1"
    local node="$2"
    local role="$3"
    local disk="$4"
    local format="$5"
    local esp="$6"
    local metadata="$7"
    local manifest_disk manifest_esp manifest_metadata
    local want_disk_sha want_esp_sha want_metadata_sha

    jq -e --arg node "$node" --arg role "$role" '
        .apiVersion == "katl.dev/v1alpha1" and
        .kind == "InstalledRuntimeVMTestFixture" and
        .nodeName == $node and
        .systemRole == $role
        ' "$manifest" >/dev/null ||
        fail "$manifest must describe $node role=$role"

    manifest_disk="$(manifest_path "$manifest" '.disk.path')"
    manifest_esp="$(manifest_path "$manifest" '.espArtifacts.path')"
    manifest_metadata="$(manifest_path "$manifest" '.nodeMetadata.path')"
    [[ "$manifest_disk" == "$disk" ]] || fail "$manifest disk path $manifest_disk does not match $disk"
    [[ "$manifest_esp" == "$esp" ]] || fail "$manifest ESP path $manifest_esp does not match $esp"
    [[ "$manifest_metadata" == "$metadata" ]] || fail "$manifest node metadata path $manifest_metadata does not match $metadata"
    [[ "$(jq -er '.disk.format' "$manifest")" == "$format" ]] || fail "$manifest disk format does not match $format"

    want_disk_sha="$(jq -er '.disk.sha256' "$manifest")"
    want_esp_sha="$(jq -er '.espArtifacts.treeSHA256' "$manifest")"
    want_metadata_sha="$(jq -er '.nodeMetadata.sha256' "$manifest")"
    [[ "$(file_sha "$disk")" == "$want_disk_sha" ]] || fail "$manifest disk sha256 does not match $disk"
    [[ "$(tree_sha "$esp")" == "$want_esp_sha" ]] || fail "$manifest ESP treeSHA256 does not match $esp"
    [[ "$(file_sha "$metadata")" == "$want_metadata_sha" ]] || fail "$manifest node metadata sha256 does not match $metadata"
}

check_bridge_address "control-plane" "$cp_address"
check_bridge_address "worker" "$worker_address"
check_node_metadata "$cp_node_metadata" "cp-1" "control-plane"
check_node_metadata "$worker_node_metadata" "worker-1" "worker"
check_fixture_manifest "$cp_fixture_manifest" "cp-1" "control-plane" "$cp_disk" "$cp_format" "$cp_esp_artifacts" "$cp_node_metadata"
check_fixture_manifest "$worker_fixture_manifest" "worker-1" "worker" "$worker_disk" "$worker_format" "$worker_esp_artifacts" "$worker_node_metadata"

mkdir -p "$state_dir"

"$repo_root/scripts/check-installed-disk-smoke" \
    --disk "$cp_disk" \
    --format "$cp_format" \
    --esp-artifacts "$cp_esp_artifacts" \
    --state-dir "$state_dir/control-plane-preflight" \
    --preflight-only >/dev/null

"$repo_root/scripts/check-installed-disk-smoke" \
    --disk "$worker_disk" \
    --format "$worker_format" \
    --esp-artifacts "$worker_esp_artifacts" \
    --state-dir "$state_dir/worker-preflight" \
    --preflight-only >/dev/null

if [[ "$check_only" -eq 1 ]]; then
    echo "ok: two-node kubeadm fixture bindings valid"
    exit 0
fi

mkdir -p "$(dirname "$env_file")" "$(dirname "$run_script")" "$(dirname "$manifest")"
{
    printf '# Generated by scripts/resolve-two-node-kubeadm-fixtures\n'
    printf '# Source this file before running the two-node kubeadm join VM smoke.\n'
    printf 'export KATL_VMTEST_RUN=%q\n' "1"
    printf 'export KATL_VMTEST_KEEP=%q\n' "$vmtest_keep"
    printf 'export KATL_VMTEST_STATE_ROOT=%q\n' "$vmtest_state_root"
    if [[ -n "$cp_published_dir" ]]; then
        printf 'export KATL_CONTROL_PLANE_PUBLISHED_FIXTURE_DIR=%q\n' "$cp_published_dir"
    fi
    printf 'export KATL_CONTROL_PLANE_INSTALLED_DISK=%q\n' "$cp_disk"
    printf 'export KATL_CONTROL_PLANE_INSTALLED_DISK_FORMAT=%q\n' "$cp_format"
    printf 'export KATL_CONTROL_PLANE_INSTALLED_ESP_ARTIFACTS=%q\n' "$cp_esp_artifacts"
    printf 'export KATL_CONTROL_PLANE_NODE_METADATA=%q\n' "$cp_node_metadata"
    printf 'export KATL_CONTROL_PLANE_FIXTURE_MANIFEST=%q\n' "$cp_fixture_manifest"
    if [[ -n "$worker_published_dir" ]]; then
        printf 'export KATL_WORKER_PUBLISHED_FIXTURE_DIR=%q\n' "$worker_published_dir"
    fi
    printf 'export KATL_WORKER_INSTALLED_DISK=%q\n' "$worker_disk"
    printf 'export KATL_WORKER_INSTALLED_DISK_FORMAT=%q\n' "$worker_format"
    printf 'export KATL_WORKER_INSTALLED_ESP_ARTIFACTS=%q\n' "$worker_esp_artifacts"
    printf 'export KATL_WORKER_NODE_METADATA=%q\n' "$worker_node_metadata"
    printf 'export KATL_WORKER_FIXTURE_MANIFEST=%q\n' "$worker_fixture_manifest"
    printf 'export KATL_CONTROL_PLANE_ADDRESS=%q\n' "$cp_address"
    printf 'export KATL_WORKER_ADDRESS=%q\n' "$worker_address"
    printf 'export KATL_KUBERNETES_VERSION=%q\n' "$kubernetes_version"
    printf 'export KATL_VMTEST_BRIDGE=%q\n' "$bridge"
    printf 'export KATL_TWO_NODE_FIXTURES_BRIDGE_CHECK=%q\n' "$bridge_check"
    if [[ -n "$bridge_helper" ]]; then
        printf 'export KATL_QEMU_BRIDGE_HELPER=%q\n' "$bridge_helper"
    fi
} >"$env_file"

{
    printf '#!/usr/bin/env bash\n'
    printf 'set -euo pipefail\n'
    printf 'cd %q\n' "$repo_root"
    printf 'source %q\n' "$env_file"
    printf 'recheck_dir=%q\n' "$state_dir/recheck"
    # shellcheck disable=SC2016
    printf 'recheck_args=(--control-plane-disk "$KATL_CONTROL_PLANE_INSTALLED_DISK" --worker-disk "$KATL_WORKER_INSTALLED_DISK" --control-plane-esp "$KATL_CONTROL_PLANE_INSTALLED_ESP_ARTIFACTS" --worker-esp "$KATL_WORKER_INSTALLED_ESP_ARTIFACTS" --control-plane-metadata "$KATL_CONTROL_PLANE_NODE_METADATA" --worker-metadata "$KATL_WORKER_NODE_METADATA" --control-plane-fixture "$KATL_CONTROL_PLANE_FIXTURE_MANIFEST" --worker-fixture "$KATL_WORKER_FIXTURE_MANIFEST" --control-plane-address "$KATL_CONTROL_PLANE_ADDRESS" --worker-address "$KATL_WORKER_ADDRESS" --control-plane-format "${KATL_CONTROL_PLANE_INSTALLED_DISK_FORMAT:-raw}" --worker-format "${KATL_WORKER_INSTALLED_DISK_FORMAT:-raw}" --kubernetes-version "${KATL_KUBERNETES_VERSION:-v1.36.1}" --bridge "$KATL_VMTEST_BRIDGE" --state-dir "$recheck_dir" --check-only)\n'
    # shellcheck disable=SC2016
    printf 'if [[ -n "${KATL_QEMU_BRIDGE_HELPER:-}" ]]; then\n'
    # shellcheck disable=SC2016
    printf '    recheck_args+=(--bridge-helper "$KATL_QEMU_BRIDGE_HELPER")\n'
    printf 'fi\n'
    # shellcheck disable=SC2016
    printf '%q "${recheck_args[@]}"\n' "$repo_root/scripts/resolve-two-node-kubeadm-fixtures"
    # shellcheck disable=SC2016
    printf 'GOCACHE="${GOCACHE:-/tmp/katl-go-cache}" go test ./cmd/katlctl -run '\''^TestInstalledRuntimeTwoNodeKubeadmJoinSmoke$'\'' -count=1 -timeout 45m -katl.vmtest.run\n'
} >"$run_script"
chmod +x "$run_script"

cat >"$manifest" <<EOF
{
  "apiVersion": "katl.dev/v1alpha1",
  "kind": "TwoNodeKubeadmVMTestFixtures",
  "controlPlane": {
    "nodeName": "cp-1",
    "systemRole": "control-plane",
    "disk": "$(json "$cp_disk")",
    "diskFormat": "$(json "$cp_format")",
    "espArtifacts": "$(json "$cp_esp_artifacts")",
    "nodeMetadata": "$(json "$cp_node_metadata")",
    "fixtureManifest": "$(json "$cp_fixture_manifest")",
    "address": "$(json "$cp_address")",
    "preflightRunDir": "$(json "$state_dir/control-plane-preflight")"
    $(if [[ -n "$cp_published_dir" ]]; then printf ',\n    "publishedFixtureDir": "%s"' "$(json "$cp_published_dir")"; fi)
  },
  "worker": {
    "nodeName": "worker-1",
    "systemRole": "worker",
    "disk": "$(json "$worker_disk")",
    "diskFormat": "$(json "$worker_format")",
    "espArtifacts": "$(json "$worker_esp_artifacts")",
    "nodeMetadata": "$(json "$worker_node_metadata")",
    "fixtureManifest": "$(json "$worker_fixture_manifest")",
    "address": "$(json "$worker_address")",
    "preflightRunDir": "$(json "$state_dir/worker-preflight")"
    $(if [[ -n "$worker_published_dir" ]]; then printf ',\n    "publishedFixtureDir": "%s"' "$(json "$worker_published_dir")"; fi)
  },
  "bridge": "$(json "$bridge")",
  "kubernetesVersion": "$(json "$kubernetes_version")",
  "envFile": "$(json "$env_file")",
  "runScript": "$(json "$run_script")"
