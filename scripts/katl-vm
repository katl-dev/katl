#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'USAGE'
Usage: scripts/katl-vm [options]

Boot the M1 installer image with direct QEMU and optional serial smoke matching.

Options:
  --uki PATH              Installer UKI to boot as EFI/BOOT/BOOTX64.EFI
  --image PATH            Raw disk image to boot (default: build/mkosi/katl-installer.raw)
  --target-disk PATH      Writable installer target disk to attach; created if missing
  --target-disk-size SIZE Size for a created target disk (default: 20G)
  --target-disk-format F  Target disk format: qcow2 or raw (default: qcow2)
  --target-disk-cleanup   Remove a target disk created by this run after successful exit
  --handoff-manifest PATH POST manifest after detecting local handoff serial output
  --handoff-timeout DUR   Time to wait for handoff serial output (default: 90s)
  --handoff-post-url URL  Host-reachable POST /v1/install URL override
  --handoff-host-port N   Forward host 127.0.0.1:N to guest handoff port
  --handoff-guest-port N  Guest handoff port for host forwarding (default: 8080)
  --serial-log PATH       Serial log path (default: build/qemu/katl-serial.log)
  --state-dir PATH        QEMU scratch directory (default: build/qemu)
  --firmware-code PATH    OVMF code image, or KATL_OVMF_CODE
  --firmware-vars PATH    OVMF vars template, or KATL_OVMF_VARS
  --kvm auto|on|off       Acceleration policy (default: auto)
  --timeout DURATION      Smoke timeout, passed to timeout(1); defaults to 90s with --expect
  --expect TEXT           Exit successfully when TEXT appears in the serial log
  --ram SIZE              Guest RAM in MiB (default: 2048)
  --cpus N                Guest CPU count (default: 2)
  -h, --help              Show this help
USAGE
}

repo_root="$(git rev-parse --show-toplevel)"
image="$repo_root/build/mkosi/katl-installer.raw"
uki=
target_disk=
target_disk_size=20G
target_disk_format=qcow2
target_disk_cleanup=0
target_disk_created=0
handoff_manifest=
handoff_timeout=90s
handoff_post_url=
handoff_host_port=
handoff_guest_port=8080
serial_log="$repo_root/build/qemu/katl-serial.log"
state_dir="$repo_root/build/qemu"
firmware_code="${KATL_OVMF_CODE:-}"
firmware_vars="${KATL_OVMF_VARS:-}"
kvm=auto
timeout_duration=
expect=
ram=2048
cpus=2

require_value() {
    local option="$1"
    local value="${2:-}"
    if [[ -z "$value" || "$value" == --* ]]; then
        echo "error: $option requires a value" >&2
        exit 2
    fi
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --uki|-uki)
            require_value "$1" "${2:-}"
            uki="$2"
            shift 2
            ;;
        --image|-image)
            require_value "$1" "${2:-}"
            image="$2"
            shift 2
            ;;
        --target-disk|-target-disk)
            require_value "$1" "${2:-}"
            target_disk="$2"
            shift 2
            ;;
        --target-disk-size|-target-disk-size)
            require_value "$1" "${2:-}"
            target_disk_size="$2"
            shift 2
            ;;
        --target-disk-format|-target-disk-format)
            require_value "$1" "${2:-}"
            target_disk_format="$2"
            shift 2
            ;;
        --target-disk-cleanup|-target-disk-cleanup)
            target_disk_cleanup=1
            shift
            ;;
        --handoff-manifest|-handoff-manifest)
            require_value "$1" "${2:-}"
            handoff_manifest="$2"
            shift 2
            ;;
        --handoff-timeout|-handoff-timeout)
            require_value "$1" "${2:-}"
            handoff_timeout="$2"
            shift 2
            ;;
        --handoff-post-url|-handoff-post-url)
            require_value "$1" "${2:-}"
            handoff_post_url="$2"
            shift 2
            ;;
        --handoff-host-port|-handoff-host-port)
            require_value "$1" "${2:-}"
            handoff_host_port="$2"
            shift 2
            ;;
        --handoff-guest-port|-handoff-guest-port)
            require_value "$1" "${2:-}"
            handoff_guest_port="$2"
            shift 2
            ;;
        --serial-log|-serial-log)
            require_value "$1" "${2:-}"
            serial_log="$2"
            shift 2
            ;;
        --state-dir|-state-dir)
            require_value "$1" "${2:-}"
            state_dir="$2"
            shift 2
            ;;
        --firmware-code|-firmware-code)
            require_value "$1" "${2:-}"
            firmware_code="$2"
            shift 2
            ;;
        --firmware-vars|-firmware-vars)
            require_value "$1" "${2:-}"
            firmware_vars="$2"
            shift 2
            ;;
        --kvm|-kvm)
            require_value "$1" "${2:-}"
            kvm="$2"
            shift 2
            ;;
        --timeout|-timeout)
            require_value "$1" "${2:-}"
            timeout_duration="$2"
            shift 2
            ;;
        --expect|-expect)
            require_value "$1" "${2:-}"
            expect="$2"
            shift 2
            ;;
        --ram|-ram)
            require_value "$1" "${2:-}"
            ram="$2"
            shift 2
            ;;
        --cpus|-cpus)
            require_value "$1" "${2:-}"
            cpus="$2"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "error: unknown argument: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

case "$kvm" in
    auto|on|off) ;;
    *)
        echo "error: --kvm must be auto, on, or off" >&2
        exit 2
        ;;
esac

case "$target_disk_format" in
    qcow2|raw) ;;
    *)
        echo "error: --target-disk-format must be qcow2 or raw" >&2
        exit 2
        ;;
esac

if [[ -n "$uki" && ! -f "$uki" ]]; then
    echo "error: installer UKI not found: $uki" >&2
    exit 1
fi
if [[ -n "$handoff_manifest" && ! -f "$handoff_manifest" ]]; then
    echo "error: handoff manifest not found: $handoff_manifest" >&2
    exit 1
fi
if [[ -n "$handoff_manifest" && -z "$handoff_post_url" && -z "$handoff_host_port" ]]; then
    handoff_host_port=18080
fi

if [[ -z "$uki" ]]; then
    if [[ ! -f "$image" ]]; then
        echo "error: image not found: $image" >&2
        echo "run scripts/mkosi -f build first, or pass --uki PATH" >&2
        exit 1
    fi
elif [[ -n "$image" && "$image" != "$repo_root/build/mkosi/katl-installer.raw" && ! -f "$image" ]]; then
    echo "error: image not found: $image" >&2
    exit 1
fi

qemu="$(command -v qemu-system-x86_64 || true)"
if [[ -z "$qemu" ]]; then
    echo "error: qemu-system-x86_64 not found in PATH" >&2
    exit 1
fi
qemu_img="$(command -v qemu-img || true)"
curl="$(command -v curl || true)"
if [[ -n "$handoff_manifest" && -z "$curl" ]]; then
    echo "error: curl not found in PATH; cannot post handoff manifest" >&2
    exit 1
fi

pick_first_file() {
    local path
    for path in "$@"; do
        [[ "$path" == *OVMF-xen* ]] && continue
        if [[ -f "$path" ]]; then
            printf '%s\n' "$path"
            return 0
        fi
    done
    return 1
}

if [[ -z "$firmware_code" ]]; then
    firmware_code="$(pick_first_file \
        /usr/share/OVMF/OVMF_CODE.fd \
        /usr/share/OVMF/OVMF_CODE_4M.fd \
        /usr/share/edk2/ovmf/OVMF_CODE.fd \
        /usr/share/qemu/OVMF_CODE.fd \
        /run/current-system/sw/share/qemu/edk2-x86_64-code.fd \
        /nix/store/*-OVMF-*-fd/FV/OVMF_CODE.fd || true)"
fi

if [[ -z "$firmware_vars" && -n "$firmware_code" ]]; then
    firmware_dir="$(dirname "$firmware_code")"
    firmware_vars="$(pick_first_file \
        "$firmware_dir/OVMF_VARS.fd" \
        "$firmware_dir/OVMF_VARS_4M.fd" \
        "$firmware_dir/OVMF_VARS.ms.fd" \
        "$firmware_dir/edk2-i386-vars.fd" \
        "$firmware_dir/../OVMF_VARS.fd" || true)"
fi

if [[ -z "$firmware_vars" ]]; then
    firmware_vars="$(pick_first_file \
        /usr/share/OVMF/OVMF_VARS.fd \
        /usr/share/OVMF/OVMF_VARS_4M.fd \
        /usr/share/edk2/ovmf/OVMF_VARS.fd \
        /usr/share/qemu/OVMF_VARS.fd \
        /usr/share/qemu/edk2-i386-vars.fd \
        /nix/store/*-OVMF-*-fd/FV/OVMF_VARS.fd || true)"
fi

if [[ -z "$firmware_code" || -z "$firmware_vars" ]]; then
    echo "error: OVMF firmware not found" >&2
    echo "set KATL_OVMF_CODE/KATL_OVMF_VARS or pass --firmware-code/--firmware-vars" >&2
    exit 1
fi
if [[ ! -f "$firmware_code" ]]; then
    echo "error: OVMF code image not found: $firmware_code" >&2
    exit 1
fi
if [[ ! -r "$firmware_code" ]]; then
    echo "error: OVMF code image is not readable: $firmware_code" >&2
    exit 1
fi
if [[ ! -f "$firmware_vars" ]]; then
    echo "error: OVMF vars template not found: $firmware_vars" >&2
    exit 1
fi
if [[ ! -r "$firmware_vars" ]]; then
    echo "error: OVMF vars template is not readable: $firmware_vars" >&2
    exit 1
fi

if [[ -n "$target_disk" && ! -e "$target_disk" ]]; then
    if [[ -z "$qemu_img" ]]; then
        echo "error: qemu-img not found in PATH; cannot create target disk: $target_disk" >&2
        exit 1
    fi
    mkdir -p "$(dirname "$target_disk")"
    "$qemu_img" create -f "$target_disk_format" "$target_disk" "$target_disk_size" >/dev/null
    target_disk_created=1
fi
if [[ -n "$target_disk" && ! -f "$target_disk" ]]; then
    echo "error: target disk is not a regular file: $target_disk" >&2
    exit 1
fi

mkdir -p "$state_dir/tmp" "$(dirname "$serial_log")"
: >"$serial_log"

vars_copy="$state_dir/OVMF_VARS.fd"
cp "$firmware_vars" "$vars_copy"
chmod u+w "$vars_copy"

accel=tcg
if [[ "$kvm" == on || "$kvm" == auto ]]; then
    if [[ -e /dev/kvm ]]; then
        accel=kvm
    elif [[ "$kvm" == on ]]; then
        echo "error: --kvm=on requested but /dev/kvm is not visible" >&2
        exit 1
    else
        echo "KVM unavailable: /dev/kvm is not visible; using QEMU TCG" >&2
    fi
fi

echo "serial log: ${serial_log#"$repo_root"/}" >&2
echo "firmware: $firmware_code" >&2
echo "acceleration: $accel" >&2

boot_drives=()
drive_index=0
add_virtio_drive() {
    local spec="$1"
    boot_drives+=(-drive "if=virtio,index=$drive_index,$spec")
    drive_index=$((drive_index + 1))
}

if [[ -n "$uki" ]]; then
    efi_tree="$state_dir/efi"
    rm -rf "$efi_tree"
    mkdir -p "$efi_tree/EFI/BOOT"
    cp "$uki" "$efi_tree/EFI/BOOT/BOOTX64.EFI"
    add_virtio_drive "format=raw,file=fat:rw:$efi_tree"
    echo "installer UKI: $uki" >&2
    echo "EFI boot tree: ${efi_tree#"$repo_root"/}" >&2
    if [[ -f "$image" ]]; then
        add_virtio_drive "format=raw,file=$image,snapshot=on"
        echo "root image: $image" >&2
    fi
else
    add_virtio_drive "format=raw,file=$image,snapshot=on"
    echo "image: $image" >&2
fi
if [[ -n "$target_disk" ]]; then
    add_virtio_drive "format=$target_disk_format,file=$target_disk"
    echo "target disk: $target_disk ($target_disk_format, created=$target_disk_created)" >&2
fi
if [[ -n "$handoff_manifest" ]]; then
    echo "handoff manifest: $handoff_manifest" >&2
    if [[ -n "$handoff_host_port" ]]; then
        echo "handoff forward: 127.0.0.1:$handoff_host_port -> guest :$handoff_guest_port" >&2
    fi
fi

netdev="user,id=net0"
if [[ -n "$handoff_host_port" ]]; then
    netdev+=",hostfwd=tcp:127.0.0.1:$handoff_host_port-:$handoff_guest_port"
fi

# shellcheck disable=SC2054
qemu_args=(
    -machine "q35,accel=$accel"
    -cpu max
    -smp "$cpus"
    -m "$ram"
    -display none
    -monitor none
    -serial "file:$serial_log"
    -drive "if=pflash,format=raw,readonly=on,file=$firmware_code"
    -drive "if=pflash,format=raw,file=$vars_copy"
    "${boot_drives[@]}"
    -device virtio-rng-pci
    -netdev "$netdev"
    -device virtio-net-pci,netdev=net0
)

TMPDIR="$state_dir/tmp" "$qemu" "${qemu_args[@]}" &
qemu_pid=$!

# shellcheck disable=SC2329
cleanup() {
    local status=$?
    if kill -0 "$qemu_pid" >/dev/null 2>&1; then
        kill "$qemu_pid" >/dev/null 2>&1 || true
        wait "$qemu_pid" >/dev/null 2>&1 || true
    fi
    if [[ "$status" -eq 0 && "$target_disk_cleanup" -eq 1 && "$target_disk_created" -eq 1 ]]; then
        rm -f "$target_disk"
    fi
}
trap cleanup EXIT INT TERM

submit_handoff() (
    set -euo pipefail

    local announcement_file="$state_dir/handoff.announcement"
    local response_file="$state_dir/handoff-response.json"
    local announcement url token post_url curl_status

    set +e
    # shellcheck disable=SC2016
    timeout "$handoff_timeout" bash -c '
        set -euo pipefail
        serial_log="$1"
        qemu_pid="$2"
        while true; do
            line="$(grep -F "katlos-install waiting for config at " "$serial_log" | tail -n 1 || true)"
            if [[ "$line" == *"/v1/install token="* ]]; then
                printf "%s\n" "$line"
                exit 0
            fi
            if ! kill -0 "$qemu_pid" >/dev/null 2>&1; then
                exit 125
            fi
            sleep 0.25
        done
    ' bash "$serial_log" "$qemu_pid" >"$announcement_file"
    curl_status=$?
    set -e

    if [[ "$curl_status" -eq 124 ]]; then
        echo "error: timed out after $handoff_timeout waiting for handoff announcement" >&2
        return 124
    fi
    if [[ "$curl_status" -ne 0 ]]; then
        echo "error: QEMU exited before handoff announcement appeared" >&2
        return "$curl_status"
    fi

    announcement="$(<"$announcement_file")"
    url="${announcement#* config at }"
    url="${url%% token=*}"
    token="${announcement##* token=}"
    token="${token%%[[:space:]]*}"

    if [[ -z "$url" || "$url" == "$announcement" || -z "$token" || "$token" == "$announcement" ]]; then
        echo "error: could not parse handoff URL/token from serial announcement: $announcement" >&2
        return 1
    fi

    post_url="$url"
    if [[ -n "$handoff_post_url" ]]; then
        post_url="$handoff_post_url"
    elif [[ -n "$handoff_host_port" ]]; then
        post_url="http://127.0.0.1:$handoff_host_port/v1/install"
    fi

    echo "handoff URL: $url" >&2
    echo "handoff POST: $post_url" >&2

    set +e
    "$curl" --fail-with-body --show-error --silent \
        --connect-timeout 5 \
        --max-time 30 \
        --request POST \
        --header "Authorization: Bearer $token" \
        --header "Content-Type: application/json" \
        --data-binary "@$handoff_manifest" \
        "$post_url" >"$response_file"
    curl_status=$?
    set -e

    if [[ "$curl_status" -ne 0 ]]; then
        echo "error: handoff POST failed with curl status $curl_status; response follows" >&2
        cat "$response_file" >&2 || true
        return "$curl_status"
    fi

    echo "handoff response: ${response_file#"$repo_root"/}" >&2
)

handoff_pid=
if [[ -n "$handoff_manifest" ]]; then
    submit_handoff &
    handoff_pid=$!
fi

if [[ -z "$expect" ]]; then
    if [[ -n "$handoff_pid" ]]; then
        wait "$handoff_pid"
    fi
    wait "$qemu_pid"
    exit $?
fi

if [[ -z "$timeout_duration" ]]; then
    timeout_duration=90s
fi

set +e
# shellcheck disable=SC2016
timeout "$timeout_duration" bash -c '
    set -euo pipefail
    expect="$1"
    serial_log="$2"
    qemu_pid="$3"
    while true; do
        if grep -Fq -- "$expect" "$serial_log"; then
            exit 0
        fi
        if ! kill -0 "$qemu_pid" >/dev/null 2>&1; then
            exit 125
        fi
        sleep 0.25
    done
' bash "$expect" "$serial_log" "$qemu_pid"
status=$?
set -e

if [[ "$status" -eq 0 ]]; then
    if [[ -n "$handoff_pid" ]]; then
        wait "$handoff_pid"
    fi
    echo "matched serial signal \"$expect\" in ${serial_log#"$repo_root"/}" >&2
    exit 0
fi

if [[ "$status" -eq 124 ]]; then
    echo "error: timed out after $timeout_duration waiting for \"$expect\"" >&2
else
    echo "error: QEMU exited before serial signal \"$expect\" appeared" >&2
fi

tail -n 80 "$serial_log" >&2 || true
exit "$status"
