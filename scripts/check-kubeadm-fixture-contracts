#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT

fail() {
    echo "error: $*" >&2
    exit 1
}

need() {
    command -v "$1" >/dev/null 2>&1 || fail "$1 is required"
}

need jq
need mktemp

make_esp() {
    local root="$1"
    mkdir -p "$root/loader/entries"
    cat >"$root/loader/entries/katl.conf" <<'EOF'
title Katl
linux /EFI/Linux/katl.efi
options root=PARTUUID=11111111-2222-3333-4444-555555555555 rootfstype=squashfs ro katl.generation=test systemd.machine_id=0123456789abcdef0123456789abcdef
EOF
}

make_metadata() {
    local path="$1"
    local node="$2"
    local role="$3"
    local config_path="/etc/katl/kubeadm/$role/config.yaml"
    mkdir -p "$(dirname "$path")"
    cat >"$path" <<EOF
{
  "apiVersion": "katl.dev/v1alpha1",
  "kind": "NodeMetadata",
  "identity": {"hostname": "$node"},
  "systemRole": "$role",
  "kubeadm": {
    "configRef": "$role",
    "configPath": "$config_path",
    "intent": "$role"
  },
  "kubernetes": {
    "payloadVersion": "v1.36.1",
    "activationPath": "/run/extensions/selected-kubernetes.raw"
  }
}
EOF
}

publish_fixture() {
    local node="$1"
    local role="$2"
    local source_run="$tmpdir/vmtest-state/first-install-installed-runtime-fixture-$node"
    local fixture_dir="$source_run/manifests/installed-runtime-fixture"
    local source_disk="$tmpdir/$node/source.raw"
    local source_esp="$tmpdir/$node/source-esp"
    local source_metadata="$tmpdir/$node/source-node.json"
    local published_dir="$tmpdir/published-$node"

    mkdir -p "$(dirname "$source_disk")"
    printf 'disk %s\n' "$node" >"$source_disk"
    make_esp "$source_esp"
    make_metadata "$source_metadata" "$node" "$role"

    "$repo_root/scripts/create-installed-runtime-fixture" \
        --disk "$source_disk" \
        --esp-artifacts "$source_esp" \
        --node-metadata "$source_metadata" \
        --format raw \
        --state-dir "$fixture_dir" >/dev/null

    "$repo_root/scripts/publish-first-install-runtime-fixture" \
        --vmtest-state-root "$tmpdir/vmtest-state" \
        --state-dir "$published_dir" \
        --format raw \
        --node-name "$node" \
        --system-role "$role" >/dev/null

    printf '%s\n' "$published_dir"
}

expect_failure() {
    local want="$1"
    shift
    local log="$tmpdir/failure.log"
    if "$@" >"$log" 2>&1; then
        fail "command unexpectedly succeeded: $*"
    fi
    grep -Fq "$want" "$log" || {
        cat "$log" >&2
        fail "command did not fail with expected text: $want"
    }
}

published_dir="$(publish_fixture cp-1 control-plane)"
worker_published_dir="$(publish_fixture worker-1 worker)"
cp2_published_dir="$(publish_fixture cp-2 control-plane)"
cp3_published_dir="$(publish_fixture cp-3 control-plane)"

published_manifest="$published_dir/published-first-install-runtime-fixture.json"
jq -e '
    .apiVersion == "katl.dev/v1alpha1" and
    .kind == "PublishedFirstInstallRuntimeFixture" and
    .nodeName == "cp-1" and
    .systemRole == "control-plane"
    ' "$published_manifest" >/dev/null ||
    fail "published fixture manifest did not record cp-1 control-plane identity"

env KATL_TWO_NODE_FIXTURES_BRIDGE_CHECK=off \
    "$repo_root/scripts/resolve-two-node-kubeadm-fixtures" \
    --control-plane-published-dir "$published_dir" \
    --worker-published-dir "$worker_published_dir" \
    --control-plane-address 10.44.0.10 \
    --worker-address 10.44.0.11 \
    --bridge katlbr0 \
    --state-dir "$tmpdir/two-node-valid" \
    --check-only >/dev/null

bootstrap_manifest="$tmpdir/user bootstrap/01-cni.yaml"
mkdir -p "$(dirname "$bootstrap_manifest")"
cat >"$bootstrap_manifest" <<'EOF'
apiVersion: v1
kind: Namespace
metadata:
  name: test-bootstrap
EOF

env KATL_TWO_NODE_FIXTURES_BRIDGE_CHECK=off \
    "$repo_root/scripts/resolve-two-node-kubeadm-fixtures" \
    --control-plane-published-dir "$published_dir" \
    --worker-published-dir "$worker_published_dir" \
    --control-plane-address 10.44.0.10 \
    --worker-address 10.44.0.11 \
    --bridge katlbr0 \
    --bootstrap-manifest "$bootstrap_manifest" \
    --bootstrap-wait nodes-ready \
    --bootstrap-wait pods-ready:kube-system:k8s-app=kube-dns \
    --state-dir "$tmpdir/two-node-bootstrap" >/dev/null

resolved_bootstrap_manifest="$(realpath -m "$bootstrap_manifest")"
jq -e \
    --arg manifest "$resolved_bootstrap_manifest" '
    .bootstrap.manifests == [$manifest] and
    .bootstrap.waits == ["nodes-ready", "pods-ready:kube-system:k8s-app=kube-dns"]
    ' "$tmpdir/two-node-bootstrap/fixtures.json" >/dev/null ||
    fail "two-node resolver did not record bootstrap fixture inputs"
grep -Fq "KATL_BOOTSTRAP_MANIFESTS=" "$tmpdir/two-node-bootstrap/vmtest.env" ||
    fail "two-node resolver env did not export bootstrap manifests"
grep -Fq "KATL_BOOTSTRAP_WAITS=" "$tmpdir/two-node-bootstrap/vmtest.env" ||
    fail "two-node resolver env did not export bootstrap waits"
grep -Fq -- "--bootstrap-manifest" "$tmpdir/two-node-bootstrap/run-two-node-kubeadm-join.sh" ||
    fail "two-node resolver wrapper did not recheck bootstrap manifests"
grep -Fq -- "--bootstrap-wait" "$tmpdir/two-node-bootstrap/run-two-node-kubeadm-join.sh" ||
    fail "two-node resolver wrapper did not recheck bootstrap waits"

env KATL_THREE_CONTROL_PLANE_FIXTURES_BRIDGE_CHECK=off \
    "$repo_root/scripts/resolve-three-control-plane-kubeadm-fixtures" \
    --cp1-published-dir "$published_dir" \
    --cp2-published-dir "$cp2_published_dir" \
    --cp3-published-dir "$cp3_published_dir" \
    --cp1-address 10.44.0.10 \
    --cp2-address 10.44.0.11 \
    --cp3-address 10.44.0.12 \
    --bridge katlbr0 \
    --state-dir "$tmpdir/three-cp-valid" \
    --check-only >/dev/null

wrong_two_node="$tmpdir/wrong-two-node"
mkdir -p "$wrong_two_node"
jq '.nodeName = "worker-1" | .systemRole = "worker"' "$published_manifest" >"$wrong_two_node/published-first-install-runtime-fixture.json"

expect_failure "control-plane published fixture manifest is invalid for cp-1 role=control-plane" \
    env KATL_TWO_NODE_FIXTURES_BRIDGE_CHECK=off \
    "$repo_root/scripts/resolve-two-node-kubeadm-fixtures" \
    --control-plane-published-dir "$wrong_two_node" \
    --control-plane-address 10.44.0.10 \
    --worker-address 10.44.0.11 \
    --bridge katlbr0 \
    --check-only

expect_failure "bootstrap manifest not found" \
    env KATL_TWO_NODE_FIXTURES_BRIDGE_CHECK=off \
    "$repo_root/scripts/resolve-two-node-kubeadm-fixtures" \
    --control-plane-published-dir "$published_dir" \
    --worker-published-dir "$worker_published_dir" \
    --control-plane-address 10.44.0.10 \
    --worker-address 10.44.0.11 \
    --bridge katlbr0 \
    --bootstrap-manifest "$tmpdir/missing-bootstrap.yaml" \
    --check-only

wrong_three_cp="$tmpdir/wrong-three-cp"
mkdir -p "$wrong_three_cp"
jq '.nodeName = "cp-2" | .systemRole = "worker"' "$published_manifest" >"$wrong_three_cp/published-first-install-runtime-fixture.json"

expect_failure "cp-1 published fixture manifest is invalid for cp-1 role=control-plane" \
    env KATL_THREE_CONTROL_PLANE_FIXTURES_BRIDGE_CHECK=off \
    "$repo_root/scripts/resolve-three-control-plane-kubeadm-fixtures" \
    --cp1-published-dir "$wrong_three_cp" \
    --cp1-address 10.44.0.10 \
    --cp2-address 10.44.0.11 \
    --cp3-address 10.44.0.12 \
    --bridge katlbr0 \
    --check-only

echo "ok: kubeadm fixture contracts valid"
