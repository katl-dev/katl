#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
build_dir="${KATL_MKOSI_BUILD_DIR:-$repo_root/_build/mkosi}"
architecture="${KATL_ARCHITECTURE:-$(uname -m)}"
go_command="${KATL_RELEASE_GO:-go}"

fail() {
    echo "error: $*" >&2
    exit 1
}

usage() {
    cat >&2 <<'EOF'
usage: scripts/katl-release-artifacts version EVENT REF_TYPE REF_NAME [MANUAL_VERSION]
       scripts/katl-release-artifacts notes VERSION
       scripts/katl-release-artifacts build-katlctl VERSION
       scripts/katl-release-artifacts stage VERSION OUTPUT_DIR
EOF
    exit 2
}

is_katlos_tag() {
    local tag="$1"
    [[ "$tag" =~ ^v[0-9]{4}\.([1-9]|1[0-2])\.(0|[1-9][0-9]*)(-(dev|alpha|beta|rc)\.(0|[1-9][0-9]*))?$ ]]
}

previous_katlos_tag() {
    local target="$1"
    local current_tag="$2"
    local commit tag

    while IFS= read -r commit; do
        while IFS= read -r tag; do
            is_katlos_tag "$tag" || continue
            [[ "$tag" != "$current_tag" ]] || continue
            printf '%s\n' "$tag"
            return 0
        done < <(git tag --points-at "$commit" --list 'v*' --sort=refname)
    done < <(git rev-list --first-parent "$target")
}

generate_release_notes() {
    local version="$1"
    local current_tag="v$version"
    local repository_url="${KATL_RELEASE_REPOSITORY_URL:-https://github.com/katl-dev/katl}"
    local target previous_tag="" range commit hash subject short_hash area summary
    local -a commits=()

    validate_version "$version"
    target="${KATL_RELEASE_TARGET:-HEAD}"
    git rev-parse --verify --quiet "$target^{commit}" >/dev/null ||
        fail "release notes target is not a commit: $target"

    previous_tag="$(previous_katlos_tag "$target" "$current_tag" || true)"

    if [[ -n "$previous_tag" ]]; then
        range="$previous_tag..$target"
    else
        range="$target"
    fi

    mapfile -t commits < <(git log --format='%H%x09%s' "$range")
    printf '## Support boundary\n\n'
    if [[ "$version" == *-alpha.* ]]; then
        printf 'This is an experimental alpha release, not a production-supported release. '
    fi
    printf 'Read SUPPORT.md before installation for the tested surface, trust and compatibility limits, recovery scope, and required issue evidence.\n\n'

    printf '## Changes\n\n'
    if ((${#commits[@]} == 0)); then
        printf '_No commits were added since the previous KatlOS release._\n'
    fi
    for commit in "${commits[@]}"; do
        IFS=$'\t' read -r hash subject <<<"$commit"
        [[ -n "$hash" ]] || continue
        short_hash="${hash:0:7}"
        if [[ "$subject" =~ ^([^:]+):[[:space:]]+(.+)$ ]]; then
            area="${BASH_REMATCH[1]}"
            summary="${BASH_REMATCH[2]}"
            printf -- "- **%s:** %s ([\`%s\`](%s/commit/%s))\n" \
                "$area" "$summary" "$short_hash" "$repository_url" "$hash"
        else
            printf -- "- %s ([\`%s\`](%s/commit/%s))\n" \
                "$subject" "$short_hash" "$repository_url" "$hash"
        fi
    done

    printf '\n## Verify downloads\n\n'
    printf 'Release assets have keyless GitHub build-provenance attestations. '
    printf "See \`PROVENANCE.md\` for verification instructions and scope.\n"
    if [[ -n "$previous_tag" ]]; then
        printf "\n**Full comparison:** [\`%s...%s\`](%s/compare/%s...%s)\n" \
            "$previous_tag" "$current_tag" "$repository_url" "$previous_tag" "$current_tag"
    else
        printf '\nThis is the first KatlOS release in the repository history.\n'
    fi
}

validate_version() {
    local version="$1"
    [[ -n "$version" ]] || fail "release version is empty"
    ((${#version} <= 80)) || fail "release version is longer than 80 characters"
    [[ "$version" =~ ^[0-9]{4}\.([1-9]|1[0-2])\.(0|[1-9][0-9]*)(-(dev|alpha|beta|rc)\.(0|[1-9][0-9]*))?$ ]] ||
        fail "release version is not canonical KatlOS CalVer (YYYY.M.PATCH[-dev.N|-alpha.N|-beta.N|-rc.N]): $version"
}

verify_artifact() {
    local name="$1"
    local version="$2"
    local expected_architecture="${3:-$architecture}"
    local digest size

    (cd "$build_dir" && sha256sum -c "$name.sha256")
    digest="$(sha256sum "$build_dir/$name" | awk '{print $1}')"
    size="$(stat -c %s "$build_dir/$name")"
    jq -e --arg digest "$digest" --argjson size "$size" \
        --arg version "$version" --arg architecture "$expected_architecture" \
        '.sha256 == $digest and .sizeBytes == $size and
         .version == $version and .architecture == $architecture' \
        "$build_dir/$name.json" >/dev/null ||
        fail "release metadata does not match artifact or release identity: $name.json"
}

build_katlctl() {
    local version="$1"
    local goarch name path digest size build_commit build_date

    validate_version "$version"
    case "$architecture" in
        x86_64 | amd64)
            goarch=amd64
            ;;
        *)
            fail "katlctl release architecture is unsupported: $architecture"
            ;;
    esac
    name="katlctl-${version}-linux-${goarch}"
    path="$build_dir/$name"
    build_commit="${KATL_BUILD_COMMIT:-$(git -C "$repo_root" rev-parse HEAD)}"
    build_date="${KATL_BUILD_DATE:-1970-01-01T00:00:00Z}"
    mkdir -p "$build_dir"
    (
        cd "$repo_root"
        CGO_ENABLED=0 GOOS=linux GOARCH="$goarch" "$go_command" build \
            -trimpath \
            -ldflags="-s -w -X main.version=$version -X main.commit=$build_commit -X main.date=$build_date" \
            -o "$path" ./cmd/katlctl
    )
    digest="$(sha256sum "$path" | awk '{print $1}')"
    size="$(stat -c %s "$path")"
    printf '%s  %s\n' "$digest" "$name" >"$path.sha256"
    jq -n \
        --arg version "$version" \
        --arg commit "$build_commit" \
        --arg buildDate "$build_date" \
        --arg sha256 "$digest" \
        --argjson sizeBytes "$size" \
        '{
            schemaVersion: 1,
            artifactKind: "katl.operator-cli.v1",
            name: "katlctl",
            version: $version,
            commit: $commit,
            buildDate: $buildDate,
            os: "linux",
            architecture: "amd64",
            sha256: $sha256,
            sizeBytes: $sizeBytes
        }' >"$path.json"
    verify_artifact "$name" "$version" amd64
}

version_for_ref() {
    local event="$1"
    local ref_type="$2"
    local ref_name="$3"
    local manual_version="${4:-}"
    local version

    case "$event" in
        workflow_dispatch)
            version="$manual_version"
            ;;
        push)
            case "$ref_type" in
                tag)
                    version="$ref_name"
                    ;;
                branch)
                    [[ "$ref_name" == release/* ]] ||
                        fail "release branch must start with release/: $ref_name"
                    version="${ref_name#release/}"
                    ;;
                *)
                    fail "unsupported push ref type: $ref_type"
                    ;;
            esac
            ;;
        *)
            fail "unsupported release event: $event"
            ;;
    esac

    if [[ "$version" == v[0-9]* ]]; then
        version="${version#v}"
    fi
    validate_version "$version"
    printf '%s\n' "$version"
}

stage_artifacts() {
    local version="$1"
    local output="$2"
    local name suffix path
    local -a checksum_files=()
    local -a names=(
        "katl-installer.efi"
        "katl-installer.vmlinuz"
        "katl-installer.initrd"
        "katl-installer.iso"
        "katlos-install-${version}-${architecture}.squashfs"
        "katlos-upgrade-${version}-${architecture}.squashfs"
    )
    local operator_name="katlctl-${version}-linux-amd64"
    local installer_packages="katl-installer.packages.tsv"

    validate_version "$version"
    [[ -n "$output" && "$output" != / && "$output" != . ]] ||
        fail "unsafe release output directory: $output"
    if [[ -e "$output" ]]; then
        [[ -d "$output" ]] || fail "release output is not a directory: $output"
        [[ -z "$(find "$output" -mindepth 1 -maxdepth 1 -print -quit)" ]] ||
            fail "release output directory is not empty: $output"
    fi

    for name in "${names[@]}"; do
        for suffix in "" .json .sha256; do
            path="$build_dir/$name$suffix"
            [[ -f "$path" ]] || fail "release artifact is missing: $path"
        done
        verify_artifact "$name" "$version"
    done
    for suffix in "" .json .sha256; do
        path="$build_dir/$operator_name$suffix"
        [[ -f "$path" ]] || fail "release artifact is missing: $path"
    done
    verify_artifact "$operator_name" "$version" amd64
    names+=("$operator_name")
    [[ -f "$build_dir/$installer_packages" ]] || fail "release installer package inventory is missing: $build_dir/$installer_packages"

    mkdir -p "$output"
    for name in "${names[@]}"; do
        for suffix in "" .json .sha256; do
            cp -- "$build_dir/$name$suffix" "$output/"
        done
    done
    cp -- "$build_dir/$installer_packages" "$output/$installer_packages"
    [[ -f "$repo_root/docs/support.md" ]] || fail "release support boundary is missing: $repo_root/docs/support.md"
    cp -- "$repo_root/docs/support.md" "$output/SUPPORT.md"
    cat >"$output/PROVENANCE.md" <<'EOF'
# KatlOS release provenance

Assets published from a KatlOS tag release are covered by keyless GitHub
build-provenance attestations issued to the `katl-dev/katl` release workflow.
Verify a downloaded asset with:

```sh
gh attestation verify <asset> \
  --repo katl-dev/katl \
  --signer-workflow katl-dev/katl/.github/workflows/release-artifacts.yml
```

`SHA256SUMS` and the adjacent `.sha256` files provide transport-integrity
checks. Provenance authenticates the repository and workflow that produced the
bytes; it does not assert that an artifact is vulnerability-free, provide a
Secure Boot signature, or replace Katl's future node-side trust policy.
EOF
    generate_release_notes "$version" >"$output/RELEASE_NOTES.md"
    (
        cd "$output"
        mapfile -d '' checksum_files < <(
            find . -mindepth 1 -maxdepth 1 -type f \
                ! -name SHA256SUMS -printf '%f\0' | sort -z
        )
        ((${#checksum_files[@]} > 0)) || fail "release output has no files to checksum"
        sha256sum "${checksum_files[@]}" >SHA256SUMS
        sha256sum --check SHA256SUMS
    )
}

case "${1:-}" in
    version)
        [[ $# -ge 4 && $# -le 5 ]] || usage
        version_for_ref "$2" "$3" "$4" "${5:-}"
        ;;
    notes)
        [[ $# -eq 2 ]] || usage
        generate_release_notes "$2"
        ;;
    build-katlctl)
        [[ $# -eq 2 ]] || usage
        build_katlctl "$2"
        ;;
    stage)
        [[ $# -eq 3 ]] || usage
        stage_artifacts "$2" "$3"
        ;;
    *)
        usage
        ;;
esac
