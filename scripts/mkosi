#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
image="${KATL_MKOSI_IMAGE:-localhost/katl-mkosi-builder:fedora-44-go-squashfs}"
runtime="${KATL_CONTAINER_RUNTIME:-}"
build_commit="$(git -C "$repo_root" describe --always --dirty --abbrev=12 2>/dev/null || printf unknown)"
kube_manifest="$repo_root/mkosi.profiles/kubernetes-sysext/kubernetes.env"
# shellcheck source=mkosi.profiles/kubernetes-sysext/kubernetes.env
source "$kube_manifest"
mkosi_env=(--environment "KATL_BUILD_COMMIT=$build_commit")
if [[ -n "${KATL_VERSION:-}" ]]; then
    mkosi_env+=(--environment "KATL_VERSION=$KATL_VERSION")
fi
emit_runtime_artifact=0
emit_kubernetes_sysext=0

if [[ -z "$runtime" ]]; then
    if command -v podman >/dev/null 2>&1; then
        runtime=podman
    elif command -v docker >/dev/null 2>&1; then
        runtime=docker
    else
        echo "error: docker or podman is required to run the mkosi builder" >&2
        exit 1
    fi
fi

case "$runtime" in
    docker | podman)
        ;;
    *)
        echo "error: unsupported container runtime: $runtime" >&2
        exit 1
        ;;
esac

image_exists() {
    case "$runtime" in
        docker)
            docker image inspect "$image" >/dev/null 2>&1
            ;;
        podman)
            podman image exists "$image" >/dev/null 2>&1
            ;;
    esac
}

if ! image_exists; then
    build_flags=(
        build
        --file "$repo_root/Containerfile.mkosi"
        --tag "$image"
    )

    if [[ "$runtime" == podman ]]; then
        build_flags+=(--signature-policy "$repo_root/containers-policy.json")
    fi

    "$runtime" "${build_flags[@]}" "$repo_root"
fi

if [[ $# -eq 0 ]]; then
    set -- --profile installer-image -f build
else
    case "$1" in
        build-installer)
            shift
            set -- --profile installer-image -f build "$@"
            ;;
        build-runtime)
            shift
            emit_runtime_artifact=1
            set -- --profile runtime -f build "$@"
            ;;
        build-kubernetes-sysext)
            shift
            emit_kubernetes_sysext=1
            repo_file="$repo_root/mkosi.profiles/kubernetes-sysext/mkosi.sandbox/etc/yum.repos.d/kubernetes.repo"
            grep -Fxq "baseurl=$KATL_KUBERNETES_REPO_BASEURL" "$repo_file" || {
                echo "error: Kubernetes repo file does not match $kube_manifest" >&2
                exit 1
            }
            grep -Fxq "gpgkey=$KATL_KUBERNETES_REPO_GPGKEY" "$repo_file" || {
                echo "error: Kubernetes repo key does not match $kube_manifest" >&2
                exit 1
            }
            set -- --profile kubernetes-sysext -f build "$@"
            ;;
        installer-image | runtime)
            profile="$1"
            shift
            if [[ $# -eq 0 ]]; then
                set -- --profile "$profile" -f build
            else
                set -- --profile "$profile" "$@"
            fi
            ;;
    esac
fi

run_flags=(
    run
    --rm
    --privileged
    --volume "$repo_root:/work"
    --workdir /work
    --env "HOST_UID=$(id -u)"
    --env "HOST_GID=$(id -g)"
    --env "KATL_BUILD_COMMIT=$build_commit"
    --env "KATL_EMIT_RUNTIME_ARTIFACT=$emit_runtime_artifact"
    --env "KATL_EMIT_KUBERNETES_SYSEXT=$emit_kubernetes_sysext"
    --env "KATL_KUBERNETES_MINOR=$KATL_KUBERNETES_MINOR"
    --env "KATL_KUBERNETES_REPO_ID=$KATL_KUBERNETES_REPO_ID"
    --env "KATL_KUBERNETES_REPO_BASEURL=$KATL_KUBERNETES_REPO_BASEURL"
    --env "KATL_KUBERNETES_KUBEADM_VERSION=$KATL_KUBERNETES_KUBEADM_VERSION"
    --env "KATL_KUBERNETES_KUBELET_VERSION=$KATL_KUBERNETES_KUBELET_VERSION"
    --env "KATL_KUBERNETES_KUBECTL_VERSION=$KATL_KUBERNETES_KUBECTL_VERSION"
    --env "KATL_KUBERNETES_CRITOOLS_VERSION=$KATL_KUBERNETES_CRITOOLS_VERSION"
)

if [[ "$runtime" == podman ]]; then
    run_flags+=(--userns=keep-id --user root)
fi

if [[ -t 0 && -t 1 ]]; then
    run_flags+=(--interactive --tty)
fi

# shellcheck disable=SC2016
"$runtime" "${run_flags[@]}" "$image" bash -lc '
    set -uo pipefail
    log=$(mktemp)
    trap "rm -f \"$log\"" EXIT
    mkosi "$@" 2>&1 | tee "$log"
    status=${PIPESTATUS[0]}
    pkg_version() {
        local package="$1"
        local want_repo="$2"
        local name repo version
        while read -r name _ version repo _; do
            if [[ "$name" == "$package" ]]; then
                break
            fi
            repo=
            version=
        done < "$log"
        if [[ -z "${version:-}" ]]; then
            echo "error: could not determine resolved version for $package" >&2
            return 1
        fi
        if [[ "$repo" != "$want_repo" ]]; then
            echo "error: $package resolved from $repo, want $want_repo" >&2
            return 1
        fi
        printf "%s" "$version"
    }
    if [[ "$status" -eq 0 && "${KATL_EMIT_RUNTIME_ARTIFACT:-0}" == 1 ]]; then
        root=build/mkosi/katl-runtime-root
        artifact=build/mkosi/katl-runtime-root.squashfs
        if [[ ! -d "$root" ]]; then
            echo "error: runtime root directory not found: $root" >&2
            status=1
        elif ! command -v mksquashfs >/dev/null 2>&1; then
            echo "error: mksquashfs is required to package the runtime root" >&2
            status=1
        else
            rm -f "$artifact" "$artifact.sha256" "$artifact.json"
            if ! mksquashfs "$root" "$artifact" -noappend -all-root -comp zstd; then
                status=1
            else
                size=$(stat -c %s "$artifact")
                sha256=$(sha256sum "$artifact" | awk "{print \$1}")
                created=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
                arch=$(uname -m)
                printf "%s  %s\n" "$sha256" "$(basename "$artifact")" > "$artifact.sha256"
                cat > "$artifact.json" <<EOF
{
  "name": "runtime-root",
  "kind": "runtime-root",
  "format": "squashfs",
  "path": "$(basename "$artifact")",
  "sizeBytes": $size,
  "sha256": "$sha256",
  "compression": "zstd",
  "generation": "${KATL_BUILD_COMMIT:-unknown}",
  "architecture": "$arch",
  "runtimeInterface": "katl-runtime-1",
  "created": "$created"
}
EOF
            fi
        fi
    fi
    if [[ "$status" -eq 0 && "${KATL_EMIT_KUBERNETES_SYSEXT:-0}" == 1 ]]; then
        artifact=build/mkosi/katl-kubernetes.raw
        runtime_meta=build/mkosi/katl-runtime-root.squashfs.json
        runtime_sha=""
        if [[ ! -f "$artifact" ]]; then
            echo "error: Kubernetes sysext artifact not found: $artifact" >&2
            status=1
        else
            kubeadm_version=$(pkg_version kubeadm "${KATL_KUBERNETES_REPO_ID:-kubernetes}") || status=1
            kubelet_version=$(pkg_version kubelet "${KATL_KUBERNETES_REPO_ID:-kubernetes}") || status=1
            kubectl_version=$(pkg_version kubectl "${KATL_KUBERNETES_REPO_ID:-kubernetes}") || status=1
            critools_version=$(pkg_version cri-tools "${KATL_KUBERNETES_REPO_ID:-kubernetes}") || status=1
            if [[ "$status" -ne 0 ]]; then
                exit "$status"
            fi
            if [[ -f "$runtime_meta" ]]; then
                runtime_sha=$(sed -n "s/.*\"sha256\": \"\\([^\"]*\\)\".*/\\1/p" "$runtime_meta" | head -n 1)
            fi
            size=$(stat -c %s "$artifact")
            sha256=$(sha256sum "$artifact" | awk "{print \$1}")
            created=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
            arch=$(uname -m)
            printf "%s  %s\n" "$sha256" "$(basename "$artifact")" > "$artifact.sha256"
            cat > "$artifact.json" <<EOF
{
  "name": "kubernetes",
  "kind": "sysext",
  "format": "sysext",
  "path": "$(basename "$artifact")",
  "sizeBytes": $size,
  "sha256": "$sha256",
  "version": "${KATL_BUILD_COMMIT:-unknown}",
  "payloadVersion": "${KATL_KUBERNETES_MINOR:-v1.34}",
  "architecture": "$arch",
  "sourceRepo": {
    "id": "${KATL_KUBERNETES_REPO_ID:-kubernetes}",
    "baseURL": "${KATL_KUBERNETES_REPO_BASEURL:-}",
    "minor": "${KATL_KUBERNETES_MINOR:-v1.34}"
  },
  "packageVersions": {
    "kubeadm": "$kubeadm_version",
    "kubelet": "$kubelet_version",
    "kubectl": "$kubectl_version",
    "cri-tools": "$critools_version"
  },
  "runtimeInterface": "katl-runtime-1",
  "compatibleRuntime": {
    "interface": "katl-runtime-1",
    "artifactPath": "katl-runtime-root.squashfs",
    "artifactSHA256": "$runtime_sha"
  },
  "created": "$created"
}
EOF
        fi
    fi
    if [[ -d build ]]; then
        chown -R "$HOST_UID:$HOST_GID" build || true
    fi
    exit "$status"
' bash "${mkosi_env[@]}" "$@"
