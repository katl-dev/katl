#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
image="${KATL_MKOSI_IMAGE:-localhost/katl-mkosi-builder:fedora-44-go-squashfs}"
runtime="${KATL_CONTAINER_RUNTIME:-}"
build_commit="${KATL_BUILD_COMMIT:-${KATL_VERSION:-0.0.0-dev}}"
build_dir="${KATL_MKOSI_BUILD_DIR:-$repo_root/_build/mkosi}"
stamp_dir="$build_dir/.katl-stamps"
go_mod_cache="${KATL_GO_MOD_CACHE:-$repo_root/_build/go-mod}"
go_build_cache="${KATL_GO_BUILD_CACHE:-$repo_root/_build/go-cache}"
kube_manifest="$repo_root/mkosi.profiles/kubernetes-sysext/kubernetes.env"
# shellcheck source=mkosi.profiles/kubernetes-sysext/kubernetes.env
# shellcheck disable=SC1091
source "$kube_manifest"
mkosi_env=(--environment "KATL_BUILD_COMMIT=$build_commit")
if [[ -n "${KATL_VERSION:-}" ]]; then
    mkosi_env+=(--environment "KATL_VERSION=$KATL_VERSION")
fi
emit_runtime_artifact=0
emit_kubernetes_sysext=0
emit_installer_iso=0
installer_package_set=""
cache_target=""
kubernetes_repo_file=""
kubernetes_repo_backup=""
kubernetes_profile_file=""
kubernetes_profile_backup=""
mkosi_installer_package_set=""
container_mkosi_storage_args=(
    --output-directory /mkosi-build
    --workspace-directory /mkosi-build/workspace
    --cache-directory /mkosi-build/cache
    --package-cache-directory /mkosi-build/package-cache
    --build-directory /mkosi-build/builddir
)

prepare_build_dirs() {
    mkdir -p \
        "$build_dir/cache" \
        "$build_dir/package-cache" \
        "$build_dir/builddir" \
        "$build_dir/workspace" \
        "$build_dir/workspace/installer" \
        "$build_dir/workspace/runtime" \
        "$go_mod_cache" \
        "$go_build_cache"
}

write_kubernetes_repo_file() {
    local path="$1"
    mkdir -p "$(dirname "$path")"
    cat > "$path" <<EOF
[${KATL_KUBERNETES_REPO_ID}]
name=Kubernetes ${KATL_KUBERNETES_MINOR}
baseurl=${KATL_KUBERNETES_REPO_BASEURL}
enabled=1
gpgcheck=1
repo_gpgcheck=1
gpgkey=${KATL_KUBERNETES_REPO_GPGKEY}
EOF
}

restore_kubernetes_repo_file() {
    if [[ -n "$kubernetes_repo_file" && -n "$kubernetes_repo_backup" && -f "$kubernetes_repo_backup" ]]; then
        cp "$kubernetes_repo_backup" "$kubernetes_repo_file"
        rm -f "$kubernetes_repo_backup"
    fi
}

prepare_kubernetes_package_profile() {
	local path="$repo_root/mkosi.profiles/kubernetes-sysext/mkosi.conf"
	local package variable version
	kubernetes_profile_file="$path"
	kubernetes_profile_backup="$(mktemp)"
	cp "$path" "$kubernetes_profile_backup"
	for package in kubeadm kubelet kubectl cri-tools; do
		case "$package" in
			kubeadm) variable="${KATL_KUBERNETES_KUBEADM_VERSION:-}" ;;
			kubelet) variable="${KATL_KUBERNETES_KUBELET_VERSION:-}" ;;
			kubectl) variable="${KATL_KUBERNETES_KUBECTL_VERSION:-}" ;;
			cri-tools) variable="${KATL_KUBERNETES_CRITOOLS_VERSION:-}" ;;
		esac
		[[ -n "$variable" ]] || continue
		version="${variable%.x86_64}.x86_64"
		sed -i -E "s#^([[:space:]]*)${package}-[^[:space:]]+#\\1${package}-${version}#" "$path"
	done
}

restore_kubernetes_profile_file() {
	if [[ -n "$kubernetes_profile_file" && -n "$kubernetes_profile_backup" && -f "$kubernetes_profile_backup" ]]; then
		cp "$kubernetes_profile_backup" "$kubernetes_profile_file"
		rm -f "$kubernetes_profile_backup"
	fi
}

restore_kubernetes_build_files() {
	restore_kubernetes_repo_file
	restore_kubernetes_profile_file
}

trap restore_kubernetes_build_files EXIT

list_repo_inputs() {
    {
        git -C "$repo_root" ls-files -z
        git -C "$repo_root" ls-files --others --exclude-standard -z
    } | while IFS= read -r -d "" path; do
        case "$path" in
            .beads/* | _build/* | */_build/* | build/* | */build/*)
                continue
                ;;
        esac
        printf '%s\0' "$path"
    done | sort -z
}

cache_input_matches_target() {
    local target="$1"
    local path="$2"
    # Go source changes are represented by target_go_binaries below. The raw
    # file scanner intentionally tracks only non-binary artifact inputs: mkosi
    # profile content, wrapper scripts, module metadata, and builder policy.
    case "$path" in
        *_test.go | docs/*)
            return 1
            ;;
        Containerfile.mkosi | containers-policy.json | go.mod | go.sum | scripts/mkosi)
            return 0
            ;;
        *.go)
            return 1
            ;;
    esac
    case "$target" in
        installer | installer-iso)
            case "$path" in
                mkosi.profiles/installer-image/* | scripts/build-installer-iso)
                    return 0
                    ;;
            esac
            ;;
        runtime)
            case "$path" in
                mkosi.profiles/runtime/*)
                    return 0
                    ;;
            esac
            ;;
        kubernetes-sysext)
            case "$path" in
                mkosi.profiles/kubernetes-sysext/*)
                    return 0
                    ;;
            esac
            ;;
        katlos-install-image)
            case "$path" in
                scripts/build-katlos-install-image | mkosi.profiles/installer-image/* | mkosi.profiles/runtime/*)
                    return 0
                    ;;
            esac
            ;;
    esac
    return 1
}

target_go_binaries() {
    case "$1" in
        installer | installer-iso)
            printf '%s\t%s\t%s\n' "included-binary:/usr/bin/katlos-install" "./cmd/katlos-install" "versioned"
            printf '%s\t%s\t%s\n' "metadata-tool:katl-mkosi-artifacts" "./cmd/katl-mkosi-artifacts" "plain"
            ;;
        runtime)
            printf '%s\t%s\t%s\n' "included-binary:/usr/bin/katlc" "./cmd/katlc" "versioned"
            printf '%s\t%s\t%s\n' "included-binary:/usr/lib/katl/vmtest/katl-vmtest-agent" "./cmd/katl-vmtest-agent" "versioned"
            printf '%s\t%s\t%s\n' "included-binary:/usr/lib/katl/runtime/katl-runtime-status" "./cmd/katl-runtime-status" "plain"
            printf '%s\t%s\t%s\n' "included-binary:/usr/lib/katl/runtime/katl-generation-activate" "./cmd/katl-generation-activate" "plain"
            printf '%s\t%s\t%s\n' "included-binary:/usr/lib/katl/runtime/katl-boot-health" "./cmd/katl-boot-health" "plain"
            printf '%s\t%s\t%s\n' "metadata-tool:katl-mkosi-artifacts" "./cmd/katl-mkosi-artifacts" "plain"
            ;;
        kubernetes-sysext)
            printf '%s\t%s\t%s\n' "metadata-tool:katl-mkosi-artifacts" "./cmd/katl-mkosi-artifacts" "plain"
            ;;
        katlos-install-image)
            target_go_binaries runtime
            printf '%s\t%s\t%s\n' "metadata-tool:build-katlos-install-image" "./cmd/katl-mkosi-artifacts" "plain"
            ;;
    esac
}

go_binary_identity() {
    local package="$1"
    local ldflags_kind="$2"
    local tmp out digest
    mkdir -p "$go_mod_cache" "$go_build_cache"
    tmp="$(mktemp -d "${TMPDIR:-/tmp}/katl-cache-binary.XXXXXX")"
    out="$tmp/binary"
    local -a ldflags=()
    if [[ "$ldflags_kind" == versioned ]]; then
        ldflags=(-ldflags="-X main.version=${KATL_VERSION:-0.0.0-dev} -X main.commit=$build_commit -X main.date=1970-01-01T00:00:00Z")
    fi
    if ! (
        cd "$repo_root" &&
            CGO_ENABLED=0 \
                GOOS=linux \
                GOARCH=amd64 \
                GOAMD64=v1 \
                GOEXPERIMENT= \
                GOFLAGS= \
                GOTOOLCHAIN=local \
                GOCACHE="$go_build_cache" \
                GOMODCACHE="$go_mod_cache" \
                go build \
                -trimpath \
                -buildvcs=false \
                "${ldflags[@]}" \
                -o "$out" \
                "$package"
    ); then
        rm -rf "$tmp"
        return 1
    fi
    read -r digest _ < <(sha256sum "$out")
    rm -rf "$tmp"
    printf '%s\n' "$digest"
}

builder_image_identity() {
    case "$runtime" in
        docker)
            docker image inspect --format '{{.Id}}' "$image" 2>/dev/null || printf '%s\n' "$image"
            ;;
        podman)
            podman image inspect --format '{{.Id}}' "$image" 2>/dev/null || printf '%s\n' "$image"
            ;;
        direct)
            printf 'direct\n'
            ;;
        *)
            printf '%s\n' "$image"
            ;;
    esac
}

list_cache_inputs() {
    local target="$1"
    local path
    while IFS= read -r -d "" path; do
        if cache_input_matches_target "$target" "$path"; then
            printf '%s\0' "$path"
        fi
    done < <(list_repo_inputs)
}

cache_fingerprint() {
    local target="$1"
    if ! command -v sha256sum >/dev/null 2>&1 || ! command -v sort >/dev/null 2>&1; then
        return 1
    fi
    local path digest
    if ! digest="$(
        {
            printf 'target=%s\n' "$target"
            printf 'builder-image=%s\n' "$image"
            printf 'builder-image-identity=%s\n' "$(builder_image_identity)"
            printf 'KATL_BUILD_COMMIT=%s\n' "$build_commit"
            printf 'KATL_VERSION=%s\n' "${KATL_VERSION:-}"
            printf 'KATL_ARCHITECTURE=%s\n' "${KATL_ARCHITECTURE:-$(uname -m)}"
            printf 'KATL_KATLOS_IMAGE_ROLE=%s\n' "${KATL_KATLOS_IMAGE_ROLE:-install}"
            printf 'KATL_RUNTIME_INTERFACE=%s\n' "${KATL_RUNTIME_INTERFACE:-katl-runtime-1}"
            printf 'KATL_KUBERNETES_MINOR=%s\n' "$KATL_KUBERNETES_MINOR"
            printf 'KATL_KUBERNETES_REPO_ID=%s\n' "$KATL_KUBERNETES_REPO_ID"
            printf 'KATL_KUBERNETES_REPO_BASEURL=%s\n' "$KATL_KUBERNETES_REPO_BASEURL"
            printf 'KATL_KUBERNETES_PAYLOAD_VERSION=%s\n' "$KATL_KUBERNETES_PAYLOAD_VERSION"
            printf 'KATL_KUBERNETES_KUBEADM_VERSION=%s\n' "$KATL_KUBERNETES_KUBEADM_VERSION"
            printf 'KATL_KUBERNETES_KUBELET_VERSION=%s\n' "$KATL_KUBERNETES_KUBELET_VERSION"
            printf 'KATL_KUBERNETES_KUBECTL_VERSION=%s\n' "$KATL_KUBERNETES_KUBECTL_VERSION"
            printf 'KATL_KUBERNETES_CRITOOLS_VERSION=%s\n' "$KATL_KUBERNETES_CRITOOLS_VERSION"
            while IFS= read -r -d "" path; do
                if [[ -f "$repo_root/$path" ]]; then
                    read -r file_digest _ < <(sha256sum "$repo_root/$path")
                    printf 'file %s %s\n' "$path" "$file_digest"
                else
                    printf 'missing %s\n' "$path"
                fi
            done < <(list_cache_inputs "$target")
            local label package ldflags_kind binary_digest
            while IFS=$'\t' read -r label package ldflags_kind; do
                [[ -n "$label" ]] || continue
                if binary_digest="$(go_binary_identity "$package" "$ldflags_kind")"; then
                    printf 'go-binary %s %s %s\n' "$label" "$package" "$binary_digest"
                else
                    exit 1
                fi
            done < <(target_go_binaries "$target")
            case "$target" in
                installer-iso)
                    path="$(katlos_image_output).json"
                    if [[ -f "$path" ]]; then
                        read -r file_digest _ < <(sha256sum "$path")
                        printf 'generated %s %s\n' "${path#$repo_root/}" "$file_digest"
                    else
                        printf 'missing %s\n' "${path#$repo_root/}"
                    fi
                    ;;
                kubernetes-sysext)
                    path="$build_dir/katl-runtime-root.squashfs.json"
                    if [[ -f "$path" ]]; then
                        read -r file_digest _ < <(sha256sum "$path")
                        printf 'generated %s %s\n' "${path#$repo_root/}" "$file_digest"
                    else
                        printf 'missing %s\n' "${path#$repo_root/}"
                    fi
                    ;;
            esac
        } | sha256sum
    )"; then
        return 1
    fi
    printf '%s\n' "${digest%% *}"
}

katlos_image_output() {
    local version architecture image_role
    version="${KATL_VERSION:-0.0.0-dev}"
    architecture="${KATL_ARCHITECTURE:-$(uname -m)}"
    image_role="${KATL_KATLOS_IMAGE_ROLE:-install}"
    printf '%s\n' "${KATL_KATLOS_IMAGE:-$build_dir/katlos-${image_role}-${version}-${architecture}.squashfs}"
}

target_outputs() {
    case "$1" in
        installer)
            printf '%s\n' \
                "$build_dir/artifacts.json" \
                "$build_dir/katl-installer.efi" \
                "$build_dir/katl-installer.efi.json" \
                "$build_dir/katl-installer.efi.sha256" \
                "$build_dir/katl-installer.initrd" \
                "$build_dir/katl-installer.initrd.json" \
                "$build_dir/katl-installer.initrd.sha256" \
                "$build_dir/katl-installer.packages.tsv" \
                "$build_dir/katl-installer.vmlinuz" \
                "$build_dir/katl-installer.vmlinuz.json" \
                "$build_dir/katl-installer.vmlinuz.sha256"
            ;;
        installer-iso)
            target_outputs installer
            printf '%s\n' \
                "$build_dir/katl-installer.iso" \
                "$build_dir/katl-installer.iso.json" \
                "$build_dir/katl-installer.iso.sha256"
            ;;
        runtime)
            printf '%s\n' \
                "$build_dir/artifacts.json" \
                "$build_dir/katl-runtime-root" \
                "$build_dir/katl-runtime-root.squashfs" \
                "$build_dir/katl-runtime-root.squashfs.json" \
                "$build_dir/katl-runtime-root.squashfs.sha256" \
                "$build_dir/katl-runtime-root.vmlinuz" \
                "$build_dir/katl-runtime.efi" \
                "$build_dir/katl-runtime.efi.json" \
                "$build_dir/katl-runtime.efi.sha256"
            ;;
        kubernetes-sysext)
            printf '%s\n' \
                "$build_dir/artifacts.json" \
                "$build_dir/katl-kubernetes.raw" \
                "$build_dir/katl-kubernetes.raw.json" \
                "$build_dir/katl-kubernetes.raw.sha256"
            ;;
        katlos-install-image)
            local image_output
            image_output="$(katlos_image_output)"
            target_outputs runtime
            printf '%s\n' \
                "$image_output" \
                "$image_output.json" \
                "$image_output.sha256"
            ;;
    esac
}

target_outputs_exist() {
    local target="$1"
    local output
    while IFS= read -r output; do
        [[ -e "$output" ]] || return 1
    done < <(target_outputs "$target")
}

target_sidecars_match() {
    local target="$1"
    local output artifact metadata digest size
    while IFS= read -r output; do
        [[ "$output" == *.sha256 ]] || continue
        artifact="${output%.sha256}"
        metadata="$artifact.json"
        [[ -f "$artifact" && -f "$metadata" ]] || return 1
        (cd "$(dirname "$artifact")" && sha256sum --status -c "$(basename "$output")") ||
            return 1
        digest="$(sha256sum "$artifact" | awk '{print $1}')"
        size="$(stat -c %s "$artifact")"
        jq -e --arg digest "$digest" --argjson size "$size" \
            '.sha256 == $digest and .sizeBytes == $size' "$metadata" >/dev/null ||
            return 1
    done < <(target_outputs "$target")
}

target_cache_hit() {
    local target="$1"
    local stamp="$stamp_dir/$target.sha256"
    local current recorded
    [[ "$runtime" != direct ]] || return 1
    target_outputs_exist "$target" || return 1
    target_sidecars_match "$target" || return 1
    [[ -f "$stamp" ]] || return 1
    current="$(cache_fingerprint "$target")" || return 1
    recorded="$(<"$stamp")"
    [[ "$recorded" == "$current" ]]
}

store_target_cache() {
    local target="$1"
    local current
    [[ "$runtime" != direct ]] || return 0
    current="$(cache_fingerprint "$target")" || return 0
    mkdir -p "$stamp_dir"
    printf '%s\n' "$current" > "$stamp_dir/$target.sha256"
}

prepare_cached_target() {
    local target="$1"
    if target_cache_hit "$target"; then
        printf 'mkosi cache hit: %s artifacts match the current repo\n' "$target" >&2
        exit 0
    fi
}

clear_installer_iso() {
    rm -f \
        "$build_dir/katl-installer.iso" \
        "$build_dir/katl-installer.iso.json" \
        "$build_dir/katl-installer.iso.sha256"
}

write_installer_package_set() {
    local output="$repo_root/_build/mkosi/katl-installer.packages.tsv"
    local cache_root="$repo_root/_build/mkosi/cache/fedora~44~x86-64~main.cache"
    if [[ ! -d "$cache_root/usr/lib/sysimage/rpm" ]]; then
        echo "error: installer RPM database not found: $cache_root/usr/lib/sysimage/rpm" >&2
        return 1
    fi
    mkdir -p "$(dirname "$output")"
    rpm \
        --root "$cache_root" \
        --dbpath /usr/lib/sysimage/rpm \
        -qa \
        --queryformat "%{NAME}\t%{EPOCHNUM}:%{VERSION}-%{RELEASE}.%{ARCH}\n" \
        | sort >"$output"
}

if [[ -z "$runtime" ]]; then
    if command -v podman >/dev/null 2>&1; then
        runtime=podman
    elif command -v docker >/dev/null 2>&1; then
        runtime=docker
    else
        echo "error: docker or podman is required to run the mkosi builder" >&2
        exit 1
    fi
fi

case "$runtime" in
    direct | docker | podman)
        ;;
    *)
        echo "error: unsupported container runtime: $runtime" >&2
        exit 1
        ;;
esac

image_exists() {
    case "$runtime" in
        docker)
            docker image inspect "$image" >/dev/null 2>&1
            ;;
        podman)
            podman image exists "$image" >/dev/null 2>&1
            ;;
        direct)
            return 0
            ;;
    esac
}

if ! image_exists; then
    build_flags=(
        build
        --file "$repo_root/Containerfile.mkosi"
        --tag "$image"
    )

    if [[ "$runtime" == podman ]]; then
        build_flags+=(--signature-policy "$repo_root/containers-policy.json")
    fi

    "$runtime" "${build_flags[@]}" "$repo_root"
fi

if [[ $# -eq 0 ]]; then
    cache_target=installer
    prepare_cached_target "$cache_target"
    clear_installer_iso
    installer_package_set=_build/mkosi/katl-installer.packages.tsv
    set -- --profile installer-image -f build
else
    case "$1" in
        build-installer)
            shift
            installer_package_set=_build/mkosi/katl-installer.packages.tsv
            if [[ $# -eq 0 ]]; then
                cache_target=installer
                prepare_cached_target "$cache_target"
                clear_installer_iso
                set -- --profile installer-image -f build
            else
                set -- --profile installer-image -f build "$@"
            fi
            ;;
        build-installer-iso)
            shift
            if [[ $# -ne 0 ]]; then
                echo "error: build-installer-iso does not accept mkosi arguments" >&2
                exit 2
            fi
            install_image="$(KATL_KATLOS_IMAGE_ROLE=install katlos_image_output)"
            if [[ ! -f "$install_image" || ! -f "$install_image.json" || ! -f "$install_image.sha256" ]]; then
                KATL_KATLOS_IMAGE_ROLE=install "$repo_root/scripts/mkosi" build-katlos-install-image
            fi
            emit_installer_iso=1
            installer_package_set=_build/mkosi/katl-installer.packages.tsv
            cache_target=installer-iso
            prepare_cached_target "$cache_target"
            set -- --profile installer-image -f build
            ;;
        build-runtime)
            shift
            emit_runtime_artifact=1
            if [[ $# -eq 0 ]]; then
                cache_target=runtime
                prepare_cached_target "$cache_target"
                set -- --profile runtime -f build
            else
                set -- --profile runtime -f build "$@"
            fi
            ;;
        build-kubernetes-sysext)
            shift
            emit_kubernetes_sysext=1
            kubernetes_repo_file="$repo_root/mkosi.profiles/kubernetes-sysext/mkosi.sandbox/etc/yum.repos.d/kubernetes.repo"
            kubernetes_repo_backup="$(mktemp)"
            cp "$kubernetes_repo_file" "$kubernetes_repo_backup"
            write_kubernetes_repo_file "$kubernetes_repo_file"
            prepare_kubernetes_package_profile
            if [[ $# -eq 0 ]]; then
                cache_target=kubernetes-sysext
                prepare_cached_target "$cache_target"
                set -- --profile kubernetes-sysext -f build
            else
                set -- --profile kubernetes-sysext -f build "$@"
            fi
            ;;
		build-kubernetes-upgrade-sysext)
			shift
			if [[ $# -ne 0 ]]; then
				echo "error: build-kubernetes-upgrade-sysext does not accept mkosi arguments" >&2
				exit 2
			fi
			KATL_KUBERNETES_PAYLOAD_VERSION="${KATL_KUBERNETES_UPGRADE_PAYLOAD_VERSION:-v1.36.1}" \
				KATL_KUBERNETES_KUBEADM_VERSION="${KATL_KUBERNETES_UPGRADE_KUBEADM_VERSION:-0:1.36.1-150500.1.1}" \
				KATL_KUBERNETES_KUBELET_VERSION="${KATL_KUBERNETES_UPGRADE_KUBELET_VERSION:-0:1.36.1-150500.1.1}" \
				KATL_KUBERNETES_KUBECTL_VERSION="${KATL_KUBERNETES_UPGRADE_KUBECTL_VERSION:-0:1.36.1-150500.1.1}" \
				"$repo_root/scripts/mkosi" build-kubernetes-sysext
			for suffix in raw raw.json raw.sha256; do
				cp "$build_dir/katl-kubernetes.$suffix" "$build_dir/katl-kubernetes-upgrade.$suffix"
			done
			exit 0
			;;
        build-katlos-install-image)
            shift
            if [[ $# -eq 0 ]] && target_cache_hit katlos-install-image; then
                printf 'mkosi cache hit: katlos-install-image artifacts match the current repo\n' >&2
                exit 0
            fi
            "$repo_root/scripts/mkosi" build-runtime
            "$repo_root/scripts/build-katlos-install-image" "$@"
            status=$?
            if [[ "$status" -eq 0 && $# -eq 0 ]]; then
                store_target_cache katlos-install-image
            fi
            exit "$status"
            ;;
		build-katlos-upgrade-image)
			shift
			"$repo_root/scripts/mkosi" build-runtime
			KATL_KATLOS_IMAGE_ROLE=upgrade \
				KATL_VERSION="${KATL_UPGRADE_VERSION:-${KATL_VERSION:-0.0.0-dev.1}}" \
				KATL_BUILD_COMMIT="$build_commit" \
				"$repo_root/scripts/build-katlos-install-image" "$@"
			exit $?
			;;
        installer-image | runtime)
            profile="$1"
            shift
            if [[ "$profile" == installer-image ]]; then
                installer_package_set=_build/mkosi/katl-installer.packages.tsv
            fi
            if [[ $# -eq 0 ]]; then
                set -- --profile "$profile" -f build
            else
                set -- --profile "$profile" "$@"
            fi
            ;;
    esac
fi

run_flags=(
    run
    --rm
    --privileged
    --volume "$repo_root:/work"
    --workdir /work
    --env "HOST_UID=$(id -u)"
    --env "HOST_GID=$(id -g)"
    --env "KATL_BUILD_COMMIT=$build_commit"
    --env "KATL_VERSION=${KATL_VERSION:-0.0.0-dev}"
    --env "KATL_EMIT_RUNTIME_ARTIFACT=$emit_runtime_artifact"
    --env "KATL_EMIT_KUBERNETES_SYSEXT=$emit_kubernetes_sysext"
    --env "KATL_EMIT_INSTALLER_ISO=$emit_installer_iso"
    --env "KATL_KUBERNETES_MINOR=$KATL_KUBERNETES_MINOR"
    --env "KATL_KUBERNETES_REPO_ID=$KATL_KUBERNETES_REPO_ID"
    --env "KATL_KUBERNETES_REPO_BASEURL=$KATL_KUBERNETES_REPO_BASEURL"
    --env "KATL_KUBERNETES_PAYLOAD_VERSION=$KATL_KUBERNETES_PAYLOAD_VERSION"
    --env "KATL_KUBERNETES_KUBEADM_VERSION=$KATL_KUBERNETES_KUBEADM_VERSION"
    --env "KATL_KUBERNETES_KUBELET_VERSION=$KATL_KUBERNETES_KUBELET_VERSION"
    --env "KATL_KUBERNETES_KUBECTL_VERSION=$KATL_KUBERNETES_KUBECTL_VERSION"
    --env "KATL_KUBERNETES_CRITOOLS_VERSION=$KATL_KUBERNETES_CRITOOLS_VERSION"
)
chown_build=1

direct_tool_search_path() {
    local tool
    local path
    local dir
    local seen=""
    local -a dirs=()
    for tool in bash xargs dnf5 ukify; do
        if ! path="$(command -v "$tool")"; then
            echo "error: $tool is required for KATL_CONTAINER_RUNTIME=direct" >&2
            return 1
        fi
        dir="$(dirname "$path")"
        if [[ ":$seen:" == *":$dir:"* ]]; then
            continue
        fi
        dirs+=("$dir")
        seen="${seen:+$seen:}$dir"
    done
    local IFS=,
    printf '%s\n' "${dirs[*]}"
}

if [[ "$runtime" == direct ]]; then
    if [[ -n "$installer_package_set" ]]; then
        mkosi_installer_package_set="$repo_root/$installer_package_set"
        mkosi_env+=(--environment "KATL_INSTALLER_PACKAGE_SET=$mkosi_installer_package_set")
    fi
    if [[ "$emit_runtime_artifact" == 1 || "$emit_kubernetes_sysext" == 1 || "$emit_installer_iso" == 1 ]]; then
        echo "error: KATL_CONTAINER_RUNTIME=direct currently supports installer-image builds only" >&2
        exit 1
    fi
    log="$(mktemp)"
    trap 'restore_kubernetes_build_files; rm -f "$log"' EXIT
    prepare_build_dirs
    direct_workspace="${KATL_MKOSI_WORKSPACE_DIR:-${TMPDIR:-/tmp}/katl-mkosi-workspace}"
    mkdir -p "$direct_workspace"
    direct_mkosi_storage_args=(
        --workspace-directory "$direct_workspace"
        --cache-directory "$build_dir/cache"
        --package-cache-directory "$build_dir/package-cache"
        --build-directory "$build_dir/builddir"
    )
    export GOCACHE="${GOCACHE:-$go_build_cache}"
    export GOMODCACHE="${GOMODCACHE:-$go_mod_cache}"
    export MKOSI_DNF="${MKOSI_DNF:-dnf5}"
    export TMPDIR="${TMPDIR:-/tmp}"
    if [[ -n "$installer_package_set" ]]; then
        rm -f "$repo_root/$installer_package_set"
    fi
    extra_search_path="$(direct_tool_search_path)"
    set +e
    mkosi --extra-search-path "$extra_search_path" "${direct_mkosi_storage_args[@]}" "${mkosi_env[@]}" "$@" 2>&1 | tee "$log"
    status=${PIPESTATUS[0]}
    set -e
    if [[ "$status" -eq 0 && -n "$installer_package_set" ]]; then
        write_installer_package_set || status=1
    fi
    if [[ "$status" -eq 0 && -n "$installer_package_set" ]]; then
        GOCACHE="${GOCACHE:-$TMPDIR/katl-go-cache}" go run ./cmd/katl-mkosi-artifacts write >/dev/null || status=1
    fi
    if [[ "$status" -eq 0 && -n "$cache_target" ]]; then
        store_target_cache "$cache_target"
    fi
    exit "$status"
fi

prepare_build_dirs
run_flags+=(--volume "$build_dir:/mkosi-build")

if [[ -n "$installer_package_set" ]]; then
    mkosi_installer_package_set="/work/$installer_package_set"
    mkosi_env+=(--environment "KATL_INSTALLER_PACKAGE_SET=$mkosi_installer_package_set")
fi

if [[ "$runtime" == podman ]]; then
    run_flags+=(--userns=keep-id --user root)
    chown_build=0
fi
run_flags+=(--env "KATL_CHOWN_BUILD=$chown_build")
if [[ -n "$mkosi_installer_package_set" ]]; then
    run_flags+=(--env "KATL_INSTALLER_PACKAGE_SET=$mkosi_installer_package_set")
else
    run_flags+=(--env "KATL_INSTALLER_PACKAGE_SET=")
fi

if [[ -t 0 && -t 1 ]]; then
    run_flags+=(--interactive --tty)
fi

# shellcheck disable=SC2016
set +e
"$runtime" "${run_flags[@]}" "$image" bash -lc '
    set -uo pipefail
    log=$(mktemp)
    trap "rm -f \"$log\"" EXIT
    mkdir -p \
        /work/_build/go-mod \
        /work/_build/go-cache \
        /work/_build/mkosi/cache \
        /work/_build/mkosi/package-cache \
        /work/_build/mkosi/builddir \
        /work/_build/mkosi/workspace \
        /work/_build/mkosi/workspace/installer \
        /work/_build/mkosi/workspace/runtime \
        /mkosi-build/cache \
        /mkosi-build/package-cache \
        /mkosi-build/builddir \
        /mkosi-build/workspace
    export GOCACHE=/work/_build/go-cache
    export GOMODCACHE=/work/_build/go-mod
    go mod download
    if [[ -n "${KATL_INSTALLER_PACKAGE_SET:-}" ]]; then
        rm -f "$KATL_INSTALLER_PACKAGE_SET"
    fi
    mkosi "$@" 2>&1 | tee "$log"
    status=${PIPESTATUS[0]}
    mkosi_artifacts() {
        go run ./cmd/katl-mkosi-artifacts "$@"
    }
    if [[ "$status" -eq 0 && "${KATL_EMIT_RUNTIME_ARTIFACT:-0}" == 1 ]]; then
        root=_build/mkosi/katl-runtime-root
        artifact=_build/mkosi/katl-runtime-root.squashfs
        boot_artifact=_build/mkosi/katl-runtime.efi
        if [[ ! -d "$root" ]]; then
            echo "error: runtime root directory not found: $root" >&2
            status=1
        elif ! command -v mksquashfs >/dev/null 2>&1; then
            echo "error: mksquashfs is required to package the runtime root" >&2
            status=1
        elif ! command -v ukify >/dev/null 2>&1; then
            echo "error: ukify is required to package the runtime UKI" >&2
            status=1
        else
            rm -f "$artifact" "$artifact.sha256" "$artifact.json" "$boot_artifact" "$boot_artifact.sha256" "$boot_artifact.json"
            if ! mksquashfs "$root" "$artifact" -noappend -all-root -comp zstd; then
                status=1
            else
                if ! sha256=$(mkosi_artifacts write-runtime-root --artifact "$artifact"); then
                    status=1
                fi
                if [[ "$status" -eq 0 ]]; then
                    kernel_dir=$(find "$root/boot" -type f -name linux -printf "%h\n" | sort | head -n 1)
                    if [[ -z "$kernel_dir" ]]; then
                        echo "error: runtime kernel not found under $root/boot" >&2
                        status=1
                    else
                        kernel="$kernel_dir/linux"
                        initrd="$kernel_dir/initrd"
                        kernel_version="$(basename "$kernel_dir")"
                        os_release="$root/usr/lib/os-release"
                        if [[ ! -f "$initrd" ]]; then
                            echo "error: runtime initrd not found: $initrd" >&2
                            status=1
                        elif [[ ! -f "$os_release" ]]; then
                            echo "error: runtime os-release not found: $os_release" >&2
                            status=1
                        else
                            ukify_args=(
                                build
                                --linux "$kernel"
                                --initrd "$initrd"
                                --os-release "@$os_release"
                                --cmdline "rootfstype=squashfs ro"
                                --uname "$kernel_version"
                                --output "$boot_artifact"
                            )
                            if [[ -f /usr/lib/systemd/boot/efi/linuxx64.efi.stub ]]; then
                                ukify_args+=(--stub /usr/lib/systemd/boot/efi/linuxx64.efi.stub)
                            fi
                            if ! ukify "${ukify_args[@]}"; then
                                status=1
                            else
                                if ! mkosi_artifacts write-runtime-uki \
                                    --artifact "$boot_artifact" \
                                    --runtime-artifact "$artifact" \
                                    --runtime-sha256 "$sha256" \
                                    --kernel-version "$kernel_version" >/dev/null; then
                                    status=1
                                fi
                            fi
                        fi
                    fi
                fi
            fi
        fi
    fi
    if [[ "$status" -eq 0 && "${KATL_EMIT_KUBERNETES_SYSEXT:-0}" == 1 ]]; then
        artifact=_build/mkosi/katl-kubernetes.raw
        runtime_meta=_build/mkosi/katl-runtime-root.squashfs.json
        if [[ ! -f "$artifact" ]]; then
            echo "error: Kubernetes sysext artifact not found: $artifact" >&2
            status=1
        else
            if ! mkosi_artifacts write-kubernetes-sysext-from-log \
                --artifact "$artifact" \
                --log "$log" \
                --runtime-artifact _build/mkosi/katl-runtime-root.squashfs \
                --runtime-metadata "$runtime_meta" \
                --repo-id "${KATL_KUBERNETES_REPO_ID:?}" \
                --repo-base-url "${KATL_KUBERNETES_REPO_BASEURL:?}" \
                --repo-minor "${KATL_KUBERNETES_MINOR:?}" \
                --expected-payload-version "${KATL_KUBERNETES_PAYLOAD_VERSION:-}" \
                --expected-kubeadm-version "${KATL_KUBERNETES_KUBEADM_VERSION:-}" \
                --expected-kubelet-version "${KATL_KUBERNETES_KUBELET_VERSION:-}" \
                --expected-kubectl-version "${KATL_KUBERNETES_KUBECTL_VERSION:-}" \
                --expected-cri-tools-version "${KATL_KUBERNETES_CRITOOLS_VERSION:-}" \
                --expected-ethtool-version "${KATL_KUBERNETES_ETHTOOL_VERSION:-}" \
                --expected-socat-version "${KATL_KUBERNETES_SOCAT_VERSION:-}" >/dev/null; then
                status=1
            fi
        fi
    fi
    if [[ "$status" -eq 0 && "${KATL_EMIT_INSTALLER_ISO:-0}" == 1 ]]; then
        iso=_build/mkosi/katl-installer.iso
        rm -f "$iso" "$iso.sha256" "$iso.json"
        if ! KATL_REPO_ROOT=/work KATL_INSTALLER_ISO="$iso" scripts/build-installer-iso >/dev/null; then
            status=1
        else
            export KATL_INSTALLER_ISO="$iso"
        fi
    fi
    if [[ "$status" -eq 0 && -n "${KATL_INSTALLER_PACKAGE_SET:-}" ]]; then
        if ! mkosi_artifacts write >/dev/null; then
            status=1
        fi
    fi
    if [[ "${KATL_CHOWN_BUILD:-1}" == 1 && -d _build ]]; then
        chown -R "$HOST_UID:$HOST_GID" _build || true
    elif [[ -d _build/mkosi ]]; then
        find _build/mkosi/cache _build/mkosi/package-cache _build/mkosi/builddir _build/mkosi/workspace -type d -exec chmod u+rwx,go+rx {} + 2>/dev/null || true
        chown -h "$HOST_UID:$HOST_GID" \
            _build/mkosi/artifacts.json \
            _build/mkosi/katl-* \
            _build/mkosi/*.json \
            _build/mkosi/*.sha256 \
            _build/mkosi/*.packages.tsv \
            2>/dev/null || true
    fi
    exit "$status"
' bash "${container_mkosi_storage_args[@]}" "${mkosi_env[@]}" "$@"
status=$?
set -e
if [[ "$status" -eq 0 && -n "$installer_package_set" ]]; then
    write_installer_package_set || status=1
fi
if [[ "$status" -eq 0 && -n "$cache_target" ]]; then
    store_target_cache "$cache_target"
fi
exit "$status"
