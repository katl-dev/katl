#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
build_dir="$repo_root/_build/mkosi"
version="${KATL_VERSION:-0.0.0-dev}"
build_id="$(git -C "$repo_root" describe --always --dirty --abbrev=12 2>/dev/null || printf unknown)"
architecture="${KATL_ARCHITECTURE:-$(uname -m)}"
image_role="${KATL_KATLOS_IMAGE_ROLE:-install}"
runtime_interface="${KATL_RUNTIME_INTERFACE:-katl-runtime-1}"
output="${KATL_KATLOS_IMAGE:-$build_dir/katlos-${image_role}-${version}-${architecture}.squashfs}"
work_root="${KATL_KATLOS_IMAGE_ROOT:-$build_dir/katlos-${image_role}-root}"

runtime_root="${KATL_RUNTIME_ARTIFACT:-$build_dir/katl-runtime-root.squashfs}"
runtime_root_metadata="${KATL_RUNTIME_METADATA:-$runtime_root.json}"
runtime_root_checksum="${KATL_RUNTIME_CHECKSUM:-$runtime_root.sha256}"
runtime_uki="${KATL_RUNTIME_UKI:-$build_dir/katl-runtime.efi}"
runtime_uki_metadata="${KATL_RUNTIME_UKI_METADATA:-$runtime_uki.json}"
runtime_uki_checksum="${KATL_RUNTIME_UKI_CHECKSUM:-$runtime_uki.sha256}"
kubernetes_sysext="${KATL_KUBERNETES_SYSEXT:-$build_dir/katl-kubernetes.raw}"
kubernetes_sysext_metadata="${KATL_KUBERNETES_SYSEXT_METADATA:-$kubernetes_sysext.json}"
kubernetes_sysext_checksum="${KATL_KUBERNETES_SYSEXT_CHECKSUM:-$kubernetes_sysext.sha256}"

fail() {
    echo "error: $*" >&2
    exit 1
}

need() {
    command -v "$1" >/dev/null 2>&1 || fail "$1 is required"
}

under_repo() {
    local label="$1"
    local path="$2"
    [[ "$path" == "$repo_root"/* ]] || fail "$label must be under repository root: $path"
}

mkosi_artifacts() {
    if command -v katl-mkosi-artifacts >/dev/null 2>&1; then
        katl-mkosi-artifacts "$@"
        return
    fi
    (cd "$repo_root" && go run ./cmd/katl-mkosi-artifacts "$@")
}

need cp
need mkdir
need mksquashfs
need rm

case "$image_role" in
    install)
        ;;
    *)
        fail "unsupported KatlOS image role: $image_role"
        ;;
esac
under_repo "KatlOS image output" "$output"
under_repo "KatlOS image assembly root" "$work_root"
[[ "$work_root" == "$build_dir"/* ]] || fail "KatlOS image assembly root must be under _build/mkosi: $work_root"

rm -rf -- "$work_root"
mkdir -p \
    "$work_root/katlos" \
    "$work_root/components/runtime" \
    "$work_root/components/boot" \
    "$work_root/components/sysext" \
    "$work_root/components/metadata"

cp "$runtime_root" "$work_root/components/runtime/root.squashfs"
cp "$runtime_uki" "$work_root/components/boot/katl.efi"
cp "$kubernetes_sysext" "$work_root/components/sysext/kubernetes.raw"
cp "$runtime_root_metadata" "$work_root/components/metadata/runtime-root.json"
cp "$runtime_uki_metadata" "$work_root/components/metadata/runtime-uki.json"
cp "$kubernetes_sysext_metadata" "$work_root/components/metadata/kubernetes-sysext.json"
mkosi_artifacts write-katlos-index \
    --output "$work_root/katlos/image.json" \
    --image-role "$image_role" \
    --version "$version" \
    --build-id "$build_id" \
    --architecture "$architecture" \
    --runtime-interface "$runtime_interface" \
    --runtime-root "$runtime_root" \
    --runtime-root-metadata "$runtime_root_metadata" \
    --runtime-uki "$runtime_uki" \
    --runtime-uki-metadata "$runtime_uki_metadata" \
    --kubernetes-sysext "$kubernetes_sysext" \
    --kubernetes-sysext-metadata "$kubernetes_sysext_metadata" >/dev/null

mkdir -p "$(dirname "$output")"
rm -f -- "$output" "$output.sha256" "$output.json"
mksquashfs "$work_root" "$output" -noappend -all-root -comp zstd >/dev/null
mkosi_artifacts write-katlos-artifact \
    --artifact "$output" \
    --image-role "$image_role" \
    --version "$version" \
    --build-id "$build_id" \
    --architecture "$architecture" \
    --runtime-interface "$runtime_interface" >/dev/null

echo "katlos image: ${output#"$repo_root"/}"
