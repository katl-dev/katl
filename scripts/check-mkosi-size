#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
installer_artifact="${KATL_INSTALLER_ARTIFACT:-$repo_root/_build/mkosi/katl-installer.efi}"
runtime_artifact="${KATL_RUNTIME_ARTIFACT:-$repo_root/_build/mkosi/katl-runtime-root.squashfs}"
runtime_root="${KATL_RUNTIME_ROOT:-$repo_root/_build/mkosi/katl-runtime-root}"
runtime_packages="${KATL_RUNTIME_PACKAGES:-$repo_root/_build/mkosi/katl-runtime.packages.tsv}"
installer_max_mib="${KATL_INSTALLER_MAX_MIB:-450}"
runtime_max_mib="${KATL_RUNTIME_MAX_MIB:-390}"
runtime_tree_max_mib="${KATL_RUNTIME_TREE_MAX_MIB:-700}"
report_count="${KATL_SIZE_REPORT_COUNT:-12}"

fail() {
    echo "error: $*" >&2
    exit 1
}

rel() {
    local path="$1"
    printf "%s" "${path#"$repo_root"/}"
}

mib() {
    awk -v bytes="$1" 'BEGIN { printf "%.1f MiB", bytes / 1024 / 1024 }'
}

max_file() {
    local label="$1"
    local path="$2"
    local limit_mib="$3"
    local actual limit
    [[ -f "$path" ]] || fail "$label not found: $(rel "$path")"
    actual="$(stat -c %s "$path")"
    limit=$((limit_mib * 1024 * 1024))
    printf "%s: %s (limit %s MiB)\n" "$label" "$(mib "$actual")" "$limit_mib"
    (( actual <= limit )) || fail "$label is $(mib "$actual"), limit $(mib "$limit")"
}

max_dir() {
    local label="$1"
    local path="$2"
    local limit_mib="$3"
    local actual limit output
    [[ -d "$path" ]] || fail "$label not found: $(rel "$path")"
    output="$(du -s -B1 -x "$path" 2>/dev/null || true)"
    actual="$(awk 'NR == 1 {print $1}' <<<"$output")"
    [[ "$actual" =~ ^[0-9]+$ ]] || fail "$label size query failed"
    limit=$((limit_mib * 1024 * 1024))
    printf "%s: %s (limit %s MiB)\n" "$label" "$(mib "$actual")" "$limit_mib"
    (( actual <= limit )) || fail "$label is $(mib "$actual"), limit $(mib "$limit")"
}

need_line() {
    local file="$1"
    local line="$2"
    grep -Fxq "$line" "$file" || fail "$(rel "$file") missing: $line"
}

pkgs() {
    local profile="$1"
    awk '
        /^Packages=/ { in_packages = 1; next }
        in_packages && /^[[:space:]]+[A-Za-z0-9_.+-]+$/ { gsub(/^[[:space:]]+|[[:space:]]+$/, ""); print; next }
        in_packages && /^[[:space:]]*(#|$)/ { next }
        in_packages { exit }
    ' "$profile"
}

deny() {
    local profile="$1"
    local label="$2"
    shift 2
    local package
    for package in "$@"; do
        if pkgs "$profile" | grep -Fxq "$package"; then
            fail "$label profile must not include $package"
        fi
    done
}

require_packages() {
    local profile="$1"
    local label="$2"
    shift 2
    local package
    for package in "$@"; do
        if ! pkgs "$profile" | grep -Fxq "$package"; then
            fail "$label profile must include $package"
        fi
    done
}

lock_pkgs() {
    local set="$1"
    local lock="$repo_root/mkosi.profiles/resource-package-lock.json"
    [[ -f "$lock" ]] || fail "package lock not found: $(rel "$lock")"
    command -v jq >/dev/null 2>&1 || fail "jq is required to inspect $(rel "$lock")"
    jq -er --arg set "$set" '
        .packageSets[]
        | select(.name == $set)
        | .packages[]
        | .name
    ' "$lock"
}

deny_lock_packages() {
    local set="$1"
    local label="$2"
    shift 2
    local package packages
    packages="$(lock_pkgs "$set")" || fail "package lock missing package set: $set"
    for package in "$@"; do
        if grep -Fxq "$package" <<<"$packages"; then
            fail "$label package lock must not include $package"
        fi
    done
}

check_profiles() {
    local installer_profile="$repo_root/mkosi.profiles/installer-image/mkosi.conf"
    local runtime_profile="$repo_root/mkosi.profiles/runtime/mkosi.conf"
    need_line "$repo_root/mkosi.conf" "WithDocs=no"
    need_line "$repo_root/mkosi.conf" "WithRecommends=no"
    need_line "$repo_root/mkosi.conf" "CacheDirectory=_build/mkosi/cache"
    need_line "$repo_root/mkosi.conf" "PackageCacheDirectory=_build/mkosi/package-cache"
    require_packages "$installer_profile" installer kernel-core kernel-modules
    require_packages "$runtime_profile" runtime kernel-core kernel-modules kmod conntrack-tools iptables-nft ipset ipvsadm containernetworking-plugins
    deny "$installer_profile" installer mkosi dnf dnf5 rpm yum gcc go make cc kubeadm kubelet kubectl crictl containerd crun helm flux cilium rook
    deny "$runtime_profile" runtime mkosi dnf dnf5 rpm yum gcc go make cc curl wget kubeadm kubelet kubectl crictl helm flux cilium rook coredns
    deny_lock_packages installer-image installer mkosi dnf dnf5 rpm yum gcc go make kubeadm kubelet kubectl crictl containerd crun helm flux cilium rook coredns
    deny_lock_packages runtime runtime mkosi dnf dnf5 rpm yum gcc go make curl wget kubeadm kubelet kubectl crictl helm flux cilium rook coredns
    echo "mkosi profile controls: docs/recommends disabled, caches external, denied packages absent"
}

sections() {
    if ! command -v objdump >/dev/null 2>&1; then
        echo "installer UKI sections: skipped (objdump unavailable)"
        return
    fi
    echo "largest installer UKI sections:"
    objdump -h "$installer_artifact" |
        awk '/^[[:space:]]+[0-9]+[[:space:]]+\./ { print $3 "\t" $2 }' |
        while IFS=$'\t' read -r hex name; do
            printf "%d\t%s\n" "$((16#$hex))" "$name"
        done |
        sort -rn |
        head -n "$report_count" |
        awk '{ printf "  %7.1f MiB  %s\n", $1 / 1024 / 1024, $2 }'
}

rpms() {
    if ! command -v rpm >/dev/null 2>&1; then
        echo "largest runtime RPM payloads: skipped (rpm unavailable)"
        return
    fi
    if [[ ! -d "$runtime_root/usr/lib/sysimage/rpm" ]]; then
        [[ -s "$runtime_packages" ]] || fail "runtime package inventory not found: $(rel "$runtime_packages")"
        echo "runtime RPM inventory: $(wc -l <"$runtime_packages") packages (payload sizes omitted after rpmdb pruning)"
        return
    fi
    local output
    output="$(rpm --root "$runtime_root" --dbpath /usr/lib/sysimage/rpm -qa --queryformat '%{SIZE}\t%{NAME}\n' | sort -rn | head -n "$report_count")" || fail "runtime rpmdb query failed"
    [[ -n "$output" ]] || fail "runtime rpmdb query returned no packages"
    echo "largest runtime RPM payloads:"
    awk '{ printf "  %7.1f MiB  %s\n", $1 / 1024 / 1024, $2 }' <<<"$output"
}

max_file "installer UKI" "$installer_artifact" "$installer_max_mib"
max_file "runtime SquashFS" "$runtime_artifact" "$runtime_max_mib"
max_dir "runtime root tree" "$runtime_root" "$runtime_tree_max_mib"
check_profiles
sections
rpms
