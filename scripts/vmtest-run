#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
go_bin="${KATL_VMTEST_GO:-go}"
image_tool="${KATL_VMTEST_IMAGE_TOOL:-qemu-img}"
virsh_bin="${KATL_VMTEST_VIRSH:-virsh}"
kubectl_bin="${KATL_VMTEST_KUBECTL:-kubectl}"
resource_lock_bin="${KATL_VMTEST_RESOURCE_LOCK:-}"
resource_go_bin="${KATL_VMTEST_RESOURCE_GO:-go}"
go_test_timeout="90m"
tmp_parent="${TMPDIR:-/tmp}/katl-vmtest"
run_id="${KATL_VMTEST_RUN_ID:-$(date -u +%Y%m%dT%H%M%SZ)-$$}"
run_dir="${KATL_VMTEST_RUN_DIR:-$tmp_parent/$run_id}"
run_dir_preexisting=0
if [[ -e "$run_dir" ]]; then
    run_dir_preexisting=1
fi
cache_dir="${KATL_VMTEST_CACHE_DIR:-$repo_root/_build/vmtest}"
artifact_dir="$run_dir/artifacts"
scenario_dir="$run_dir/scenarios"
network_dir="$run_dir/network"
run_owner_marker="$run_dir/.katl-vmtest-run-dir"
world_manifest="$run_dir/world.json"
host_capabilities_json="$run_dir/host-capabilities.json"
run_index="$run_dir/run.json"
go_test_log="$run_dir/go-test.log"
resource_manifest="$run_dir/resource-test-manifest.json"
package_lock="$repo_root/mkosi.profiles/resource-package-lock.json"
resource_manifest_sha256=""
package_lock_sha256=""
vmtest_artifacts_json="[]"
vmtest_artifact_inputs_json="{}"
debug_targets_artifact="$run_dir/preserved-vm-debug.txt"
lease_file="$network_dir/leases.json"
libvirt_uri="${KATL_VMTEST_LIBVIRT_URI:-qemu:///system}"
libvirt_network="${KATL_VMTEST_LIBVIRT_NETWORK:-default}"
libvirt_storage_pool="${KATL_VMTEST_LIBVIRT_STORAGE_POOL:-default}"
libvirt_storage_path="${KATL_VMTEST_LIBVIRT_STORAGE_PATH:-/var/lib/libvirt/images}"
libvirt_domain_prefix="${KATL_VMTEST_LIBVIRT_DOMAIN_PREFIX:-katl-${run_id}}"
network_cidr="${KATL_VMTEST_CIDR:-10.77.0.0/24}"
network_gateway="${KATL_VMTEST_GATEWAY:-10.77.0.1}"
ovmf_code="${KATL_OVMF_CODE:-}"
ovmf_vars="${KATL_OVMF_VARS:-}"
kvm_device="${KATL_VMTEST_KVM_DEVICE:-/dev/kvm}"
vsock_device="${KATL_VMTEST_VSOCK_DEVICE:-/dev/vhost-vsock}"
network_prefix=""
final_status="setup-failed"
cap_image_tool="disabled"
cap_libvirt="disabled"
cap_libvirt_network="disabled"
cap_libvirt_storage_pool="disabled"
cap_ovmf="disabled"
cap_kvm="disabled"
cap_vsock="disabled"
cap_mtools="disabled"
cap_sfdisk="disabled"
cap_sha256sum="disabled"
cap_awk="disabled"
cap_realpath="disabled"
cap_kubectl="disabled"
require_scenario_result="${KATL_VMTEST_REQUIRE_SCENARIO_RESULT:-1}"
auto_rebuild="${KATL_VMTEST_AUTO_REBUILD:-1}"
artifact_set="${KATL_VMTEST_ARTIFACT_SET:-default}"
keep_policy="${KATL_VMTEST_KEEP:-failed}"
debug_on_failure_policy="${KATL_VMTEST_DEBUG_ON_FAILURE:-auto}"
debug_on_failure_effective=""
go_test_input_args=()
missing_capabilities=()
setup_failures=()
help_requested=0
declare -A artifact_build_actions=()

usage() {
    cat <<'EOF'
usage: scripts/vmtest-run [vmtest-run options] [go test args]

Options:
  -h, --help                    Show this help and exit.
  --no-rebuild, --no-auto-rebuild
                                Do not build missing default artifacts.
  --rebuild, --auto-rebuild     Build missing default artifacts.
  --rebuild=<bool>, --auto-rebuild=<bool>
                                Set artifact rebuild behavior.
  --artifact-set=<set>          Select default artifact set: default, install,
                                runtime, or none.
  --runtime-artifacts           Alias for --artifact-set=runtime.
  --debug-on-failure            Preserve failed VM domains for debugging.
  --no-debug-on-failure         Do not preserve failed VM domains.
  --debug-on-failure=<value>    Set debug preservation policy.
  --                            Pass all remaining args to go test.

Go test args are forwarded to:
  go test -exec scripts/vmtest-exec [default timeout] <args>
EOF
}

need() {
    command -v "$1" >/dev/null 2>&1 || {
        echo "error: $1 is required" >&2
        exit 1
    }
}

missing_status() {
    if [[ "$1" == "passed" ]]; then
        printf "passed"
    else
        printf "failed"
    fi
}

have_command() {
    command -v "$1" >/dev/null 2>&1
}

capability_hint() {
    case "$1" in
        image-tool)
            printf "install qemu-img or set KATL_VMTEST_IMAGE_TOOL to an image tool compatible with qemu-img"
            ;;
        libvirt)
            printf "install libvirt client tools and ensure %s can connect to %s" "$virsh_bin" "$libvirt_uri"
            ;;
        libvirt-network)
            printf "define and start libvirt network %s on %s, or set KATL_VMTEST_LIBVIRT_NETWORK" "$libvirt_network" "$libvirt_uri"
            ;;
        libvirt-storage-pool)
            printf "define and start libvirt storage pool %s on %s, or set KATL_VMTEST_LIBVIRT_STORAGE_POOL" "$libvirt_storage_pool" "$libvirt_uri"
            ;;
        ovmf)
            printf "set KATL_OVMF_CODE and KATL_OVMF_VARS to readable OVMF pflash images"
            ;;
        kvm)
            printf "%s is missing; enable KVM support or set KATL_VMTEST_KVM_DEVICE" "$kvm_device"
            ;;
        vsock)
            printf "%s is missing; load vhost_vsock or set KATL_VMTEST_VSOCK_DEVICE" "$vsock_device"
            ;;
        mtools)
            printf "install mtools and coreutils so mformat, mcopy, and truncate are available"
            ;;
        sfdisk)
            printf "install util-linux so sfdisk is available"
            ;;
        sha256sum)
            printf "install coreutils so sha256sum is available"
            ;;
        awk)
            printf "install awk, such as gawk"
            ;;
        realpath)
            printf "install coreutils so realpath is available"
            ;;
        kubectl)
            printf "install kubectl or set KATL_VMTEST_KUBECTL to the kubectl binary"
            ;;
        *)
            printf "see %s for recorded host capability state" "$host_capabilities_json"
            ;;
    esac
}

print_missing_capabilities() {
    local heading="$1"
    local printed=""
    local capability hint
    printf '%s\n' "$heading" >&2
    for capability in "${missing_capabilities[@]}"; do
        case " $printed " in
            *" $capability "*)
                continue
                ;;
        esac
        printed="${printed:+$printed }$capability"
        hint="$(capability_hint "$capability")"
        printf '  - %s: %s\n' "$capability" "$hint" >&2
    done
    printf 'vmtest run dir: %s\n' "$run_dir" >&2
}

has_go_test_timeout() {
    local arg
    while (($# > 0)); do
        arg="$1"
        case "$arg" in
            -args)
                return 1
                ;;
            -timeout | --timeout | -test.timeout | --test.timeout)
                return 0
                ;;
            -timeout=* | --timeout=* | -test.timeout=* | --test.timeout=*)
                return 0
                ;;
        esac
        shift
    done
    return 1
}

parse_runner_args() {
    local arg value
    while (($# > 0)); do
        arg="$1"
        case "$arg" in
            -args)
                go_test_input_args+=("$@")
                return 0
                ;;
            -h | --help)
                help_requested=1
                ;;
            --no-rebuild | --no-auto-rebuild)
                auto_rebuild=0
                ;;
            --rebuild | --auto-rebuild)
                auto_rebuild=1
                ;;
            --rebuild=* | --auto-rebuild=*)
                value="${arg#*=}"
                case "$value" in
                    1 | true | yes | on)
                        auto_rebuild=1
                        ;;
                    0 | false | no | off)
                        auto_rebuild=0
                        ;;
                    *)
                        setup_failures+=("invalid ${arg%%=*} value: $value")
                        ;;
                esac
                ;;
            --artifact-set=*)
                artifact_set="${arg#*=}"
                ;;
            --runtime-artifacts)
                artifact_set="runtime"
                ;;
            --debug-on-failure)
                debug_on_failure_policy="1"
                ;;
            --no-debug-on-failure)
                debug_on_failure_policy="0"
                ;;
            --debug-on-failure=*)
                debug_on_failure_policy="${arg#*=}"
                ;;
            --)
                shift
                go_test_input_args+=("$@")
                return 0
                ;;
            *)
                go_test_input_args+=("$arg")
                ;;
        esac
        shift
    done
}

has_explicit_artifact_index() {
    [[ -n "${KATL_MKOSI_ARTIFACT_INDEX:-}" ]]
}

has_explicit_installer_artifact() {
    [[ -n "${KATL_INSTALLER_UKI:-}" || -n "${KATL_INSTALLER_KERNEL:-}" || -n "${KATL_INSTALLER_INITRD:-}" ]]
}

has_explicit_runtime_artifact() {
    [[ -n "${KATL_RUNTIME_ARTIFACT:-}" ]]
}

has_explicit_install_manifest() {
    [[ -n "${KATL_INSTALL_MANIFEST:-}" ]]
}

uses_installer_artifacts() {
    case "$artifact_set" in
        default | install)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

validate_stale_artifact_policy() {
    case "${KATL_ALLOW_STALE_INSTALLER_ARTIFACTS:-0}" in
        1 | true | yes | on)
            setup_failures+=("KATL_ALLOW_STALE_INSTALLER_ARTIFACTS is not supported by scripts/vmtest-run; strict installer artifact validation is required")
            ;;
    esac
}

validate_current_artifact_inputs() {
    if ! uses_installer_artifacts; then
        return 0
    fi
    if has_explicit_artifact_index || has_explicit_installer_artifact || has_explicit_runtime_artifact || has_explicit_install_manifest; then
        setup_failures+=("explicit installer artifact inputs are not supported by scripts/vmtest-run; use current repo artifacts validated by katl-resource-lock")
    fi
}

build_default_artifacts() {
    case "$auto_rebuild" in
        0 | false | no | off)
            return 0
            ;;
    esac

    if has_explicit_artifact_index; then
        return 0
    fi

    local -a targets=()
    case "$artifact_set" in
        default | install)
            if ! has_explicit_installer_artifact; then
                targets+=("build-installer")
            fi
            if ! has_explicit_install_manifest; then
                targets+=("build-katlos-install-image")
                targets+=("build-kubernetes-sysext")
            elif ! has_explicit_runtime_artifact; then
                targets+=("build-runtime")
            fi
            ;;
        runtime)
            if ! has_explicit_runtime_artifact; then
                targets+=("build-runtime")
            fi
            ;;
        none)
            ;;
        *)
            setup_failures+=("invalid vmtest artifact set: $artifact_set")
            return 1
            ;;
    esac
    if [[ "${#targets[@]}" -eq 0 ]]; then
        return 0
    fi

	local target
	for target in "${targets[@]}"; do
        local log
        local cache_label
        log="$(mktemp)"
        cache_label="$(mkosi_cache_label_for_target "$target")"
		printf 'vmtest building current repo artifact: scripts/mkosi %s\n' "$target" >&2
		if ! "$repo_root/scripts/mkosi" "$target" > >(tee "$log" >&2) 2>&1; then
			setup_failures+=("build default vmtest artifact with scripts/mkosi $target failed")
            rm -f "$log"
			return 1
		fi
        if grep -q "^mkosi cache hit: ${cache_label} artifacts match the current repo$" "$log"; then
            artifact_build_actions["$target"]="cache-resolved"
        else
            artifact_build_actions["$target"]="built"
        fi
        rm -f "$log"
	done
}

mkosi_cache_label_for_target() {
    case "$1" in
        build-installer)
            printf 'installer\n'
            ;;
        build-runtime)
            printf 'runtime\n'
            ;;
        build-katlos-install-image)
            printf 'katlos-install-image\n'
            ;;
        build-kubernetes-sysext)
            printf 'kubernetes-sysext\n'
            ;;
        *)
            printf '%s\n' "$1"
            ;;
    esac
}

artifact_build_actions_json() {
    jq -nc \
        --arg buildInstaller "${artifact_build_actions[build-installer]:-}" \
        --arg buildRuntime "${artifact_build_actions[build-runtime]:-}" \
        --arg buildInstallImage "${artifact_build_actions[build-katlos-install-image]:-}" \
        --arg buildKubernetesSysext "${artifact_build_actions[build-kubernetes-sysext]:-}" \
        '{
          "build-installer": $buildInstaller,
          "build-runtime": $buildRuntime,
          "build-katlos-install-image": $buildInstallImage,
          "build-kubernetes-sysext": $buildKubernetesSysext
        } | with_entries(select(.value != ""))'
}

run_resource_lock() {
    if [[ -n "$resource_lock_bin" ]]; then
        "$resource_lock_bin" "$@"
        return
    fi
    (cd "$repo_root" && "$resource_go_bin" run ./cmd/katl-resource-lock "$@")
}

git_revision() {
    git -C "$repo_root" rev-parse HEAD 2>/dev/null || printf unknown
}

file_sha256() {
    local path="$1"
    local digest _
    read -r digest _ < <(sha256sum "$path")
    printf '%s\n' "$digest"
}

prepare_resource_manifest() {
    if ! uses_installer_artifacts; then
        return 0
    fi

    local revision
    revision="$(git_revision)"
    printf 'vmtest validating current repo artifacts: katl-resource-lock prepare-mkosi --mode strict\n' >&2
    if ! run_resource_lock prepare-mkosi \
        -manifest "$resource_manifest" \
        -lock "$package_lock" \
        -mode strict \
        -run-id "$run_id" \
        -git-revision "$revision"; then
        setup_failures+=("strict vmtest resource manifest validation failed")
        return 1
    fi
	resource_manifest_sha256="$(file_sha256 "$resource_manifest")"
	package_lock_sha256="$(file_sha256 "$package_lock")"
	vmtest_artifacts_json="$(
		jq -c '
          def abs_path($repo):
            if (.path | startswith("/")) then .path else ($repo + "/" + .path) end;
          def action_for($actions):
            if (.name | startswith("installer-")) then ($actions["build-installer"] // "validated")
            elif (.name == "kubernetes-sysext") then ($actions["build-kubernetes-sysext"] // "validated")
            elif (.name == "runtime-uki" or .name == "runtime-root" or .name == "katlos-install-image") then ($actions["build-katlos-install-image"] // $actions["build-runtime"] // "validated")
            else "validated"
            end;
          .artifacts
          | map({
              name,
              kind,
              path: abs_path($repoRoot),
              repoPath: .path,
              sha256,
              sizeBytes,
              source: "resource-test-manifest",
              action: action_for($actions)
            })
        ' --arg repoRoot "$repo_root" --argjson actions "$(artifact_build_actions_json)" "$resource_manifest"
	)"
	vmtest_artifact_inputs_json="$(
		jq -c '
          {
            resourceManifestGitRevision: (.git.revision // .gitRevision // null),
            tools: (.tools // []),
            mkosiProfiles: (.mkosiProfiles // []),
            packageSets: ((.packageSets // []) | map({
              name,
              source,
              profile,
              lockSHA256,
              packageCount: ((.packages // []) | length)
            }))
          }
        ' "$resource_manifest"
	)"
}

probe_vm_capabilities() {
    if have_command "$image_tool"; then
        cap_image_tool="passed"
    else
        missing_capabilities+=("image-tool")
        cap_image_tool="$(missing_status missing)"
    fi

    if have_command "$virsh_bin" && "$virsh_bin" -c "$libvirt_uri" uri >/dev/null 2>&1; then
        cap_libvirt="passed"
    else
        missing_capabilities+=("libvirt")
        cap_libvirt="$(missing_status missing)"
    fi

    if [[ "$cap_libvirt" == "passed" ]]; then
        local network_info=""
        if network_info="$("$virsh_bin" -c "$libvirt_uri" net-info "$libvirt_network" 2>/dev/null)" &&
            grep -Eq '^Active:[[:space:]]+yes' <<<"$network_info" &&
            discover_libvirt_network; then
            cap_libvirt_network="passed"
        else
            missing_capabilities+=("libvirt-network")
            cap_libvirt_network="$(missing_status missing)"
        fi

        local pool_info=""
        if pool_info="$("$virsh_bin" -c "$libvirt_uri" pool-info "$libvirt_storage_pool" 2>/dev/null)" &&
            grep -Eq '^State:[[:space:]]+running' <<<"$pool_info"; then
            cap_libvirt_storage_pool="passed"
            local pool_xml=""
            if pool_xml="$("$virsh_bin" -c "$libvirt_uri" pool-dumpxml "$libvirt_storage_pool" 2>/dev/null)"; then
                local discovered_path=""
                discovered_path="$(sed -n 's:.*<path>\(.*\)</path>.*:\1:p' <<<"$pool_xml" | head -n 1)"
                if [[ -n "$discovered_path" ]]; then
                    libvirt_storage_path="$discovered_path"
                fi
            fi
        else
            missing_capabilities+=("libvirt-storage-pool")
            cap_libvirt_storage_pool="$(missing_status missing)"
        fi
    fi

    if [[ -n "$ovmf_code" && -e "$ovmf_code" && -n "$ovmf_vars" && -e "$ovmf_vars" ]]; then
        cap_ovmf="passed"
    else
        missing_capabilities+=("ovmf")
        cap_ovmf="$(missing_status missing)"
    fi
    if [[ -n "$kvm_device" && -e "$kvm_device" ]]; then
        cap_kvm="passed"
    else
        missing_capabilities+=("kvm")
        cap_kvm="$(missing_status missing)"
    fi
    if [[ -n "$vsock_device" && -e "$vsock_device" ]]; then
        cap_vsock="passed"
    else
        missing_capabilities+=("vsock")
        cap_vsock="$(missing_status missing)"
    fi
}

probe_fixture_tool_capabilities() {
    if have_command mformat && have_command mcopy && have_command truncate; then
        cap_mtools="passed"
    else
        missing_capabilities+=("mtools")
        cap_mtools="$(missing_status missing)"
    fi
    if have_command sfdisk; then
        cap_sfdisk="passed"
    else
        missing_capabilities+=("sfdisk")
        cap_sfdisk="$(missing_status missing)"
    fi
    if have_command sha256sum; then
        cap_sha256sum="passed"
    else
        missing_capabilities+=("sha256sum")
        cap_sha256sum="$(missing_status missing)"
    fi
    if have_command awk; then
        cap_awk="passed"
    else
        missing_capabilities+=("awk")
        cap_awk="$(missing_status missing)"
    fi
    if have_command realpath; then
        cap_realpath="passed"
    else
        missing_capabilities+=("realpath")
        cap_realpath="$(missing_status missing)"
    fi
    if have_command "$kubectl_bin"; then
        cap_kubectl="passed"
    else
        missing_capabilities+=("kubectl")
        cap_kubectl="$(missing_status missing)"
    fi
}

probe_capabilities() {
    probe_vm_capabilities
    probe_fixture_tool_capabilities
}

cleanup_existing_vmtest_domains() {
    if [[ "$cap_libvirt" != "passed" ]]; then
        return 0
    fi

    local -a domains=()
    local domain state
    while IFS= read -r domain; do
        domain="${domain//$'\r'/}"
        if [[ -z "$domain" ]]; then
            continue
        fi
        domains+=("$domain")
    done < <("$virsh_bin" -c "$libvirt_uri" list --all --name 2>/dev/null || true)

    if [[ "${#domains[@]}" -eq 0 ]]; then
        return 0
    fi

    printf 'vmtest cleanup: removing %d existing libvirt domain(s) before starting a new run\n' "${#domains[@]}" >&2
    for domain in "${domains[@]}"; do
        if [[ ! "$domain" =~ ^[A-Za-z0-9_.:-]+$ ]]; then
            setup_failures+=("refusing unsafe existing libvirt domain name: $domain")
            return 1
        fi
        state="$("$virsh_bin" -c "$libvirt_uri" domstate "$domain" 2>/dev/null || true)"
        case "$state" in
            *"shut off"*|*"no state"*|*"not found"*|"")
                ;;
            *)
                if ! "$virsh_bin" -c "$libvirt_uri" destroy "$domain" >/dev/null 2>&1; then
                    setup_failures+=("destroy existing vmtest domain $domain failed")
                    return 1
                fi
                ;;
        esac
        if ! "$virsh_bin" -c "$libvirt_uri" undefine "$domain" --nvram >/dev/null 2>&1; then
            setup_failures+=("undefine existing vmtest domain $domain failed")
            return 1
        fi
    done
}

ipv4_to_int() {
    local address="$1"
    local a b c d extra
    IFS=. read -r a b c d extra <<<"$address"
    if [[ -n "${extra:-}" || -z "${a:-}" || -z "${b:-}" || -z "${c:-}" || -z "${d:-}" ]]; then
        return 1
    fi
    local octet
    for octet in "$a" "$b" "$c" "$d"; do
        if ! [[ "$octet" =~ ^[0-9]+$ ]] || ((octet < 0 || octet > 255)); then
            return 1
        fi
    done
    printf "%u" "$(((a << 24) + (b << 16) + (c << 8) + d))"
}

int_to_ipv4() {
    local value="$1"
    printf "%u.%u.%u.%u" "$(((value >> 24) & 255))" "$(((value >> 16) & 255))" "$(((value >> 8) & 255))" "$((value & 255))"
}

netmask_to_prefix() {
    local mask="$1"
    local mask_int
    if ! mask_int="$(ipv4_to_int "$mask")"; then
        return 1
    fi
    local prefix=0
    local seen_zero=0
    local bit
    for ((bit = 31; bit >= 0; bit--)); do
        if (((mask_int & (1 << bit)) != 0)); then
            if [[ "$seen_zero" == 1 ]]; then
                return 1
            fi
            prefix=$((prefix + 1))
        else
            seen_zero=1
        fi
    done
    printf "%u" "$prefix"
}

network_cidr_from_gateway() {
    local gateway="$1"
    local prefix="$2"
    local gateway_int mask network_int
    if ! gateway_int="$(ipv4_to_int "$gateway")"; then
        return 1
    fi
    if ! [[ "$prefix" =~ ^[0-9]+$ ]] || ((prefix < 0 || prefix > 32)); then
        return 1
    fi
    if ((prefix == 0)); then
        mask=0
    else
        mask=$(((0xffffffff << (32 - prefix)) & 0xffffffff))
    fi
    network_int=$((gateway_int & mask))
    printf "%s/%u" "$(int_to_ipv4 "$network_int")" "$prefix"
}

discover_libvirt_network() {
    local network_xml gateway prefix netmask cidr
    if ! network_xml="$("$virsh_bin" -c "$libvirt_uri" net-dumpxml "$libvirt_network" 2>/dev/null)"; then
        return 1
    fi
    gateway="$(sed -n "s/.*<ip[^>]* address=['\"]\([^'\"]*\)['\"][^>]*>.*/\1/p" <<<"$network_xml" | head -n 1)"
    prefix="$(sed -n "s/.*<ip[^>]* prefix=['\"]\([0-9][0-9]*\)['\"][^>]*>.*/\1/p" <<<"$network_xml" | head -n 1)"
    if [[ -z "$prefix" ]]; then
        netmask="$(sed -n "s/.*<ip[^>]* netmask=['\"]\([^'\"]*\)['\"][^>]*>.*/\1/p" <<<"$network_xml" | head -n 1)"
        if [[ -n "$netmask" ]]; then
            prefix="$(netmask_to_prefix "$netmask")"
        fi
    fi
    if [[ -z "$gateway" || -z "$prefix" ]]; then
        return 1
    fi
    if ! cidr="$(network_cidr_from_gateway "$gateway" "$prefix")"; then
        return 1
    fi
    network_gateway="$gateway"
    network_cidr="$cidr"
}

validate_network() {
    if [[ ! "$network_cidr" =~ ^([^/]+)/([0-9]{1,2})$ ]]; then
        setup_failures+=("invalid CIDR: $network_cidr")
        return
    fi
    local network_address="${BASH_REMATCH[1]}"
    network_prefix="${BASH_REMATCH[2]}"
    if ((network_prefix < 0 || network_prefix > 32)); then
        setup_failures+=("invalid CIDR prefix: $network_cidr")
        return
    fi
    local network_int gateway_int mask
    if ! network_int="$(ipv4_to_int "$network_address")"; then
        setup_failures+=("invalid CIDR address: $network_cidr")
        return
    fi
    if ! gateway_int="$(ipv4_to_int "$network_gateway")"; then
        setup_failures+=("invalid gateway: $network_gateway")
        return
    fi
    if ((network_prefix == 0)); then
        mask=0
    else
        mask=$(((0xffffffff << (32 - network_prefix)) & 0xffffffff))
    fi
    if (((network_int & mask) != (gateway_int & mask))); then
        setup_failures+=("gateway $network_gateway is outside CIDR $network_cidr")
    fi
}

write_host_capabilities() {
    jq -n \
        --arg imageTool "$cap_image_tool" \
        --arg libvirt "$cap_libvirt" \
        --arg libvirtNetwork "$cap_libvirt_network" \
        --arg libvirtStoragePool "$cap_libvirt_storage_pool" \
        --arg ovmf "$cap_ovmf" \
        --arg kvm "$cap_kvm" \
        --arg vsock "$cap_vsock" \
        --arg mtools "$cap_mtools" \
        --arg sfdisk "$cap_sfdisk" \
        --arg sha256sum "$cap_sha256sum" \
        --arg awk "$cap_awk" \
        --arg realpath "$cap_realpath" \
        --arg kubectl "$cap_kubectl" \
        --args \
        '{
          apiVersion: "katl.dev/v1alpha1",
          kind: "VMTestHostCapabilities",
          capabilities: {
            "image-tool": $imageTool,
            libvirt: $libvirt,
            "libvirt-network": $libvirtNetwork,
            "libvirt-storage-pool": $libvirtStoragePool,
            ovmf: $ovmf,
            kvm: $kvm,
            vsock: $vsock,
            mtools: $mtools,
            sfdisk: $sfdisk,
            sha256sum: $sha256sum,
            awk: $awk,
            realpath: $realpath,
            kubectl: $kubectl
          },
          missing: $ARGS.positional
        }' -- "${missing_capabilities[@]}" >"$host_capabilities_json"
}

write_world() {
    jq -n \
        --arg runID "$run_id" \
        --arg runDir "$run_dir" \
        --arg cacheDir "$cache_dir" \
        --arg artifactDir "$artifact_dir" \
        --arg scenarioDir "$scenario_dir" \
        --arg runIndex "$run_index" \
        --arg goTestLog "$go_test_log" \
        --arg resourceManifest "$resource_manifest" \
        --arg resourceManifestSHA256 "$resource_manifest_sha256" \
        --arg packageLock "$package_lock" \
        --arg packageLockSHA256 "$package_lock_sha256" \
        --argjson vmtestArtifacts "$vmtest_artifacts_json" \
        --argjson vmtestArtifactInputs "$vmtest_artifact_inputs_json" \
        --arg autoRebuild "$auto_rebuild" \
        --arg artifactSet "$artifact_set" \
        --arg debugOnFailure "$debug_on_failure_effective" \
        --arg libvirtURI "$libvirt_uri" \
        --arg libvirtNetwork "$libvirt_network" \
        --arg libvirtStoragePool "$libvirt_storage_pool" \
        --arg libvirtStoragePath "$libvirt_storage_path" \
        --arg libvirtDomainPrefix "$libvirt_domain_prefix" \
        --arg cidr "$network_cidr" \
        --arg gateway "$network_gateway" \
        --arg leaseFile "$lease_file" \
        --arg imageTool "$cap_image_tool" \
        --arg libvirt "$cap_libvirt" \
        --arg libvirtNetworkStatus "$cap_libvirt_network" \
        --arg libvirtStoragePoolStatus "$cap_libvirt_storage_pool" \
        --arg ovmf "$cap_ovmf" \
        --arg kvm "$cap_kvm" \
        --arg vsock "$cap_vsock" \
        --arg mtools "$cap_mtools" \
        --arg sfdisk "$cap_sfdisk" \
        --arg sha256sum "$cap_sha256sum" \
        --arg awk "$cap_awk" \
        --arg realpath "$cap_realpath" \
        --arg kubectl "$cap_kubectl" \
        '{
          apiVersion: "katl.dev/v1alpha1",
          kind: "VMTestWorld",
          runID: $runID,
          runDir: $runDir,
          cacheDir: $cacheDir,
          artifactDir: $artifactDir,
          scenarioDir: $scenarioDir,
          runIndex: $runIndex,
          goTestLog: $goTestLog,
          resourceManifest: $resourceManifest,
          resourceManifestSHA256: $resourceManifestSHA256,
          packageLock: $packageLock,
          packageLockSHA256: $packageLockSHA256,
          vmtestArtifacts: $vmtestArtifacts,
          vmtestArtifactInputs: $vmtestArtifactInputs,
          autoRebuild: ($autoRebuild == "1" or $autoRebuild == "true" or $autoRebuild == "yes" or $autoRebuild == "on"),
          artifactSet: $artifactSet,
          debugOnFailure: ($debugOnFailure == "1"),
          debugShell: ($debugOnFailure == "1"),
          libvirt: {
            uri: $libvirtURI,
            network: $libvirtNetwork,
            storagePool: $libvirtStoragePool,
            storagePath: $libvirtStoragePath,
            domainPrefix: $libvirtDomainPrefix
          },
          network: {
            backend: "libvirt",
            name: $libvirtNetwork,
            cidr: $cidr,
            gateway: $gateway,
            leaseFile: $leaseFile
          },
          capabilities: {
            "image-tool": $imageTool,
            libvirt: $libvirt,
            "libvirt-network": $libvirtNetworkStatus,
            "libvirt-storage-pool": $libvirtStoragePoolStatus,
            ovmf: $ovmf,
            kvm: $kvm,
            mtools: $mtools,
            sfdisk: $sfdisk,
            sha256sum: $sha256sum,
            awk: $awk,
            realpath: $realpath,
            kubectl: $kubectl,
            vsock: $vsock
          }
        }' >"$world_manifest"
}

write_run_index() {
    local status="$1"
    shift
    local setup_failure_text=""
    local missing_capabilities_json
    if [[ "${#setup_failures[@]}" -gt 0 ]]; then
        setup_failure_text="$(printf '%s\n' "${setup_failures[@]}")"
    fi
    missing_capabilities_json="$(jq -n '$ARGS.positional' --args -- "${missing_capabilities[@]}")"
    jq -n \
        --arg runID "$run_id" \
        --arg runDir "$run_dir" \
        --arg cacheDir "$cache_dir" \
        --arg artifactDir "$artifact_dir" \
        --arg scenarioDir "$scenario_dir" \
        --arg worldManifest "$world_manifest" \
        --arg hostCapabilities "$host_capabilities_json" \
        --arg goTestLog "$go_test_log" \
        --arg resourceManifest "$resource_manifest" \
        --arg resourceManifestSHA256 "$resource_manifest_sha256" \
        --arg packageLock "$package_lock" \
        --arg packageLockSHA256 "$package_lock_sha256" \
        --argjson vmtestArtifacts "$vmtest_artifacts_json" \
        --argjson vmtestArtifactInputs "$vmtest_artifact_inputs_json" \
        --arg autoRebuild "$auto_rebuild" \
        --arg artifactSet "$artifact_set" \
        --arg debugOnFailure "$debug_on_failure_effective" \
        --arg leaseFile "$lease_file" \
        --arg status "$status" \
        --arg setupFailures "$setup_failure_text" \
        --argjson missingCapabilities "$missing_capabilities_json" \
        --args \
        '{
          apiVersion: "katl.dev/v1alpha1",
          kind: "VMTestRun",
          runID: $runID,
          runDir: $runDir,
          cacheDir: $cacheDir,
          artifactDir: $artifactDir,
          scenarioDir: $scenarioDir,
          worldManifest: $worldManifest,
          hostCapabilities: $hostCapabilities,
          goTestLog: $goTestLog,
          resourceManifest: $resourceManifest,
          resourceManifestSHA256: $resourceManifestSHA256,
          packageLock: $packageLock,
          packageLockSHA256: $packageLockSHA256,
          vmtestArtifacts: $vmtestArtifacts,
          vmtestArtifactInputs: $vmtestArtifactInputs,
          autoRebuild: ($autoRebuild == "1" or $autoRebuild == "true" or $autoRebuild == "yes" or $autoRebuild == "on"),
          artifactSet: $artifactSet,
          debugOnFailure: ($debugOnFailure == "1"),
          debugShell: ($debugOnFailure == "1"),
          networkLeaseFile: $leaseFile,
          status: $status,
          missingCapabilities: $missingCapabilities,
          goTestArgs: $ARGS.positional,
          setupFailures: ($setupFailures | split("\n") | map(select(length > 0)))
        }' -- "$@" >"$run_index"
}

validate_keep_policy() {
    case "$keep_policy" in
        never | failed | always)
            ;;
        *)
            setup_failures+=("invalid vmtest keep policy: $keep_policy")
            ;;
    esac
}

validate_debug_on_failure_policy() {
    local value
    value="$(printf '%s' "$debug_on_failure_policy" | tr '[:upper:]' '[:lower:]')"
    case "$value" in
        auto)
            if [[ "${CI:-}" == "true" || "${CI:-}" == "1" ]]; then
                debug_on_failure_effective=0
            else
                debug_on_failure_effective=1
            fi
            ;;
        1 | true | yes | on)
            debug_on_failure_effective=1
            ;;
        0 | false | no | off)
            debug_on_failure_effective=0
            ;;
        *)
            setup_failures+=("invalid vmtest debug-on-failure policy: $debug_on_failure_policy")
            debug_on_failure_effective=0
            ;;
    esac
}

cleanup_run_dir() {
    local status="$1"
    local remove=0
    case "$keep_policy" in
        always)
            remove=0
            ;;
        failed)
            if [[ "$status" == "passed" ]]; then
                remove=1
            fi
            ;;
        never)
            remove=1
            ;;
        *)
            return 1
            ;;
    esac
    if [[ "$remove" != 1 ]]; then
        return 0
    fi
    if [[ ! -f "$run_owner_marker" ]]; then
        printf 'vmtest run dir cleanup skipped; ownership marker is missing: %s\n' "$run_owner_marker" >&2
        return 0
    fi
    if [[ "$(cat "$run_owner_marker")" != "$run_id" ]]; then
        printf 'vmtest run dir cleanup skipped; ownership marker does not match run id: %s\n' "$run_owner_marker" >&2
        return 0
    fi
    if [[ -z "$run_dir" || "$run_dir" == "/" || "$run_dir" == "." ]]; then
        printf 'vmtest run dir cleanup refused unsafe path: %s\n' "$run_dir" >&2
        return 1
    fi
    rm -rf -- "$run_dir"
    printf 'vmtest run dir removed: %s\n' "$run_dir" >&2
}

print_preserved_debug_targets() {
    local tmp result line printed=0
    tmp="$(mktemp "$run_dir/preserved-vm-debug.XXXXXX")"
    {
        find "$scenario_dir" -mindepth 2 -maxdepth 8 -name result.json -print 2>/dev/null || true
    } | while IFS= read -r result; do
        jq -r --arg result "$result" '
          (.debug.targets // [])
          | map(select(.preserved == true))
          | .[]
          | [
              $result,
              .domainName,
              .libvirtURI,
              .serialLog,
              .consoleCommand,
              (.vsock.guestCid // ""),
              (.vsock.port // ""),
              .shellMode,
              .cleanupCommand
            ]
          | @tsv
        ' "$result" 2>/dev/null || true
    done >"$tmp"
    if [[ ! -s "$tmp" ]]; then
        rm -f "$tmp"
        return 0
    fi
    {
        printf 'preserved VM debug targets\n'
        printf 'These libvirt domains were preserved by vmtest debug-on-failure. They will not be cleaned up automatically.\n'
        while IFS=$'\t' read -r result domain uri serial console cid port shell cleanup; do
            printed=1
            printf '\n'
            printf -- '- result: %s\n' "$result"
            printf '  domain: %s\n' "$domain"
            printf '  libvirt URI: %s\n' "$uri"
            printf '  console: %s\n' "$console"
            printf '  serial log: %s\n' "$serial"
            if [[ -n "$cid" && -n "$port" ]]; then
                printf '  vsock: cid=%s port=%s\n' "$cid" "$port"
            fi
            if [[ -n "$shell" ]]; then
                printf '  shell: %s\n' "$shell"
            fi
            printf '  cleanup: %s\n' "$cleanup"
        done <"$tmp"
        if [[ "$printed" == 1 ]]; then
            printf '\nRun the cleanup command when you are done debugging.\n'
        fi
    } | tee "$debug_targets_artifact" >&2
    rm -f "$tmp"
}

parse_runner_args "$@"
if [[ "$help_requested" == 1 ]]; then
    usage
    exit 0
fi
set -- "${go_test_input_args[@]}"

need jq
mkdir -p "$cache_dir" "$artifact_dir" "$scenario_dir" "$network_dir"
if [[ "$run_dir_preexisting" == 0 ]]; then
    printf '%s\n' "$run_id" >"$run_owner_marker"
fi
: >"$go_test_log"
validate_debug_on_failure_policy
jq -n '{}' >"$lease_file"
write_host_capabilities
write_run_index "setup" "$@"
validate_keep_policy
validate_stale_artifact_policy
validate_current_artifact_inputs
validate_network
if [[ "${#setup_failures[@]}" -gt 0 ]]; then
    write_run_index "setup-failed" "$@"
    printf 'setup failed: %s\n' "${setup_failures[@]}" >&2
    if ! cleanup_run_dir "setup-failed"; then
        printf 'vmtest run dir cleanup failed: %s\n' "$run_dir" >&2
    fi
    exit 2
fi
write_run_index "building-artifacts" "$@"
if ! build_default_artifacts; then
    write_run_index "setup-failed" "$@"
    printf 'setup failed: %s\n' "${setup_failures[@]}" >&2
    if ! cleanup_run_dir "setup-failed"; then
        printf 'vmtest run dir cleanup failed: %s\n' "$run_dir" >&2
    fi
    exit 2
fi
if ! prepare_resource_manifest; then
    write_run_index "setup-failed" "$@"
    printf 'setup failed: %s\n' "${setup_failures[@]}" >&2
    if ! cleanup_run_dir "setup-failed"; then
        printf 'vmtest run dir cleanup failed: %s\n' "$run_dir" >&2
    fi
    exit 2
fi
probe_capabilities
write_host_capabilities
write_world
if [[ "${#missing_capabilities[@]}" -gt 0 ]]; then
    print_missing_capabilities "vmtest world has missing host capabilities"
fi
if ! cleanup_existing_vmtest_domains; then
    write_run_index "setup-failed" "$@"
    printf 'setup failed: %s\n' "${setup_failures[@]}" >&2
    if ! cleanup_run_dir "setup-failed"; then
        printf 'vmtest run dir cleanup failed: %s\n' "$run_dir" >&2
    fi
    exit 2
fi

export KATL_VMTEST_RUN_DIR="$run_dir"
export KATL_VMTEST_CACHE_DIR="$cache_dir"
export KATL_VMTEST_WORLD_MANIFEST="$world_manifest"
export KATL_VMTEST_LIBVIRT_URI="$libvirt_uri"
export KATL_VMTEST_LIBVIRT_NETWORK="$libvirt_network"
export KATL_VMTEST_LIBVIRT_STORAGE_POOL="$libvirt_storage_pool"
export KATL_VMTEST_LIBVIRT_STORAGE_PATH="$libvirt_storage_path"
export KATL_VMTEST_LIBVIRT_DOMAIN_PREFIX="$libvirt_domain_prefix"
export KATL_VMTEST_DEBUG_ON_FAILURE="$debug_on_failure_effective"
export KATL_VMTEST_RESOURCE_MANIFEST="$resource_manifest"

final_status="go-test"
write_run_index "$final_status" "$@"
printf 'vmtest run id: %s\n' "$run_id" >&2
printf 'vmtest run dir: %s\n' "$run_dir" >&2
printf 'vmtest world: %s\n' "$world_manifest" >&2
printf 'vmtest host capabilities: %s\n' "$host_capabilities_json" >&2
if [[ -f "$resource_manifest" ]]; then
    printf 'vmtest resource manifest: %s\n' "$resource_manifest" >&2
fi
printf 'vmtest scenarios: %s\n' "$scenario_dir" >&2
printf 'vmtest go test log: %s\n' "$go_test_log" >&2
printf 'vmtest debug helper: scripts/vmtest-debug %q\n' "$run_dir" >&2
go_test_args=()
if [[ -n "$go_test_timeout" ]] && ! has_go_test_timeout "$@"; then
    go_test_args+=("-timeout" "$go_test_timeout")
fi
set +e
"$go_bin" test -exec "$repo_root/scripts/vmtest-exec" "${go_test_args[@]}" "$@" >"$go_test_log" 2>&1
exit_code=$?
set -e
if [[ "$exit_code" -ne 0 ]]; then
    write_run_index "failed" "$@"
    printf 'vmtest failed: go test exited %d\n' "$exit_code" >&2
    print_preserved_debug_targets
    if ! cleanup_run_dir "failed"; then
        printf 'vmtest run dir cleanup failed: %s\n' "$run_dir" >&2
    fi
    exit "$exit_code"
fi
if [[ "$exit_code" -eq 0 && ( "$require_scenario_result" == 1 || "$require_scenario_result" == true ) ]]; then
    if ! find "$scenario_dir" -mindepth 2 -maxdepth 4 -name result.json -print -quit | grep -q .; then
        write_run_index "no-scenario-result" "$@"
        printf 'vmtest did not execute any world scenario; no result.json found under %s\n' "$scenario_dir" >&2
        printf 'vmtest run dir: %s\n' "$run_dir" >&2
        printf 'vmtest go test log: %s\n' "$go_test_log" >&2
        print_preserved_debug_targets
        if ! cleanup_run_dir "no-scenario-result"; then
            printf 'vmtest run dir cleanup failed: %s\n' "$run_dir" >&2
        fi
        exit 3
    fi
fi
write_run_index "passed" "$@"
if ! cleanup_run_dir "passed"; then
    printf 'vmtest run dir cleanup failed: %s\n' "$run_dir" >&2
    exit 4
fi
printf 'vmtest passed\n' >&2
exit "$exit_code"
