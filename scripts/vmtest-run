#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
go_bin="${KATL_VMTEST_GO:-go}"
qemu_bin="${KATL_VMTEST_QEMU:-qemu-system-x86_64}"
qemu_img_bin="${KATL_VMTEST_QEMU_IMG:-qemu-img}"
ip_bin="${KATL_VMTEST_IP:-ip}"
kubectl_bin="${KATL_VMTEST_KUBECTL:-kubectl}"
tmp_parent="${TMPDIR:-/tmp}/katl-vmtest"
run_id="${KATL_VMTEST_RUN_ID:-$(date -u +%Y%m%dT%H%M%SZ)-$$}"
run_dir="${KATL_VMTEST_RUN_DIR:-$tmp_parent/$run_id}"
artifact_dir="$run_dir/artifacts"
scenario_dir="$run_dir/scenarios"
network_dir="$run_dir/network"
world_manifest="$run_dir/world.json"
host_capabilities_json="$run_dir/host-capabilities.json"
lease_file="$network_dir/leases.json"
go_test_log="$run_dir/go-test.log"
summary_json="$run_dir/summary.json"
scenario_summary_json="$run_dir/scenario-summary.json"
selected_packages_json="$run_dir/selected-packages.json"
setup_failures_json="$run_dir/setup-failures.json"
keep_policy="${KATL_VMTEST_KEEP:-failed}"
host_policy="${KATL_VMTEST_HOST_POLICY:-}"
network_backend="${KATL_VMTEST_NETWORK_BACKEND:-bridge}"
network_bridge="${KATL_VMTEST_BRIDGE:-katl-vmtest0}"
network_cidr="${KATL_VMTEST_CIDR:-10.77.0.0/24}"
network_gateway="${KATL_VMTEST_GATEWAY:-10.77.0.1}"
ovmf_code="${KATL_OVMF_CODE:-}"
ovmf_vars="${KATL_OVMF_VARS:-}"
kvm_device="${KATL_VMTEST_KVM_DEVICE:-/dev/kvm}"
vsock_device="${KATL_VMTEST_VSOCK_DEVICE:-/dev/vhost-vsock}"
tun_device="${KATL_VMTEST_TUN_DEVICE:-/dev/net/tun}"
bridge_conf="${KATL_QEMU_BRIDGE_CONF:-/etc/qemu/bridge.conf}"
network_prefix=""
bridge_created=0
final_status="setup-failed"
cap_qemu="disabled"
cap_qemu_img="disabled"
cap_ovmf="disabled"
cap_kvm="disabled"
cap_vsock="disabled"
cap_bridge="disabled"
cap_mtools="disabled"
cap_sfdisk="disabled"
cap_sha256sum="disabled"
cap_awk="disabled"
cap_realpath="disabled"
cap_systemd_nspawn="disabled"
cap_kubectl="disabled"
capability_scope="full"
missing_capabilities=()
setup_failures=()

if [[ -z "$host_policy" ]]; then
    host_policy="fail"
fi

usage() {
    cat <<'USAGE'
Usage: scripts/vmtest-run [go test package patterns and flags...]

Create a temporary Katl VM test world and run Go test binaries through
scripts/vmtest-exec. Arguments are forwarded to go test after forcing -count=1.
Pass the normal go test -json flag when JSON event output is wanted.
With no package arguments, the runner preflights the full suite host
capabilities before running tests. With explicit package or -run selections,
host capability state is recorded and the selected tests enforce their own
requirements under the strict world.

Environment:
  KATL_VMTEST_HOST_POLICY=skip|fail        Host capability gap handling (default: fail)
  KATL_VMTEST_NETWORK_BACKEND=bridge       Network backend
  KATL_VMTEST_CIDR=10.77.0.0/24            World network CIDR
  KATL_VMTEST_GATEWAY=10.77.0.1            Bridge gateway address
  KATL_VMTEST_BRIDGE=katl-vmtest0          Bridge name
  KATL_VMTEST_KUBECTL=kubectl              kubectl used for host-side verification
  KATL_VMTEST_KEEP=never|failed|always     Cleanup policy
USAGE
}

need() {
    command -v "$1" >/dev/null 2>&1 || {
        echo "error: $1 is required" >&2
        exit 1
    }
}

status_for_missing_capabilities() {
    if [[ "$host_policy" == "skip" ]]; then
        printf "host-skipped"
    else
        printf "failed"
    fi
}

missing_status() {
    if [[ "$1" == "passed" ]]; then
        printf "passed"
    else
        status_for_missing_capabilities
    fi
}

have_command() {
    command -v "$1" >/dev/null 2>&1
}

capability_hint() {
    case "$1" in
        qemu)
            printf "install qemu-system-x86_64 or set KATL_VMTEST_QEMU to the QEMU binary"
            ;;
        qemu-img)
            printf "install qemu-img or set KATL_VMTEST_QEMU_IMG to the qemu-img binary"
            ;;
        ovmf)
            printf "set KATL_OVMF_CODE and KATL_OVMF_VARS to readable OVMF pflash images"
            ;;
        kvm)
            printf "%s is missing; enable KVM support or set KATL_VMTEST_KVM_DEVICE" "$kvm_device"
            ;;
        vsock)
            printf "%s is missing; load vhost_vsock or set KATL_VMTEST_VSOCK_DEVICE" "$vsock_device"
            ;;
        mtools)
            printf "install mtools and coreutils so mformat, mcopy, and truncate are available"
            ;;
        sfdisk)
            printf "install util-linux so sfdisk is available"
            ;;
        sha256sum)
            printf "install coreutils so sha256sum is available"
            ;;
        awk)
            printf "install awk, such as gawk"
            ;;
        realpath)
            printf "install coreutils so realpath is available"
            ;;
        kubectl)
            printf "install kubectl or set KATL_VMTEST_KUBECTL to the kubectl binary"
            ;;
        systemd-nspawn)
            printf "install systemd-nspawn"
            ;;
        nspawn-privileges)
            printf "systemd-nspawn is installed, but this run is not privileged; run with sudo or set KATL_NSPAWN_ALLOW_UNPRIVILEGED=1 after configuring rootless systemd-nspawn"
            ;;
        tun)
            printf "%s is missing; load the tun module or set KATL_VMTEST_TUN_DEVICE" "$tun_device"
            ;;
        qemu-bridge-helper)
            printf "install qemu-bridge-helper or set KATL_QEMU_BRIDGE_HELPER to its path"
            ;;
        qemu-bridge-acl)
            printf "%s must contain 'allow %s' or 'allow all'; override the ACL path with KATL_QEMU_BRIDGE_CONF" "$bridge_conf" "$network_bridge"
            ;;
        bridge)
            printf "create or allow creation of bridge %s, or set KATL_VMTEST_BRIDGE to an existing bridge" "$network_bridge"
            ;;
        *)
            printf "see %s for recorded host capability state" "$host_capabilities_json"
            ;;
    esac
}

print_missing_capabilities() {
    local heading="$1"
    local printed=""
    local capability hint
    printf '%s\n' "$heading" >&2
    for capability in "${missing_capabilities[@]}"; do
        case " $printed " in
            *" $capability "*)
                continue
                ;;
        esac
        printed="${printed:+$printed }$capability"
        hint="$(capability_hint "$capability")"
        printf '  - %s: %s\n' "$capability" "$hint" >&2
    done
    printf 'vmtest run dir: %s\n' "$run_dir" >&2
}

probe_vm_capabilities() {
    if have_command "$qemu_bin"; then
        cap_qemu="passed"
    else
        missing_capabilities+=("qemu")
        cap_qemu="$(missing_status missing)"
    fi
    if have_command "$qemu_img_bin"; then
        cap_qemu_img="passed"
    else
        missing_capabilities+=("qemu-img")
        cap_qemu_img="$(missing_status missing)"
    fi
    if [[ -n "$ovmf_code" && -e "$ovmf_code" && -n "$ovmf_vars" && -e "$ovmf_vars" ]]; then
        cap_ovmf="passed"
    else
        missing_capabilities+=("ovmf")
        cap_ovmf="$(missing_status missing)"
    fi
    if [[ -n "$kvm_device" && -e "$kvm_device" ]]; then
        cap_kvm="passed"
    else
        missing_capabilities+=("kvm")
        cap_kvm="$(missing_status missing)"
    fi
    if [[ -n "$vsock_device" && -e "$vsock_device" ]]; then
        cap_vsock="passed"
    else
        missing_capabilities+=("vsock")
        cap_vsock="$(missing_status missing)"
    fi
}

probe_fixture_tool_capabilities() {
    if have_command mformat && have_command mcopy && have_command truncate; then
        cap_mtools="passed"
    else
        missing_capabilities+=("mtools")
        cap_mtools="$(missing_status missing)"
    fi
    if have_command sfdisk; then
        cap_sfdisk="passed"
    else
        missing_capabilities+=("sfdisk")
        cap_sfdisk="$(missing_status missing)"
    fi
    if have_command sha256sum; then
        cap_sha256sum="passed"
    else
        missing_capabilities+=("sha256sum")
        cap_sha256sum="$(missing_status missing)"
    fi
    if have_command awk; then
        cap_awk="passed"
    else
        missing_capabilities+=("awk")
        cap_awk="$(missing_status missing)"
    fi
    if have_command realpath; then
        cap_realpath="passed"
    else
        missing_capabilities+=("realpath")
        cap_realpath="$(missing_status missing)"
    fi
    if have_command "$kubectl_bin"; then
        cap_kubectl="passed"
    else
        missing_capabilities+=("kubectl")
        cap_kubectl="$(missing_status missing)"
    fi
}

probe_nspawn_capabilities() {
    if have_command systemd-nspawn; then
        if [[ "${EUID:-$(id -u)}" == 0 || "${KATL_NSPAWN_ALLOW_UNPRIVILEGED:-}" == 1 || "${KATL_NSPAWN_ALLOW_UNPRIVILEGED:-}" == true ]]; then
            cap_systemd_nspawn="passed"
        else
            missing_capabilities+=("nspawn-privileges")
            cap_systemd_nspawn="$(missing_status missing)"
        fi
    else
        missing_capabilities+=("systemd-nspawn")
        cap_systemd_nspawn="$(missing_status missing)"
    fi
}

probe_capabilities() {
    case "$capability_scope" in
        nspawn)
            probe_nspawn_capabilities
            ;;
        *)
            probe_vm_capabilities
            probe_fixture_tool_capabilities
            probe_nspawn_capabilities
            ;;
    esac
}

ipv4_to_int() {
    local address="$1"
    local a b c d extra
    IFS=. read -r a b c d extra <<<"$address"
    if [[ -n "${extra:-}" || -z "${a:-}" || -z "${b:-}" || -z "${c:-}" || -z "${d:-}" ]]; then
        return 1
    fi
    local octet
    for octet in "$a" "$b" "$c" "$d"; do
        if ! [[ "$octet" =~ ^[0-9]+$ ]] || ((octet < 0 || octet > 255)); then
            return 1
        fi
    done
    printf "%u" "$(((a << 24) + (b << 16) + (c << 8) + d))"
}

validate_network() {
    if [[ "$network_backend" != "bridge" ]]; then
        setup_failures+=("unsupported network backend: $network_backend")
        return
    fi
    if [[ ! "$network_cidr" =~ ^([^/]+)/([0-9]{1,2})$ ]]; then
        setup_failures+=("invalid CIDR: $network_cidr")
        return
    fi
    local network_address="${BASH_REMATCH[1]}"
    network_prefix="${BASH_REMATCH[2]}"
    if ((network_prefix < 0 || network_prefix > 32)); then
        setup_failures+=("invalid CIDR prefix: $network_cidr")
        return
    fi
    local network_int gateway_int mask
    if ! network_int="$(ipv4_to_int "$network_address")"; then
        setup_failures+=("invalid CIDR address: $network_cidr")
        return
    fi
    if ! gateway_int="$(ipv4_to_int "$network_gateway")"; then
        setup_failures+=("invalid gateway: $network_gateway")
        return
    fi
    if ((network_prefix == 0)); then
        mask=0
    else
        mask=$(((0xffffffff << (32 - network_prefix)) & 0xffffffff))
    fi
    if (((network_int & mask) != (gateway_int & mask))); then
        setup_failures+=("gateway $network_gateway is outside CIDR $network_cidr")
    fi
}

find_bridge_helper() {
    if [[ -n "${KATL_QEMU_BRIDGE_HELPER:-}" ]]; then
        printf "%s" "$KATL_QEMU_BRIDGE_HELPER"
        return 0
    fi
    local helper
    for helper in /usr/lib/qemu/qemu-bridge-helper /usr/libexec/qemu-bridge-helper /usr/lib64/qemu/qemu-bridge-helper; do
        if [[ -e "$helper" ]]; then
            printf "%s" "$helper"
            return 0
        fi
    done
    return 1
}

bridge_acl_allows() {
    local bridge="$1"
    local line
    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line%%#*}"
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        if [[ "$line" == "allow all" || "$line" == "allow $bridge" ]]; then
            return 0
        fi
    done <"$bridge_conf"
    return 1
}

check_bridge_prerequisites() {
    local missing=0
    if [[ ! -e "$tun_device" ]]; then
        missing_capabilities+=("tun")
        missing=1
    fi
    local helper=""
    if ! helper="$(find_bridge_helper)"; then
        missing_capabilities+=("qemu-bridge-helper")
        missing=1
    elif [[ ! -e "$helper" ]]; then
        missing_capabilities+=("qemu-bridge-helper")
        missing=1
    fi
    if [[ ! -r "$bridge_conf" ]]; then
        missing_capabilities+=("qemu-bridge-acl")
        missing=1
    elif ! bridge_acl_allows "$network_bridge"; then
        missing_capabilities+=("qemu-bridge-acl")
        missing=1
    fi
    if [[ "$missing" == 1 ]]; then
        cap_bridge="$(missing_status missing)"
        return 1
    fi
    return 0
}

setup_network() {
    if [[ "$network_backend" != "bridge" ]]; then
        return
    fi
    if ! have_command "$ip_bin"; then
        missing_capabilities+=("bridge")
        cap_bridge="$(missing_status missing)"
        return
    fi
    if "$ip_bin" link show "$network_bridge" >/dev/null 2>&1; then
        if ! check_bridge_prerequisites; then
            return 0
        fi
        cap_bridge="passed"
        return
    fi
    if "$ip_bin" link add name "$network_bridge" type bridge >/dev/null 2>&1; then
        bridge_created=1
        if "$ip_bin" addr add "$network_gateway/$network_prefix" dev "$network_bridge" >/dev/null 2>&1 &&
            "$ip_bin" link set "$network_bridge" up >/dev/null 2>&1; then
            if ! check_bridge_prerequisites; then
                return 0
            fi
            cap_bridge="passed"
            return
        fi
    fi
    missing_capabilities+=("bridge")
    cap_bridge="$(missing_status missing)"
}

write_host_capabilities() {
    jq -n \
        --arg qemu "$cap_qemu" \
        --arg qemuImg "$cap_qemu_img" \
        --arg ovmf "$cap_ovmf" \
        --arg kvm "$cap_kvm" \
        --arg vsock "$cap_vsock" \
        --arg bridge "$cap_bridge" \
        --arg mtools "$cap_mtools" \
        --arg sfdisk "$cap_sfdisk" \
        --arg sha256sum "$cap_sha256sum" \
        --arg awk "$cap_awk" \
        --arg realpath "$cap_realpath" \
        --arg systemdNspawn "$cap_systemd_nspawn" \
        --arg kubectl "$cap_kubectl" \
        --args \
        '{
          apiVersion: "katl.dev/v1alpha1",
          kind: "VMTestHostCapabilities",
          capabilities: {
            qemu: $qemu,
            "qemu-img": $qemuImg,
            ovmf: $ovmf,
            kvm: $kvm,
            vsock: $vsock,
            bridge: $bridge,
            mtools: $mtools,
            sfdisk: $sfdisk,
            sha256sum: $sha256sum,
            awk: $awk,
            realpath: $realpath,
            kubectl: $kubectl,
            "systemd-nspawn": $systemdNspawn
          },
          missing: $ARGS.positional
        }' -- "${missing_capabilities[@]}" >"$host_capabilities_json"
}

write_world() {
    jq -n \
        --arg runID "$run_id" \
        --arg runDir "$run_dir" \
        --arg artifactDir "$artifact_dir" \
        --arg scenarioDir "$scenario_dir" \
        --arg bridge "$network_bridge" \
        --arg cidr "$network_cidr" \
        --arg gateway "$network_gateway" \
        --arg leaseFile "$lease_file" \
        --arg qemu "$cap_qemu" \
        --arg qemuImg "$cap_qemu_img" \
        --arg ovmf "$cap_ovmf" \
        --arg kvm "$cap_kvm" \
        --arg vsock "$cap_vsock" \
        --arg bridgeStatus "$cap_bridge" \
        --arg mtools "$cap_mtools" \
        --arg sfdisk "$cap_sfdisk" \
        --arg sha256sum "$cap_sha256sum" \
        --arg awk "$cap_awk" \
        --arg realpath "$cap_realpath" \
        --arg systemdNspawn "$cap_systemd_nspawn" \
        --arg kubectl "$cap_kubectl" \
        '{
          apiVersion: "katl.dev/v1alpha1",
          kind: "VMTestWorld",
          runID: $runID,
          runDir: $runDir,
          artifactDir: $artifactDir,
          scenarioDir: $scenarioDir,
          network: {
            backend: "bridge",
            bridge: $bridge,
            cidr: $cidr,
            gateway: $gateway,
            leaseFile: $leaseFile
          },
          capabilities: {
            qemu: $qemu,
            "qemu-img": $qemuImg,
            ovmf: $ovmf,
            kvm: $kvm,
            bridge: $bridgeStatus,
            mtools: $mtools,
            sfdisk: $sfdisk,
            sha256sum: $sha256sum,
            awk: $awk,
            realpath: $realpath,
            kubectl: $kubectl,
            vsock: $vsock,
            "systemd-nspawn": $systemdNspawn
          }
        }' >"$world_manifest"
}

write_selected_packages() {
    local packages=()
    local expect_flag_value=0
    local after_args=0
    while [[ $# -gt 0 ]]; do
        if [[ "$after_args" == 1 ]]; then
            shift
            continue
        fi
        if [[ "$expect_flag_value" == 1 ]]; then
            expect_flag_value=0
            shift
            continue
        fi
        case "$1" in
            -args)
                after_args=1
                shift
                ;;
            -run|-bench|-list|-skip|-timeout|-benchtime|-cpu|-parallel|-shuffle|-coverprofile|-covermode|-coverpkg|-outputdir|-count)
                expect_flag_value=1
                shift
                ;;
            -*)
                shift
                ;;
            *)
                packages+=("$1")
                shift
                ;;
        esac
    done
    jq -n --args '$ARGS.positional' -- "${packages[@]}" >"$selected_packages_json"
}

write_setup_failures() {
    jq -n --args '$ARGS.positional' -- "${setup_failures[@]}" >"$setup_failures_json"
}

append_scenario_summary() {
    local item_json="$1"
    local tmp="$scenario_summary_json.tmp"
    jq --argjson item "$item_json" '. + [$item]' "$scenario_summary_json" >"$tmp"
    mv "$tmp" "$scenario_summary_json"
}

scenario_status_from_result() {
    local result_path="$1"
    jq -r '
      (.status // "") as $status |
      if $status == "passed" or $status == "pass" then "passed"
      elif $status == "failed" or $status == "fail" then "failed"
      elif $status == "setup-failed" then "setup-failed"
      elif $status == "skipped" or $status == "skip" then
        if ((.missing // []) | length) > 0 then "host-skipped" else "setup-failed" end
      elif $status == "planned" or $status == "" then "setup-failed"
      else "setup-failed"
      end
    ' "$result_path"
}

collect_scenario_summaries() {
    jq -n '[]' >"$scenario_summary_json"
    if [[ ! -d "$scenario_dir" ]]; then
        return
    fi
    local scenario_manifest result_path item status failure tmp
    while IFS= read -r -d '' scenario_manifest; do
        if ! jq -e . "$scenario_manifest" >/dev/null 2>&1; then
            item="$(
                jq -n \
                    --arg manifestPath "$scenario_manifest" \
                    --arg status "setup-failed" \
                    --arg failureSummary "scenario manifest is invalid JSON" \
                    '{manifestPath: $manifestPath, status: $status, failureSummary: $failureSummary}'
            )"
            append_scenario_summary "$item"
            continue
        fi
        result_path="$(jq -r '.resultPath // empty' "$scenario_manifest")"
        if [[ -z "$result_path" ]]; then
            item="$(
                jq -n \
                    --slurpfile scenario "$scenario_manifest" \
                    --arg manifestPath "$scenario_manifest" \
                    --arg status "setup-failed" \
                    --arg failureSummary "scenario manifest is missing resultPath" \
                    '{
                      name: $scenario[0].name,
                      id: $scenario[0].id,
                      manifestPath: $manifestPath,
                      status: $status,
                      failureSummary: $failureSummary,
                      nodes: ($scenario[0].nodes // []),
                      fixtures: ($scenario[0].fixtures // [])
                    }'
            )"
            append_scenario_summary "$item"
            continue
        fi
        if [[ ! -f "$result_path" ]]; then
            item="$(
                jq -n \
                    --slurpfile scenario "$scenario_manifest" \
                    --arg manifestPath "$scenario_manifest" \
                    --arg resultPath "$result_path" \
                    --arg status "setup-failed" \
                    --arg failureSummary "scenario result missing" \
                    '{
                      name: $scenario[0].name,
                      id: $scenario[0].id,
                      manifestPath: $manifestPath,
                      resultPath: $resultPath,
                      status: $status,
                      failureSummary: $failureSummary,
                      nodes: ($scenario[0].nodes // []),
                      fixtures: ($scenario[0].fixtures // [])
                    }'
            )"
            append_scenario_summary "$item"
            continue
        fi
        if ! jq -e . "$result_path" >/dev/null 2>&1; then
            item="$(
                jq -n \
                    --slurpfile scenario "$scenario_manifest" \
                    --arg manifestPath "$scenario_manifest" \
                    --arg resultPath "$result_path" \
                    --arg status "setup-failed" \
                    --arg failureSummary "scenario result is invalid JSON" \
                    '{
                      name: $scenario[0].name,
                      id: $scenario[0].id,
                      manifestPath: $manifestPath,
                      resultPath: $resultPath,
                      status: $status,
                      failureSummary: $failureSummary,
                      nodes: ($scenario[0].nodes // []),
                      fixtures: ($scenario[0].fixtures // [])
                    }'
            )"
            append_scenario_summary "$item"
            continue
        fi
        status="$(scenario_status_from_result "$result_path")"
        failure="$(jq -r '.failureSummary // empty' "$result_path")"
        if jq -e --slurpfile scenario "$scenario_manifest" '
            (.scenarioName // "") != "" and (.scenarioName != $scenario[0].name)
          ' "$result_path" >/dev/null; then
            status="setup-failed"
            failure="scenario result is stale"
        elif jq -e --arg runID "$run_id" '
            (.runId // "") != "" and (.runId != $runID)
          ' "$result_path" >/dev/null; then
            status="setup-failed"
            failure="scenario result is from another run"
        elif [[ "$status" == "setup-failed" && -z "$failure" ]]; then
            failure="scenario did not complete successfully"
        fi
        item="$(
            jq -n \
                --slurpfile scenario "$scenario_manifest" \
                --slurpfile result "$result_path" \
                --arg manifestPath "$scenario_manifest" \
                --arg resultPath "$result_path" \
                --arg status "$status" \
                --arg failureSummary "$failure" \
                '{
                  name: $scenario[0].name,
                  id: $scenario[0].id,
                  manifestPath: $manifestPath,
                  resultPath: $resultPath,
                  status: $status,
                  runDir: ($result[0].runDir // $scenario[0].dir),
                  failureSummary: $failureSummary,
                  nodes: ($scenario[0].nodes // $result[0].nodes // []),
                  fixtures: ($scenario[0].fixtures // []),
                  missing: ($result[0].missing // [])
                } | if .failureSummary == "" then del(.failureSummary) else . end'
        )"
        append_scenario_summary "$item"
    done < <(find "$scenario_dir" -type f -name scenario.json -print0 | sort -z)
}

write_summary() {
    local status="$1"
    local exit_code="$2"
    shift 2
    write_selected_packages "$@"
    write_setup_failures
    collect_scenario_summaries
    jq -n \
        --arg runID "$run_id" \
        --arg runDir "$run_dir" \
        --arg worldManifest "$world_manifest" \
        --arg hostCapabilities "$host_capabilities_json" \
        --arg goTestLog "$go_test_log" \
        --arg requestedStatus "$status" \
        --argjson exitCode "$exit_code" \
        --slurpfile host "$host_capabilities_json" \
        --slurpfile packages "$selected_packages_json" \
        --slurpfile setupFailures "$setup_failures_json" \
        --slurpfile scenarios "$scenario_summary_json" \
        --args \
        '{
          apiVersion: "katl.dev/v1alpha1",
          kind: "VMTestRunSummary",
          runID: $runID,
          runDir: $runDir,
          worldManifest: $worldManifest,
          hostCapabilities: $hostCapabilities,
          goTestLog: $goTestLog,
          status: (
            if $requestedStatus == "host-skipped" then "host-skipped"
            elif $requestedStatus == "setup-failed" then "setup-failed"
            elif $exitCode != 0 then "failed"
            elif any($scenarios[0][]; .status == "failed" or .status == "setup-failed") then "failed"
            else "passed"
            end
          ),
          exitCode: (
            if $requestedStatus == "host-skipped" then 0
            elif $requestedStatus == "setup-failed" then $exitCode
            elif $exitCode != 0 then $exitCode
            elif any($scenarios[0][]; .status == "failed" or .status == "setup-failed") then 1
            else 0
            end
          ),
          childExitCode: $exitCode,
          args: $ARGS.positional,
          selectedPackages: $packages[0],
          hostCapabilityGaps: ($host[0].missing // []),
          setupFailures: $setupFailures[0],
          counts: (reduce $scenarios[0][] as $scenario ({}; .[$scenario.status] += 1)),
          scenarios: $scenarios[0]
        }' -- "$@" >"$summary_json"
}

cleanup_network() {
    local exit_code=$?
    if [[ "$bridge_created" == 1 ]]; then
        case "$keep_policy:$final_status" in
            always:*)
                ;;
            failed:failed|failed:setup-failed)
                ;;
            *)
                "$ip_bin" link del "$network_bridge" >/dev/null 2>&1 || true
                ;;
        esac
    fi
    exit "$exit_code"
}

filter_count_args() {
    filtered_args=()
    filtered_has_package_arg=0
    filtered_has_non_suite_package_arg=0
    filtered_has_selection_arg=0
    local expect_flag_value=0
    while [[ $# -gt 0 ]]; do
        if [[ "$expect_flag_value" == 1 ]]; then
            filtered_args+=("$1")
            expect_flag_value=0
            shift
            continue
        fi
        case "$1" in
            -h|--help)
                usage
                exit 0
                ;;
            -count=*)
                shift
                ;;
            -count)
                shift
                if [[ $# -gt 0 ]]; then
                    shift
                fi
                ;;
            -args)
                if [[ "$filtered_has_package_arg" == 0 ]]; then
                    filtered_args+=("./...")
                fi
                filtered_args+=("$@")
                return
                ;;
            -run|-bench|-list|-skip)
                filtered_has_selection_arg=1
                filtered_args+=("$1")
                expect_flag_value=1
                shift
                ;;
            -run=*|-bench=*|-list=*|-skip=*)
                filtered_has_selection_arg=1
                filtered_args+=("$1")
                shift
                ;;
            -timeout|-benchtime|-cpu|-parallel|-shuffle|-coverprofile|-covermode|-coverpkg|-outputdir)
                filtered_args+=("$1")
                expect_flag_value=1
                shift
                ;;
            -*)
                filtered_args+=("$1")
                shift
                ;;
            *)
                filtered_has_package_arg=1
                if [[ "$1" != "./..." ]]; then
                    filtered_has_non_suite_package_arg=1
                fi
                filtered_args+=("$1")
                shift
                ;;
        esac
    done
    if [[ "$filtered_has_package_arg" == 0 ]]; then
        filtered_args+=("./...")
    fi
}

select_capability_scope() {
    if is_nspawn_only_selection "$@"; then
        capability_scope="nspawn"
    else
        capability_scope="full"
    fi
}

is_nspawn_only_selection() {
    local has_internal_vmtest_package=0
    local has_nspawn_selection=0
    local expect_selection_value=0
    local expect_ignored_value=0
    local arg value
    while [[ $# -gt 0 ]]; do
        arg="$1"
        if [[ "$expect_ignored_value" == 1 ]]; then
            expect_ignored_value=0
            shift
            continue
        fi
        if [[ "$expect_selection_value" == 1 ]]; then
            value="$arg"
            if [[ "$value" == *Nspawn* || "$value" == *nspawn* ]]; then
                has_nspawn_selection=1
            fi
            expect_selection_value=0
            shift
            continue
        fi
        case "$arg" in
            -run|-list)
                expect_selection_value=1
                ;;
            -run=*|-list=*)
                value="${arg#*=}"
                if [[ "$value" == *Nspawn* || "$value" == *nspawn* ]]; then
                    has_nspawn_selection=1
                fi
                ;;
            -bench|-skip)
                expect_ignored_value=1
                ;;
            -bench=*|-skip=*)
                ;;
            -timeout|-benchtime|-cpu|-parallel|-shuffle|-coverprofile|-covermode|-coverpkg|-outputdir)
                expect_ignored_value=1
                ;;
            -*)
                ;;
            ./internal/vmtest|github.com/zariel/katl/internal/vmtest)
                has_internal_vmtest_package=1
                ;;
            *)
                return 1
                ;;
        esac
        shift
    done
    [[ "$has_internal_vmtest_package" == 1 && "$has_nspawn_selection" == 1 ]]
}

filtered_args=()
if [[ $# -eq 0 ]]; then
    filtered_args=("./...")
    preflight_required=1
else
    filter_count_args "$@"
    if [[ "$filtered_has_non_suite_package_arg" == 1 || "$filtered_has_selection_arg" == 1 ]]; then
        preflight_required=0
    else
        preflight_required=1
    fi
fi
select_capability_scope "${filtered_args[@]}"

need jq
mkdir -p "$artifact_dir" "$scenario_dir" "$network_dir"
jq -n '{}' >"$lease_file"
write_host_capabilities
trap cleanup_network EXIT
if [[ "$capability_scope" != "nspawn" ]]; then
    validate_network
fi
if [[ "${#setup_failures[@]}" -gt 0 ]]; then
    printf 'setup failed: %s\n' "${setup_failures[@]}" >&2
    write_summary "setup-failed" 2 "${filtered_args[@]}"
    exit 2
fi
probe_capabilities
if [[ "$capability_scope" != "nspawn" ]]; then
    setup_network
fi
write_host_capabilities
write_world

if [[ "${#missing_capabilities[@]}" -gt 0 ]]; then
    if [[ "$host_policy" == "skip" ]]; then
        final_status="host-skipped"
        print_missing_capabilities "host-skipped: missing host capabilities"
        write_summary "$final_status" 0 "${filtered_args[@]}"
        exit 0
    fi
    if [[ "$preflight_required" == 1 || "$capability_scope" == "nspawn" ]]; then
        final_status="setup-failed"
        print_missing_capabilities "setup failed: missing required host capabilities"
        write_summary "$final_status" 1 "${filtered_args[@]}"
        exit 1
    fi
fi

export KATL_VMTEST_RUN_DIR="$run_dir"
export KATL_VMTEST_WORLD_MANIFEST="$world_manifest"
export KATL_VMTEST_BRIDGE="$network_bridge"

set +e
"$go_bin" test -count=1 -exec "$repo_root/scripts/vmtest-exec" "${filtered_args[@]}" 2>&1 | tee "$go_test_log"
exit_code=${PIPESTATUS[0]}
set -e

status="passed"
if [[ "$exit_code" -ne 0 ]]; then
    status="failed"
    echo "vmtest run dir: $run_dir" >&2
fi
final_status="$status"
write_summary "$status" "$exit_code" "${filtered_args[@]}"
final_status="$(jq -r '.status' "$summary_json")"
exit_code="$(jq -r '.exitCode' "$summary_json")"

exit "$exit_code"
