#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
go_bin="${KATL_VMTEST_GO:-go}"
image_tool="${KATL_VMTEST_IMAGE_TOOL:-qemu-img}"
virsh_bin="${KATL_VMTEST_VIRSH:-virsh}"
kubectl_bin="${KATL_VMTEST_KUBECTL:-kubectl}"
go_test_timeout="90m"
tmp_parent="${TMPDIR:-/tmp}/katl-vmtest"
run_id="${KATL_VMTEST_RUN_ID:-$(date -u +%Y%m%dT%H%M%SZ)-$$}"
run_dir="${KATL_VMTEST_RUN_DIR:-$tmp_parent/$run_id}"
artifact_dir="$run_dir/artifacts"
scenario_dir="$run_dir/scenarios"
network_dir="$run_dir/network"
world_manifest="$run_dir/world.json"
host_capabilities_json="$run_dir/host-capabilities.json"
run_index="$run_dir/run.json"
lease_file="$network_dir/leases.json"
libvirt_uri="${KATL_VMTEST_LIBVIRT_URI:-qemu:///system}"
libvirt_network="${KATL_VMTEST_LIBVIRT_NETWORK:-default}"
libvirt_storage_pool="${KATL_VMTEST_LIBVIRT_STORAGE_POOL:-default}"
libvirt_storage_path="${KATL_VMTEST_LIBVIRT_STORAGE_PATH:-/var/lib/libvirt/images}"
libvirt_domain_prefix="${KATL_VMTEST_LIBVIRT_DOMAIN_PREFIX:-katl-${run_id}}"
network_cidr="${KATL_VMTEST_CIDR:-10.77.0.0/24}"
network_gateway="${KATL_VMTEST_GATEWAY:-10.77.0.1}"
ovmf_code="${KATL_OVMF_CODE:-}"
ovmf_vars="${KATL_OVMF_VARS:-}"
kvm_device="${KATL_VMTEST_KVM_DEVICE:-/dev/kvm}"
vsock_device="${KATL_VMTEST_VSOCK_DEVICE:-/dev/vhost-vsock}"
network_prefix=""
final_status="setup-failed"
cap_image_tool="disabled"
cap_libvirt="disabled"
cap_libvirt_network="disabled"
cap_libvirt_storage_pool="disabled"
cap_ovmf="disabled"
cap_kvm="disabled"
cap_vsock="disabled"
cap_mtools="disabled"
cap_sfdisk="disabled"
cap_sha256sum="disabled"
cap_awk="disabled"
cap_realpath="disabled"
cap_systemd_nspawn="disabled"
cap_kubectl="disabled"
nspawn_checks="${KATL_VMTEST_NSPAWN:-1}"
require_scenario_result="${KATL_VMTEST_REQUIRE_SCENARIO_RESULT:-1}"
missing_capabilities=()
setup_failures=()

need() {
    command -v "$1" >/dev/null 2>&1 || {
        echo "error: $1 is required" >&2
        exit 1
    }
}

missing_status() {
    if [[ "$1" == "passed" ]]; then
        printf "passed"
    else
        printf "failed"
    fi
}

have_command() {
    command -v "$1" >/dev/null 2>&1
}

capability_hint() {
    case "$1" in
        image-tool)
            printf "install qemu-img or set KATL_VMTEST_IMAGE_TOOL to an image tool compatible with qemu-img"
            ;;
        libvirt)
            printf "install libvirt client tools and ensure %s can connect to %s" "$virsh_bin" "$libvirt_uri"
            ;;
        libvirt-network)
            printf "define and start libvirt network %s on %s, or set KATL_VMTEST_LIBVIRT_NETWORK" "$libvirt_network" "$libvirt_uri"
            ;;
        libvirt-storage-pool)
            printf "define and start libvirt storage pool %s on %s, or set KATL_VMTEST_LIBVIRT_STORAGE_POOL" "$libvirt_storage_pool" "$libvirt_uri"
            ;;
        ovmf)
            printf "set KATL_OVMF_CODE and KATL_OVMF_VARS to readable OVMF pflash images"
            ;;
        kvm)
            printf "%s is missing; enable KVM support or set KATL_VMTEST_KVM_DEVICE" "$kvm_device"
            ;;
        vsock)
            printf "%s is missing; load vhost_vsock or set KATL_VMTEST_VSOCK_DEVICE" "$vsock_device"
            ;;
        mtools)
            printf "install mtools and coreutils so mformat, mcopy, and truncate are available"
            ;;
        sfdisk)
            printf "install util-linux so sfdisk is available"
            ;;
        sha256sum)
            printf "install coreutils so sha256sum is available"
            ;;
        awk)
            printf "install awk, such as gawk"
            ;;
        realpath)
            printf "install coreutils so realpath is available"
            ;;
        kubectl)
            printf "install kubectl or set KATL_VMTEST_KUBECTL to the kubectl binary"
            ;;
        systemd-nspawn)
            printf "install systemd-nspawn"
            ;;
        nspawn-privileges)
            printf "systemd-nspawn is installed, but this run is not privileged; run with sudo or set KATL_NSPAWN_ALLOW_UNPRIVILEGED=1 after configuring rootless systemd-nspawn"
            ;;
        *)
            printf "see %s for recorded host capability state" "$host_capabilities_json"
            ;;
    esac
}

print_missing_capabilities() {
    local heading="$1"
    local printed=""
    local capability hint
    printf '%s\n' "$heading" >&2
    for capability in "${missing_capabilities[@]}"; do
        case " $printed " in
            *" $capability "*)
                continue
                ;;
        esac
        printed="${printed:+$printed }$capability"
        hint="$(capability_hint "$capability")"
        printf '  - %s: %s\n' "$capability" "$hint" >&2
    done
    printf 'vmtest run dir: %s\n' "$run_dir" >&2
}

has_go_test_timeout() {
    local arg
    while (($# > 0)); do
        arg="$1"
        case "$arg" in
            -args)
                return 1
                ;;
            -timeout | --timeout | -test.timeout | --test.timeout)
                return 0
                ;;
            -timeout=* | --timeout=* | -test.timeout=* | --test.timeout=*)
                return 0
                ;;
        esac
        shift
    done
    return 1
}

has_explicit_artifact_index() {
    [[ -n "${KATL_MKOSI_ARTIFACT_INDEX:-}" ]]
}

has_explicit_installer_artifact() {
    [[ -n "${KATL_INSTALLER_UKI:-}" || -n "${KATL_INSTALLER_KERNEL:-}" || -n "${KATL_INSTALLER_INITRD:-}" ]]
}

has_explicit_runtime_artifact() {
    [[ -n "${KATL_RUNTIME_ARTIFACT:-}" ]]
}

has_explicit_install_manifest() {
    [[ -n "${KATL_INSTALL_MANIFEST:-}" ]]
}

build_default_artifacts() {
    if has_explicit_artifact_index; then
        return 0
    fi

    local -a targets=()
    if ! has_explicit_installer_artifact; then
        targets+=("build-installer")
    fi
    if ! has_explicit_install_manifest; then
        targets+=("build-katlos-install-image")
    elif ! has_explicit_runtime_artifact; then
        targets+=("build-runtime")
    fi
    if [[ "${#targets[@]}" -eq 0 ]]; then
        return 0
    fi

    local target
    for target in "${targets[@]}"; do
        printf 'vmtest building current repo artifact: scripts/mkosi %s\n' "$target" >&2
        if ! "$repo_root/scripts/mkosi" "$target"; then
            setup_failures+=("build default vmtest artifact with scripts/mkosi $target failed")
            return 1
        fi
    done
}

probe_vm_capabilities() {
    if have_command "$image_tool"; then
        cap_image_tool="passed"
    else
        missing_capabilities+=("image-tool")
        cap_image_tool="$(missing_status missing)"
    fi

    if have_command "$virsh_bin" && "$virsh_bin" -c "$libvirt_uri" uri >/dev/null 2>&1; then
        cap_libvirt="passed"
    else
        missing_capabilities+=("libvirt")
        cap_libvirt="$(missing_status missing)"
    fi

    if [[ "$cap_libvirt" == "passed" ]]; then
        local network_info=""
        if network_info="$("$virsh_bin" -c "$libvirt_uri" net-info "$libvirt_network" 2>/dev/null)" &&
            grep -Eq '^Active:[[:space:]]+yes' <<<"$network_info" &&
            discover_libvirt_network; then
            cap_libvirt_network="passed"
        else
            missing_capabilities+=("libvirt-network")
            cap_libvirt_network="$(missing_status missing)"
        fi

        local pool_info=""
        if pool_info="$("$virsh_bin" -c "$libvirt_uri" pool-info "$libvirt_storage_pool" 2>/dev/null)" &&
            grep -Eq '^State:[[:space:]]+running' <<<"$pool_info"; then
            cap_libvirt_storage_pool="passed"
            local pool_xml=""
            if pool_xml="$("$virsh_bin" -c "$libvirt_uri" pool-dumpxml "$libvirt_storage_pool" 2>/dev/null)"; then
                local discovered_path=""
                discovered_path="$(sed -n 's:.*<path>\(.*\)</path>.*:\1:p' <<<"$pool_xml" | head -n 1)"
                if [[ -n "$discovered_path" ]]; then
                    libvirt_storage_path="$discovered_path"
                fi
            fi
        else
            missing_capabilities+=("libvirt-storage-pool")
            cap_libvirt_storage_pool="$(missing_status missing)"
        fi
    fi

    if [[ -n "$ovmf_code" && -e "$ovmf_code" && -n "$ovmf_vars" && -e "$ovmf_vars" ]]; then
        cap_ovmf="passed"
    else
        missing_capabilities+=("ovmf")
        cap_ovmf="$(missing_status missing)"
    fi
    if [[ -n "$kvm_device" && -e "$kvm_device" ]]; then
        cap_kvm="passed"
    else
        missing_capabilities+=("kvm")
        cap_kvm="$(missing_status missing)"
    fi
    if [[ -n "$vsock_device" && -e "$vsock_device" ]]; then
        cap_vsock="passed"
    else
        missing_capabilities+=("vsock")
        cap_vsock="$(missing_status missing)"
    fi
}

probe_fixture_tool_capabilities() {
    if have_command mformat && have_command mcopy && have_command truncate; then
        cap_mtools="passed"
    else
        missing_capabilities+=("mtools")
        cap_mtools="$(missing_status missing)"
    fi
    if have_command sfdisk; then
        cap_sfdisk="passed"
    else
        missing_capabilities+=("sfdisk")
        cap_sfdisk="$(missing_status missing)"
    fi
    if have_command sha256sum; then
        cap_sha256sum="passed"
    else
        missing_capabilities+=("sha256sum")
        cap_sha256sum="$(missing_status missing)"
    fi
    if have_command awk; then
        cap_awk="passed"
    else
        missing_capabilities+=("awk")
        cap_awk="$(missing_status missing)"
    fi
    if have_command realpath; then
        cap_realpath="passed"
    else
        missing_capabilities+=("realpath")
        cap_realpath="$(missing_status missing)"
    fi
    if have_command "$kubectl_bin"; then
        cap_kubectl="passed"
    else
        missing_capabilities+=("kubectl")
        cap_kubectl="$(missing_status missing)"
    fi
}

probe_nspawn_capabilities() {
    if [[ "$nspawn_checks" == 0 || "$nspawn_checks" == false || "$nspawn_checks" == disabled ]]; then
        cap_systemd_nspawn="disabled"
        return
    fi
    if have_command systemd-nspawn; then
        if [[ "${EUID:-$(id -u)}" == 0 || "${KATL_NSPAWN_ALLOW_UNPRIVILEGED:-}" == 1 || "${KATL_NSPAWN_ALLOW_UNPRIVILEGED:-}" == true ]]; then
            cap_systemd_nspawn="passed"
        else
            missing_capabilities+=("nspawn-privileges")
            cap_systemd_nspawn="$(missing_status missing)"
        fi
    else
        missing_capabilities+=("systemd-nspawn")
        cap_systemd_nspawn="$(missing_status missing)"
    fi
}

probe_capabilities() {
    probe_vm_capabilities
    probe_fixture_tool_capabilities
    probe_nspawn_capabilities
}

ipv4_to_int() {
    local address="$1"
    local a b c d extra
    IFS=. read -r a b c d extra <<<"$address"
    if [[ -n "${extra:-}" || -z "${a:-}" || -z "${b:-}" || -z "${c:-}" || -z "${d:-}" ]]; then
        return 1
    fi
    local octet
    for octet in "$a" "$b" "$c" "$d"; do
        if ! [[ "$octet" =~ ^[0-9]+$ ]] || ((octet < 0 || octet > 255)); then
            return 1
        fi
    done
    printf "%u" "$(((a << 24) + (b << 16) + (c << 8) + d))"
}

int_to_ipv4() {
    local value="$1"
    printf "%u.%u.%u.%u" "$(((value >> 24) & 255))" "$(((value >> 16) & 255))" "$(((value >> 8) & 255))" "$((value & 255))"
}

netmask_to_prefix() {
    local mask="$1"
    local mask_int
    if ! mask_int="$(ipv4_to_int "$mask")"; then
        return 1
    fi
    local prefix=0
    local seen_zero=0
    local bit
    for ((bit = 31; bit >= 0; bit--)); do
        if (((mask_int & (1 << bit)) != 0)); then
            if [[ "$seen_zero" == 1 ]]; then
                return 1
            fi
            prefix=$((prefix + 1))
        else
            seen_zero=1
        fi
    done
    printf "%u" "$prefix"
}

network_cidr_from_gateway() {
    local gateway="$1"
    local prefix="$2"
    local gateway_int mask network_int
    if ! gateway_int="$(ipv4_to_int "$gateway")"; then
        return 1
    fi
    if ! [[ "$prefix" =~ ^[0-9]+$ ]] || ((prefix < 0 || prefix > 32)); then
        return 1
    fi
    if ((prefix == 0)); then
        mask=0
    else
        mask=$(((0xffffffff << (32 - prefix)) & 0xffffffff))
    fi
    network_int=$((gateway_int & mask))
    printf "%s/%u" "$(int_to_ipv4 "$network_int")" "$prefix"
}

discover_libvirt_network() {
    local network_xml gateway prefix netmask cidr
    if ! network_xml="$("$virsh_bin" -c "$libvirt_uri" net-dumpxml "$libvirt_network" 2>/dev/null)"; then
        return 1
    fi
    gateway="$(sed -n "s/.*<ip[^>]* address=['\"]\([^'\"]*\)['\"][^>]*>.*/\1/p" <<<"$network_xml" | head -n 1)"
    prefix="$(sed -n "s/.*<ip[^>]* prefix=['\"]\([0-9][0-9]*\)['\"][^>]*>.*/\1/p" <<<"$network_xml" | head -n 1)"
    if [[ -z "$prefix" ]]; then
        netmask="$(sed -n "s/.*<ip[^>]* netmask=['\"]\([^'\"]*\)['\"][^>]*>.*/\1/p" <<<"$network_xml" | head -n 1)"
        if [[ -n "$netmask" ]]; then
            prefix="$(netmask_to_prefix "$netmask")"
        fi
    fi
    if [[ -z "$gateway" || -z "$prefix" ]]; then
        return 1
    fi
    if ! cidr="$(network_cidr_from_gateway "$gateway" "$prefix")"; then
        return 1
    fi
    network_gateway="$gateway"
    network_cidr="$cidr"
}

validate_network() {
    if [[ ! "$network_cidr" =~ ^([^/]+)/([0-9]{1,2})$ ]]; then
        setup_failures+=("invalid CIDR: $network_cidr")
        return
    fi
    local network_address="${BASH_REMATCH[1]}"
    network_prefix="${BASH_REMATCH[2]}"
    if ((network_prefix < 0 || network_prefix > 32)); then
        setup_failures+=("invalid CIDR prefix: $network_cidr")
        return
    fi
    local network_int gateway_int mask
    if ! network_int="$(ipv4_to_int "$network_address")"; then
        setup_failures+=("invalid CIDR address: $network_cidr")
        return
    fi
    if ! gateway_int="$(ipv4_to_int "$network_gateway")"; then
        setup_failures+=("invalid gateway: $network_gateway")
        return
    fi
    if ((network_prefix == 0)); then
        mask=0
    else
        mask=$(((0xffffffff << (32 - network_prefix)) & 0xffffffff))
    fi
    if (((network_int & mask) != (gateway_int & mask))); then
        setup_failures+=("gateway $network_gateway is outside CIDR $network_cidr")
    fi
}

write_host_capabilities() {
    jq -n \
        --arg imageTool "$cap_image_tool" \
        --arg libvirt "$cap_libvirt" \
        --arg libvirtNetwork "$cap_libvirt_network" \
        --arg libvirtStoragePool "$cap_libvirt_storage_pool" \
        --arg ovmf "$cap_ovmf" \
        --arg kvm "$cap_kvm" \
        --arg vsock "$cap_vsock" \
        --arg mtools "$cap_mtools" \
        --arg sfdisk "$cap_sfdisk" \
        --arg sha256sum "$cap_sha256sum" \
        --arg awk "$cap_awk" \
        --arg realpath "$cap_realpath" \
        --arg systemdNspawn "$cap_systemd_nspawn" \
        --arg kubectl "$cap_kubectl" \
        --args \
        '{
          apiVersion: "katl.dev/v1alpha1",
          kind: "VMTestHostCapabilities",
          capabilities: {
            "image-tool": $imageTool,
            libvirt: $libvirt,
            "libvirt-network": $libvirtNetwork,
            "libvirt-storage-pool": $libvirtStoragePool,
            ovmf: $ovmf,
            kvm: $kvm,
            vsock: $vsock,
            mtools: $mtools,
            sfdisk: $sfdisk,
            sha256sum: $sha256sum,
            awk: $awk,
            realpath: $realpath,
            kubectl: $kubectl,
            "systemd-nspawn": $systemdNspawn
          },
          missing: $ARGS.positional
        }' -- "${missing_capabilities[@]}" >"$host_capabilities_json"
}

write_world() {
    jq -n \
        --arg runID "$run_id" \
        --arg runDir "$run_dir" \
        --arg artifactDir "$artifact_dir" \
        --arg scenarioDir "$scenario_dir" \
        --arg runIndex "$run_index" \
        --arg libvirtURI "$libvirt_uri" \
        --arg libvirtNetwork "$libvirt_network" \
        --arg libvirtStoragePool "$libvirt_storage_pool" \
        --arg libvirtStoragePath "$libvirt_storage_path" \
        --arg libvirtDomainPrefix "$libvirt_domain_prefix" \
        --arg cidr "$network_cidr" \
        --arg gateway "$network_gateway" \
        --arg leaseFile "$lease_file" \
        --arg imageTool "$cap_image_tool" \
        --arg libvirt "$cap_libvirt" \
        --arg libvirtNetworkStatus "$cap_libvirt_network" \
        --arg libvirtStoragePoolStatus "$cap_libvirt_storage_pool" \
        --arg ovmf "$cap_ovmf" \
        --arg kvm "$cap_kvm" \
        --arg vsock "$cap_vsock" \
        --arg mtools "$cap_mtools" \
        --arg sfdisk "$cap_sfdisk" \
        --arg sha256sum "$cap_sha256sum" \
        --arg awk "$cap_awk" \
        --arg realpath "$cap_realpath" \
        --arg systemdNspawn "$cap_systemd_nspawn" \
        --arg kubectl "$cap_kubectl" \
        '{
          apiVersion: "katl.dev/v1alpha1",
          kind: "VMTestWorld",
          runID: $runID,
          runDir: $runDir,
          artifactDir: $artifactDir,
          scenarioDir: $scenarioDir,
          runIndex: $runIndex,
          libvirt: {
            uri: $libvirtURI,
            network: $libvirtNetwork,
            storagePool: $libvirtStoragePool,
            storagePath: $libvirtStoragePath,
            domainPrefix: $libvirtDomainPrefix
          },
          network: {
            backend: "libvirt",
            name: $libvirtNetwork,
            cidr: $cidr,
            gateway: $gateway,
            leaseFile: $leaseFile
          },
          capabilities: {
            "image-tool": $imageTool,
            libvirt: $libvirt,
            "libvirt-network": $libvirtNetworkStatus,
            "libvirt-storage-pool": $libvirtStoragePoolStatus,
            ovmf: $ovmf,
            kvm: $kvm,
            mtools: $mtools,
            sfdisk: $sfdisk,
            sha256sum: $sha256sum,
            awk: $awk,
            realpath: $realpath,
            kubectl: $kubectl,
            vsock: $vsock,
            "systemd-nspawn": $systemdNspawn
          }
        }' >"$world_manifest"
}

write_run_index() {
    local status="$1"
    shift
    local setup_failure_text=""
    local missing_capabilities_json
    if [[ "${#setup_failures[@]}" -gt 0 ]]; then
        setup_failure_text="$(printf '%s\n' "${setup_failures[@]}")"
    fi
    missing_capabilities_json="$(jq -n '$ARGS.positional' --args -- "${missing_capabilities[@]}")"
    jq -n \
        --arg runID "$run_id" \
        --arg runDir "$run_dir" \
        --arg artifactDir "$artifact_dir" \
        --arg scenarioDir "$scenario_dir" \
        --arg worldManifest "$world_manifest" \
        --arg hostCapabilities "$host_capabilities_json" \
        --arg leaseFile "$lease_file" \
        --arg status "$status" \
        --arg setupFailures "$setup_failure_text" \
        --argjson missingCapabilities "$missing_capabilities_json" \
        --args \
        '{
          apiVersion: "katl.dev/v1alpha1",
          kind: "VMTestRun",
          runID: $runID,
          runDir: $runDir,
          artifactDir: $artifactDir,
          scenarioDir: $scenarioDir,
          worldManifest: $worldManifest,
          hostCapabilities: $hostCapabilities,
          networkLeaseFile: $leaseFile,
          status: $status,
          missingCapabilities: $missingCapabilities,
          goTestArgs: $ARGS.positional,
          setupFailures: ($setupFailures | split("\n") | map(select(length > 0)))
        }' -- "$@" >"$run_index"
}

need jq
mkdir -p "$artifact_dir" "$scenario_dir" "$network_dir"
jq -n '{}' >"$lease_file"
write_host_capabilities
write_run_index "setup" "$@"
validate_network
if [[ "${#setup_failures[@]}" -gt 0 ]]; then
    write_run_index "setup-failed" "$@"
    printf 'setup failed: %s\n' "${setup_failures[@]}" >&2
    exit 2
fi
write_run_index "building-artifacts" "$@"
if ! build_default_artifacts; then
    write_run_index "setup-failed" "$@"
    printf 'setup failed: %s\n' "${setup_failures[@]}" >&2
    exit 2
fi
probe_capabilities
write_host_capabilities
write_world
if [[ "${#missing_capabilities[@]}" -gt 0 ]]; then
    print_missing_capabilities "vmtest world has missing host capabilities"
fi

export KATL_VMTEST_RUN_DIR="$run_dir"
export KATL_VMTEST_WORLD_MANIFEST="$world_manifest"
export KATL_VMTEST_LIBVIRT_URI="$libvirt_uri"
export KATL_VMTEST_LIBVIRT_NETWORK="$libvirt_network"
export KATL_VMTEST_LIBVIRT_STORAGE_POOL="$libvirt_storage_pool"
export KATL_VMTEST_LIBVIRT_STORAGE_PATH="$libvirt_storage_path"
export KATL_VMTEST_LIBVIRT_DOMAIN_PREFIX="$libvirt_domain_prefix"

final_status="go-test"
write_run_index "$final_status" "$@"
printf 'vmtest run dir: %s\n' "$run_dir" >&2
go_test_args=()
if [[ -n "$go_test_timeout" ]] && ! has_go_test_timeout "$@"; then
    go_test_args+=("-timeout" "$go_test_timeout")
fi
set +e
"$go_bin" test -exec "$repo_root/scripts/vmtest-exec" "${go_test_args[@]}" "$@"
exit_code=$?
set -e
if [[ "$exit_code" -eq 0 && ( "$require_scenario_result" == 1 || "$require_scenario_result" == true ) ]]; then
    if ! find "$scenario_dir" -mindepth 2 -maxdepth 4 -name result.json -print -quit | grep -q .; then
        write_run_index "no-scenario-result" "$@"
        printf 'vmtest did not execute any world scenario; no result.json found under %s\n' "$scenario_dir" >&2
        printf 'vmtest run dir: %s\n' "$run_dir" >&2
        exit 3
    fi
fi
exit "$exit_code"
