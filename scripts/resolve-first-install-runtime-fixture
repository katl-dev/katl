#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
run_id="${KATL_FIRST_INSTALL_FIXTURE_RUN_ID:-$(date -u +%Y%m%dT%H%M%SZ)-$$}"
state_root="${KATL_FIRST_INSTALL_FIXTURE_STATE_ROOT:-$repo_root/build/first-install-runtime-fixture}"
state_dir="${KATL_FIRST_INSTALL_FIXTURE_STATE_DIR:-$state_root/$run_id}"
env_file="${KATL_FIRST_INSTALL_FIXTURE_ENV:-$state_dir/vmtest.env}"
run_script="$state_dir/run-first-install-target-disk-fixture.sh"
manifest="$state_dir/fixture.json"

installer_uki="${KATL_INSTALLER_UKI:-}"
runtime_artifact="${KATL_RUNTIME_ARTIFACT:-}"
runtime_esp="${KATL_RUNTIME_ESP_ARTIFACTS:-${KATL_INSTALLED_ESP_ARTIFACTS:-}}"
node_metadata="${KATL_RUNTIME_NODE_METADATA:-${KATL_INSTALLED_NODE_METADATA:-}}"
install_manifest="${KATL_INSTALL_MANIFEST:-}"
use_installed_esp="${KATL_FIRST_INSTALL_USE_INSTALLED_ESP:-0}"
installer_uki_sha256="${KATL_FIRST_INSTALL_INSTALLER_UKI_SHA256:-}"
runtime_artifact_sha256="${KATL_FIRST_INSTALL_RUNTIME_ARTIFACT_SHA256:-}"
install_manifest_sha256="${KATL_FIRST_INSTALL_MANIFEST_SHA256:-}"
node_metadata_sha256="${KATL_FIRST_INSTALL_NODE_METADATA_SHA256:-}"
target_disk_size="${KATL_FIRST_INSTALL_TARGET_DISK_SIZE:-20G}"
vmtest_keep="${KATL_VMTEST_KEEP:-always}"
vmtest_state_root="${KATL_VMTEST_STATE_ROOT:-$state_dir/vm-runs}"
env_file_set=0
check_only=0

usage() {
    cat <<'USAGE'
Usage: scripts/resolve-first-install-runtime-fixture [options]

Resolve and preflight the inputs needed by the opt-in first-install target-disk
fixture contract smoke. The command does not build artifacts or run QEMU; it
validates existing installer/runtime inputs, writes a sourceable env file, and
generates a wrapper for TestFirstInstallTargetDiskFixtureContract.

Options:
  --installer-uki PATH       Installer UKI, or KATL_INSTALLER_UKI
  --runtime-artifact PATH    Runtime root artifact, or KATL_RUNTIME_ARTIFACT
  --runtime-esp DIR          Rendered runtime ESP tree, or KATL_RUNTIME_ESP_ARTIFACTS
  --use-installed-esp        Extract and use the ESP written into the target disk
  --node-metadata PATH       Optional /etc/katl/node.json, or KATL_RUNTIME_NODE_METADATA
  --install-manifest PATH    Install manifest, or KATL_INSTALL_MANIFEST
  --installer-uki-sha256 H   Expected installer UKI SHA-256
  --runtime-artifact-sha256 H Expected runtime artifact SHA-256
  --install-manifest-sha256 H Expected install manifest SHA-256
  --node-metadata-sha256 H   Expected node metadata SHA-256
  --target-disk-size SIZE    Target disk size for the first install smoke (default: 20G)
  --state-dir DIR            Output directory for generated env, manifest, and wrapper
  --env-file PATH            Sourceable env output path (default: <state-dir>/vmtest.env)
  --check-only               Validate inputs without writing wrappers
  -h, --help                 Show this help

After this command succeeds:
  source <state-dir>/vmtest.env
  <state-dir>/run-first-install-target-disk-fixture.sh
USAGE
}

fail() {
    echo "error: $*" >&2
    exit 1
}

need_value() {
    local option="$1"
    local value="${2:-}"
    if [[ -z "$value" || "$value" == --* ]]; then
        fail "$option requires a value"
    fi
}

rel() {
    local path="$1"
    printf "%s" "${path#"$repo_root"/}"
}

real() {
    realpath -m "$1"
}

json() {
    local value="$1"
    value="${value//\\/\\\\}"
    value="${value//\"/\\\"}"
    value="${value//$'\n'/\\n}"
    printf "%s" "$value"
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --installer-uki)
            need_value "$1" "${2:-}"
            installer_uki="$2"
            shift 2
            ;;
        --runtime-artifact)
            need_value "$1" "${2:-}"
            runtime_artifact="$2"
            shift 2
            ;;
        --runtime-esp|--runtime-esp-artifacts|--esp-artifacts)
            need_value "$1" "${2:-}"
            runtime_esp="$2"
            shift 2
            ;;
        --use-installed-esp)
            use_installed_esp=1
            shift
            ;;
        --node-metadata)
            need_value "$1" "${2:-}"
            node_metadata="$2"
            shift 2
            ;;
        --install-manifest)
            need_value "$1" "${2:-}"
            install_manifest="$2"
            shift 2
            ;;
        --installer-uki-sha256)
            need_value "$1" "${2:-}"
            installer_uki_sha256="$2"
            shift 2
            ;;
        --runtime-artifact-sha256)
            need_value "$1" "${2:-}"
            runtime_artifact_sha256="$2"
            shift 2
            ;;
        --install-manifest-sha256)
            need_value "$1" "${2:-}"
            install_manifest_sha256="$2"
            shift 2
            ;;
        --node-metadata-sha256)
            need_value "$1" "${2:-}"
            node_metadata_sha256="$2"
            shift 2
            ;;
        --target-disk-size)
            need_value "$1" "${2:-}"
            target_disk_size="$2"
            shift 2
            ;;
        --state-dir)
            need_value "$1" "${2:-}"
            state_dir="$2"
            if [[ "$env_file_set" -eq 0 ]]; then
                env_file="$state_dir/vmtest.env"
            fi
            run_script="$state_dir/run-first-install-target-disk-fixture.sh"
            manifest="$state_dir/fixture.json"
            vmtest_state_root="$state_dir/vm-runs"
            shift 2
            ;;
        --env-file)
            need_value "$1" "${2:-}"
            env_file="$2"
            env_file_set=1
            shift 2
            ;;
        --check-only)
            check_only=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            usage >&2
            fail "unknown argument: $1"
            ;;
    esac
done

[[ -n "$installer_uki" ]] || fail "--installer-uki is required"
[[ -f "$installer_uki" ]] || fail "installer UKI not found: $(rel "$installer_uki")"
[[ -n "$runtime_artifact" ]] || fail "--runtime-artifact is required"
[[ -f "$runtime_artifact" ]] || fail "runtime artifact not found: $(rel "$runtime_artifact")"
case "$use_installed_esp" in
    0|false|False|FALSE)
        use_installed_esp=0
        ;;
    1|true|True|TRUE)
        use_installed_esp=1
        ;;
    *)
        fail "KATL_FIRST_INSTALL_USE_INSTALLED_ESP must be 0 or 1"
        ;;
esac
if [[ "$use_installed_esp" -eq 0 ]]; then
    [[ -n "$runtime_esp" ]] || fail "--runtime-esp is required unless --use-installed-esp is set"
    [[ -d "$runtime_esp" ]] || fail "runtime ESP artifacts directory not found: $(rel "$runtime_esp")"
fi
[[ -n "$install_manifest" ]] || fail "--install-manifest is required"
[[ -f "$install_manifest" ]] || fail "install manifest not found: $(rel "$install_manifest")"
[[ -n "$target_disk_size" ]] || fail "--target-disk-size is required"
if [[ -n "$node_metadata" ]]; then
    [[ -f "$node_metadata" ]] || fail "node metadata not found: $(rel "$node_metadata")"
fi

installer_uki="$(real "$installer_uki")"
runtime_artifact="$(real "$runtime_artifact")"
if [[ -n "$runtime_esp" ]]; then
    runtime_esp="$(real "$runtime_esp")"
fi
install_manifest="$(real "$install_manifest")"
if [[ -n "$node_metadata" ]]; then
    node_metadata="$(real "$node_metadata")"
fi
state_dir="$(real "$state_dir")"
env_file="$(real "$env_file")"
run_script="$(real "$run_script")"
manifest="$(real "$manifest")"
vmtest_state_root="$(real "$vmtest_state_root")"

validate_no_shell_list_value() {
    local label="$1"
    local value="$2"
    case "$value" in
        *[[:space:],]*)
            fail "$label must not contain whitespace or comma"
            ;;
    esac
}

validate_no_shell_list_value "target disk size" "$target_disk_size"

need() {
    command -v "$1" >/dev/null 2>&1 || fail "$1 is required"
}

need sha256sum

file_sha() {
    sha256sum "$1" | awk '{print $1}'
}

validate_sha256() {
    local label="$1"
    local value="$2"
    [[ -z "$value" ]] && return 0
    [[ "$value" =~ ^[0-9a-f]{64}$ ]] || fail "$label must be a lowercase SHA-256 hex digest"
}

verify_sha256() {
    local label="$1"
    local path="$2"
    local expected="$3"
    local actual
    actual="$(file_sha "$path")"
    if [[ -n "$expected" && "$actual" != "$expected" ]]; then
        fail "$label sha256 does not match $path"
    fi
    printf "%s" "$actual"
}

validate_sha256 "installer UKI SHA-256" "$installer_uki_sha256"
validate_sha256 "runtime artifact SHA-256" "$runtime_artifact_sha256"
validate_sha256 "install manifest SHA-256" "$install_manifest_sha256"
validate_sha256 "node metadata SHA-256" "$node_metadata_sha256"

installer_uki_sha256="$(verify_sha256 "installer UKI" "$installer_uki" "$installer_uki_sha256")"
runtime_artifact_sha256="$(verify_sha256 "runtime artifact" "$runtime_artifact" "$runtime_artifact_sha256")"
install_manifest_sha256="$(verify_sha256 "install manifest" "$install_manifest" "$install_manifest_sha256")"
if [[ -n "$node_metadata" ]]; then
    node_metadata_sha256="$(verify_sha256 "node metadata" "$node_metadata" "$node_metadata_sha256")"
elif [[ -n "$node_metadata_sha256" ]]; then
    fail "--node-metadata is required when --node-metadata-sha256 is set"
fi

check_loader_entries() {
    local esp="$1"
    local entries_dir="$esp/loader/entries"
    local first
    [[ -d "$entries_dir" ]] || fail "runtime ESP artifacts missing loader/entries"
    first="$(find "$entries_dir" -maxdepth 1 -type f -name '*.conf' -print -quit)"
    [[ -n "$first" ]] || fail "runtime ESP artifacts contain no loader entries"
    grep -R -Fq 'root=PARTUUID=' "$entries_dir" || fail "loader entries missing root=PARTUUID"
    grep -R -Fq 'rootfstype=squashfs' "$entries_dir" || fail "loader entries missing rootfstype=squashfs"
    grep -R -Eq '(^|[[:space:]])ro([[:space:]]|$)' "$entries_dir" || fail "loader entries missing ro option"
    grep -R -Fq 'katl.generation=' "$entries_dir" || fail "loader entries missing katl.generation"
    grep -R -Fq 'systemd.machine_id=' "$entries_dir" || fail "loader entries missing systemd.machine_id"
    if grep -R -Eq 'root=(gpt-auto|LABEL=|UUID=)' "$entries_dir"; then
        fail "loader entries rely on root auto-discovery"
    fi
}

if [[ "$use_installed_esp" -eq 0 ]]; then
    check_loader_entries "$runtime_esp"
fi

if [[ "$check_only" -eq 1 ]]; then
    echo "ok: first-install runtime fixture inputs valid"
    exit 0
fi

mkdir -p "$(dirname "$env_file")" "$(dirname "$run_script")" "$(dirname "$manifest")"
{
    printf '# Generated by scripts/resolve-first-install-runtime-fixture\n'
    printf '# Source this file before running the first-install target-disk fixture smoke.\n'
    printf 'export KATL_VMTEST_RUN=%q\n' "1"
    printf 'export KATL_VMTEST_KEEP=%q\n' "$vmtest_keep"
    printf 'export KATL_VMTEST_STATE_ROOT=%q\n' "$vmtest_state_root"
    printf 'export KATL_INSTALLER_UKI=%q\n' "$installer_uki"
    printf 'export KATL_RUNTIME_ARTIFACT=%q\n' "$runtime_artifact"
    if [[ -n "$runtime_esp" ]]; then
        printf 'export KATL_RUNTIME_ESP_ARTIFACTS=%q\n' "$runtime_esp"
    fi
    printf 'export KATL_INSTALL_MANIFEST=%q\n' "$install_manifest"
    printf 'export KATL_FIRST_INSTALL_USE_INSTALLED_ESP=%q\n' "$use_installed_esp"
    printf 'export KATL_FIRST_INSTALL_INSTALLER_UKI_SHA256=%q\n' "$installer_uki_sha256"
    printf 'export KATL_FIRST_INSTALL_RUNTIME_ARTIFACT_SHA256=%q\n' "$runtime_artifact_sha256"
    printf 'export KATL_FIRST_INSTALL_MANIFEST_SHA256=%q\n' "$install_manifest_sha256"
    printf 'export KATL_FIRST_INSTALL_TARGET_DISK_SIZE=%q\n' "$target_disk_size"
    if [[ -n "$node_metadata" ]]; then
        printf 'export KATL_RUNTIME_NODE_METADATA=%q\n' "$node_metadata"
        printf 'export KATL_FIRST_INSTALL_NODE_METADATA_SHA256=%q\n' "$node_metadata_sha256"
    fi
} >"$env_file"

{
    printf '#!/usr/bin/env bash\n'
    printf 'set -euo pipefail\n'
    printf 'cd %q\n' "$repo_root"
    printf 'source %q\n' "$env_file"
    printf 'recheck_dir=%q\n' "$state_dir/recheck"
    # shellcheck disable=SC2016
    printf 'recheck_args=(--installer-uki "$KATL_INSTALLER_UKI" --runtime-artifact "$KATL_RUNTIME_ARTIFACT" --install-manifest "$KATL_INSTALL_MANIFEST" --installer-uki-sha256 "$KATL_FIRST_INSTALL_INSTALLER_UKI_SHA256" --runtime-artifact-sha256 "$KATL_FIRST_INSTALL_RUNTIME_ARTIFACT_SHA256" --install-manifest-sha256 "$KATL_FIRST_INSTALL_MANIFEST_SHA256" --target-disk-size "${KATL_FIRST_INSTALL_TARGET_DISK_SIZE:-20G}" --state-dir "$recheck_dir" --check-only)\n'
    # shellcheck disable=SC2016
    printf 'if [[ "${KATL_FIRST_INSTALL_USE_INSTALLED_ESP:-0}" == "1" ]]; then\n'
    printf '    recheck_args+=(--use-installed-esp)\n'
    printf 'else\n'
    # shellcheck disable=SC2016
    printf '    recheck_args+=(--runtime-esp "$KATL_RUNTIME_ESP_ARTIFACTS")\n'
    printf 'fi\n'
    # shellcheck disable=SC2016
    printf 'if [[ -n "${KATL_RUNTIME_NODE_METADATA:-}" ]]; then\n'
    # shellcheck disable=SC2016
    printf '    recheck_args+=(--node-metadata "$KATL_RUNTIME_NODE_METADATA")\n'
    # shellcheck disable=SC2016
    printf '    if [[ -n "${KATL_FIRST_INSTALL_NODE_METADATA_SHA256:-}" ]]; then\n'
    # shellcheck disable=SC2016
    printf '        recheck_args+=(--node-metadata-sha256 "$KATL_FIRST_INSTALL_NODE_METADATA_SHA256")\n'
    printf '    fi\n'
    printf 'fi\n'
    # shellcheck disable=SC2016
    printf '%q "${recheck_args[@]}"\n' "$repo_root/scripts/resolve-first-install-runtime-fixture"
    # shellcheck disable=SC2016
    printf 'GOCACHE="${GOCACHE:-/tmp/katl-go-cache}" go test ./internal/vmtest -run '\''^TestFirstInstallTargetDiskFixtureContract$'\'' -count=1 -timeout 35m -katl.vmtest.run\n'
} >"$run_script"
chmod +x "$run_script"

cat >"$manifest" <<EOF
{
  "apiVersion": "katl.dev/v1alpha1",
  "kind": "FirstInstallRuntimeFixtureResolution",
  "installerUKI": "$(json "$installer_uki")",
  "installerUKISHA256": "$(json "$installer_uki_sha256")",
  "runtimeArtifact": "$(json "$runtime_artifact")",
  "runtimeArtifactSHA256": "$(json "$runtime_artifact_sha256")",
  "runtimeESPArtifacts": "$(json "$runtime_esp")",
  "useInstalledESP": $(if [[ "$use_installed_esp" -eq 1 ]]; then printf true; else printf false; fi),
  "nodeMetadata": "$(json "$node_metadata")",
  "nodeMetadataSHA256": "$(json "$node_metadata_sha256")",
  "installManifest": "$(json "$install_manifest")",
  "installManifestSHA256": "$(json "$install_manifest_sha256")",
  "targetDiskSize": "$(json "$target_disk_size")",
  "envFile": "$(json "$env_file")",
  "runScript": "$(json "$run_script")"
}
EOF

echo "fixture env: $(rel "$env_file")"
echo "fixture manifest: $(rel "$manifest")"
echo "run script: $(rel "$run_script")"
echo "next: source $(rel "$env_file")"
echo "next: $(rel "$run_script")"
