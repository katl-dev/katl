#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(git -C "$script_dir/.." rev-parse --show-toplevel 2>/dev/null || (cd "$script_dir/.." && pwd))"

args=(
    bind-install-manifest-image
    --artifact-index "${KATL_MKOSI_ARTIFACT_INDEX:-$repo_root/_build/mkosi/artifacts.json}"
)
if [[ -n "${KATL_INSTALL_MANIFEST_TEMPLATE:-}" ]]; then
    args+=(--template "$KATL_INSTALL_MANIFEST_TEMPLATE")
fi
if [[ -n "${KATL_INSTALL_MANIFEST:-}" ]]; then
    args+=(--output "$KATL_INSTALL_MANIFEST")
fi
if [[ -n "${KATL_INSTALL_MANIFEST_KATLOS_LOCAL_REF:-}" ]]; then
    args+=(--local-ref "$KATL_INSTALL_MANIFEST_KATLOS_LOCAL_REF")
fi
if [[ -n "${KATL_INSTALL_TARGET_DISK_BY_ID:-}" ]]; then
    args+=(--target-disk-by-id "$KATL_INSTALL_TARGET_DISK_BY_ID")
fi
args+=("$@")

if command -v katl-mkosi-artifacts >/dev/null 2>&1; then
    exec katl-mkosi-artifacts "${args[@]}"
fi
cd "$repo_root"
exec go run ./cmd/katl-mkosi-artifacts "${args[@]}"
