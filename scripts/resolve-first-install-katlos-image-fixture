#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
run_id="${KATL_FIRST_INSTALL_FIXTURE_RUN_ID:-$(date -u +%Y%m%dT%H%M%SZ)-$$}"
state_root="${KATL_FIRST_INSTALL_KATLOS_FIXTURE_STATE_ROOT:-$repo_root/build/first-install-katlos-image-fixture}"
state_dir="${KATL_FIRST_INSTALL_KATLOS_FIXTURE_STATE_DIR:-$state_root/$run_id}"
env_file="${KATL_FIRST_INSTALL_FIXTURE_ENV:-$state_dir/vmtest.env}"
run_script="$state_dir/run-first-install-katlos-image-fixture.sh"
serial_run_script="$state_dir/run-first-install-katlos-image-serial-smoke.sh"
manifest="$state_dir/katlos-image-fixture.json"

artifact_index="${KATL_MKOSI_ARTIFACT_INDEX:-}"
installer_uki="${KATL_INSTALLER_UKI:-}"
installer_kernel="${KATL_INSTALLER_KERNEL:-}"
installer_initrd="${KATL_INSTALLER_INITRD:-}"
installer_uki_sha256="${KATL_FIRST_INSTALL_INSTALLER_UKI_SHA256:-}"
katlos_image="${KATL_KATLOS_IMAGE:-}"
katlos_image_sha256="${KATL_KATLOS_IMAGE_SHA256:-}"
install_manifest="${KATL_INSTALL_MANIFEST:-}"
node_metadata="${KATL_RUNTIME_NODE_METADATA:-${KATL_INSTALLED_NODE_METADATA:-}}"
node_metadata_sha256="${KATL_FIRST_INSTALL_NODE_METADATA_SHA256:-}"
target_disk_size="${KATL_FIRST_INSTALL_TARGET_DISK_SIZE:-20G}"
env_file_set=0
check_only=0

usage() {
    cat <<'USAGE'
Usage: scripts/resolve-first-install-katlos-image-fixture [options]

Resolve the host-side runtime root input for the opt-in first-install target
disk fixture smoke from a single KatlOS install image. The generated wrapper
revalidates the KatlOS image and then runs the first-install target-disk smoke
in installed-ESP mode, so runtime boot metadata comes from the disk written by
the installer.

Options:
  --artifact-index PATH     mkosi artifact index for installer/image discovery
  --installer-uki PATH       Installer UKI, or KATL_INSTALLER_UKI
  --installer-kernel PATH    Installer kernel, or KATL_INSTALLER_KERNEL
  --installer-initrd PATH    Installer initrd, or KATL_INSTALLER_INITRD
  --installer-uki-sha256 H   Expected installer UKI SHA-256
  --katlos-image PATH        KatlOS install image, or KATL_KATLOS_IMAGE
  --katlos-image-sha256 H    Expected KatlOS image SHA-256
  --node-metadata PATH       Optional /etc/katl/node.json, or KATL_RUNTIME_NODE_METADATA
  --node-metadata-sha256 H   Expected node metadata SHA-256
  --install-manifest PATH    Install manifest, or KATL_INSTALL_MANIFEST
  --target-disk-size SIZE    Target disk size for the first install smoke (default: 20G)
  --state-dir DIR            Output directory for generated env, manifest, and wrappers
  --env-file PATH            Sourceable env output path (default: <state-dir>/vmtest.env)
  --check-only               Validate inputs without writing wrappers
  -h, --help                 Show this help

After this command succeeds:
  source <state-dir>/vmtest.env
  <state-dir>/run-first-install-katlos-image-serial-smoke.sh
  <state-dir>/run-first-install-katlos-image-fixture.sh

Set KATL_ALLOW_STALE_INSTALLER_ARTIFACTS=1 only when intentionally running
installer artifacts older than the local installer source tree.
USAGE
}

fail() {
    echo "error: $*" >&2
    exit 1
}

need() {
    command -v "$1" >/dev/null 2>&1 || fail "$1 is required"
}

need_value() {
    local option="$1"
    local value="${2:-}"
    if [[ -z "$value" || "$value" == --* ]]; then
        fail "$option requires a value"
    fi
}

rel() {
    local path="$1"
    printf "%s" "${path#"$repo_root"/}"
}

real() {
    realpath -m "$1"
}

stale_installer_allowed() {
    case "${KATL_ALLOW_STALE_INSTALLER_ARTIFACTS:-0}" in
        1|true|TRUE|yes|YES)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

check_installer_artifact_freshness() {
    stale_installer_allowed && return 0
    local sources=(
        "$repo_root/cmd/katlos-install"
        "$repo_root/internal/installer"
        "$repo_root/mkosi.profiles/installer-image"
    )
    local artifacts=()
    local artifact newer
    [[ -n "$installer_uki" ]] && artifacts+=("$installer_uki")
    [[ -n "$installer_kernel" ]] && artifacts+=("$installer_kernel")
    [[ -n "$installer_initrd" ]] && artifacts+=("$installer_initrd")
    for artifact in "${artifacts[@]}"; do
        newer="$(find "${sources[@]}" -type f ! -path '*/build/*' ! -name '*_test.go' -newer "$artifact" -print -quit)"
        if [[ -n "$newer" ]]; then
            fail "installer artifact $(rel "$artifact") is older than installer source $(rel "$newer"); rebuild with scripts/mkosi build-installer or set KATL_ALLOW_STALE_INSTALLER_ARTIFACTS=1"
        fi
    done
}

json() {
    local value="$1"
    value="${value//\\/\\\\}"
    value="${value//\"/\\\"}"
    value="${value//$'\n'/\\n}"
    printf "%s" "$value"
}

file_sha() {
    sha256sum "$1" | awk '{print $1}'
}

validate_sha256() {
    local label="$1"
    local value="$2"
    [[ -z "$value" ]] && return 0
    [[ "$value" =~ ^[0-9a-f]{64}$ ]] || fail "$label must be a lowercase SHA-256 hex digest"
}

normal_image_path() {
    local label="$1"
    local value="$2"
    [[ -n "$value" ]] || fail "$label is required"
    [[ "$value" != /* ]] || fail "$label must be relative"
    [[ "$value" != *".."* ]] || fail "$label must not contain dot segments"
    [[ "$value" != *"//"* ]] || fail "$label must be clean"
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --artifact-index)
            need_value "$1" "${2:-}"
            artifact_index="$2"
            shift 2
            ;;
        --installer-uki)
            need_value "$1" "${2:-}"
            installer_uki="$2"
            shift 2
            ;;
        --installer-kernel)
            need_value "$1" "${2:-}"
            installer_kernel="$2"
            shift 2
            ;;
        --installer-initrd)
            need_value "$1" "${2:-}"
            installer_initrd="$2"
            shift 2
            ;;
        --installer-uki-sha256)
            need_value "$1" "${2:-}"
            installer_uki_sha256="$2"
            shift 2
            ;;
        --katlos-image)
            need_value "$1" "${2:-}"
            katlos_image="$2"
            shift 2
            ;;
        --katlos-image-sha256)
            need_value "$1" "${2:-}"
            katlos_image_sha256="$2"
            shift 2
            ;;
        --node-metadata)
            need_value "$1" "${2:-}"
            node_metadata="$2"
            shift 2
            ;;
        --node-metadata-sha256)
            need_value "$1" "${2:-}"
            node_metadata_sha256="$2"
            shift 2
            ;;
        --install-manifest)
            need_value "$1" "${2:-}"
            install_manifest="$2"
            shift 2
            ;;
        --target-disk-size)
            need_value "$1" "${2:-}"
            target_disk_size="$2"
            shift 2
            ;;
        --state-dir)
            need_value "$1" "${2:-}"
            state_dir="$2"
            if [[ "$env_file_set" -eq 0 ]]; then
                env_file="$state_dir/vmtest.env"
            fi
            run_script="$state_dir/run-first-install-katlos-image-fixture.sh"
            serial_run_script="$state_dir/run-first-install-katlos-image-serial-smoke.sh"
            manifest="$state_dir/katlos-image-fixture.json"
            shift 2
            ;;
        --env-file)
            need_value "$1" "${2:-}"
            env_file="$2"
            env_file_set=1
            shift 2
            ;;
        --check-only)
            check_only=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            usage >&2
            fail "unknown argument: $1"
            ;;
    esac
done

need awk
need jq
need mkdir
need realpath
need sha256sum
need stat
need unsquashfs

if [[ -n "$artifact_index" ]]; then
    artifact_index="$(real "$artifact_index")"
    [[ -f "$artifact_index" ]] || fail "artifact index not found: $(rel "$artifact_index")"
    index_installer_uki="$("$repo_root/scripts/mkosi-artifacts" path installer-uki "$artifact_index")"
    index_installer_kernel="$("$repo_root/scripts/mkosi-artifacts" path installer-kernel "$artifact_index")"
    index_installer_initrd="$("$repo_root/scripts/mkosi-artifacts" path installer-initrd "$artifact_index")"
    index_katlos_image="$("$repo_root/scripts/mkosi-artifacts" path katlos-install-image "$artifact_index")"
    if [[ -z "$installer_uki" ]]; then
        installer_uki="$index_installer_uki"
    fi
    if [[ -z "$installer_kernel" ]]; then
        installer_kernel="$index_installer_kernel"
    fi
    if [[ -z "$installer_initrd" ]]; then
        installer_initrd="$index_installer_initrd"
    fi
    if [[ -z "$katlos_image" ]]; then
        katlos_image="$index_katlos_image"
    fi
fi

if [[ -n "$installer_kernel" || -n "$installer_initrd" ]]; then
    [[ -n "$installer_kernel" ]] || fail "--installer-kernel is required when --installer-initrd is set"
    [[ -n "$installer_initrd" ]] || fail "--installer-initrd is required when --installer-kernel is set"
    [[ -f "$installer_kernel" ]] || fail "installer kernel not found: $(rel "$installer_kernel")"
    [[ -f "$installer_initrd" ]] || fail "installer initrd not found: $(rel "$installer_initrd")"
else
    [[ -n "$installer_uki" ]] || fail "--installer-uki is required unless --installer-kernel and --installer-initrd are set"
fi
if [[ -n "$installer_uki" ]]; then
    [[ -f "$installer_uki" ]] || fail "installer UKI not found: $(rel "$installer_uki")"
fi
[[ -n "$katlos_image" ]] || fail "--katlos-image is required"
[[ -f "$katlos_image" ]] || fail "KatlOS image not found: $(rel "$katlos_image")"
[[ -n "$install_manifest" ]] || fail "--install-manifest is required"
[[ -f "$install_manifest" ]] || fail "install manifest not found: $(rel "$install_manifest")"
[[ -n "$target_disk_size" ]] || fail "--target-disk-size is required"
case "$target_disk_size" in
    *[[:space:],]*)
        fail "target disk size must not contain whitespace or comma"
        ;;
esac
if [[ -n "$node_metadata" ]]; then
    [[ -f "$node_metadata" ]] || fail "node metadata not found: $(rel "$node_metadata")"
fi

if [[ -n "$installer_uki" ]]; then
    installer_uki="$(real "$installer_uki")"
fi
if [[ -n "$installer_kernel" ]]; then
    installer_kernel="$(real "$installer_kernel")"
fi
if [[ -n "$installer_initrd" ]]; then
    installer_initrd="$(real "$installer_initrd")"
fi
katlos_image="$(real "$katlos_image")"
if [[ -n "${index_installer_uki:-}" ]]; then
    index_installer_uki="$(real "$index_installer_uki")"
    [[ "$installer_uki" == "$index_installer_uki" ]] || fail "artifact index installer-uki resolves to $(rel "$index_installer_uki"), not $(rel "$installer_uki")"
fi
if [[ -n "${index_installer_kernel:-}" && -n "$installer_kernel" ]]; then
    index_installer_kernel="$(real "$index_installer_kernel")"
    [[ "$installer_kernel" == "$index_installer_kernel" ]] || fail "artifact index installer-kernel resolves to $(rel "$index_installer_kernel"), not $(rel "$installer_kernel")"
fi
if [[ -n "${index_installer_initrd:-}" && -n "$installer_initrd" ]]; then
    index_installer_initrd="$(real "$index_installer_initrd")"
    [[ "$installer_initrd" == "$index_installer_initrd" ]] || fail "artifact index installer-initrd resolves to $(rel "$index_installer_initrd"), not $(rel "$installer_initrd")"
fi
if [[ -n "${index_katlos_image:-}" ]]; then
    index_katlos_image="$(real "$index_katlos_image")"
    [[ "$katlos_image" == "$index_katlos_image" ]] || fail "artifact index katlos-install-image resolves to $(rel "$index_katlos_image"), not $(rel "$katlos_image")"
fi
install_manifest="$(real "$install_manifest")"
if [[ -n "$node_metadata" ]]; then
    node_metadata="$(real "$node_metadata")"
fi
state_dir="$(real "$state_dir")"
env_file="$(real "$env_file")"
run_script="$(real "$run_script")"
manifest="$(real "$manifest")"
check_installer_artifact_freshness

validate_sha256 "KatlOS image SHA-256" "$katlos_image_sha256"
validate_sha256 "installer UKI SHA-256" "$installer_uki_sha256"
validate_sha256 "node metadata SHA-256" "$node_metadata_sha256"

if [[ -n "$installer_uki" ]]; then
    actual_installer_uki_sha256="$(file_sha "$installer_uki")"
    if [[ -n "$installer_uki_sha256" && "$actual_installer_uki_sha256" != "$installer_uki_sha256" ]]; then
        fail "installer UKI sha256 does not match $installer_uki"
    fi
    installer_uki_sha256="$actual_installer_uki_sha256"
else
    installer_uki_sha256=""
fi

image_sha256="$(file_sha "$katlos_image")"
if [[ -n "$katlos_image_sha256" && "$image_sha256" != "$katlos_image_sha256" ]]; then
    fail "KatlOS image sha256 does not match $katlos_image"
fi
image_size="$(stat -c %s "$katlos_image")"

manifest_image_sha256="$(jq -r '.katlosImage.sha256 // ""' "$install_manifest")"
if [[ -n "$manifest_image_sha256" && "$manifest_image_sha256" != "$image_sha256" ]]; then
    fail "install manifest KatlOS image sha256 does not match $katlos_image"
fi
manifest_image_size="$(jq -r '.katlosImage.sizeBytes // ""' "$install_manifest")"
if [[ -n "$manifest_image_size" && "$manifest_image_size" != "$image_size" ]]; then
    fail "install manifest KatlOS image size does not match $katlos_image"
fi
manifest_local_ref="$(jq -r '.katlosImage.localRef // ""' "$install_manifest")"
if [[ -n "$manifest_local_ref" ]]; then
    normal_image_path "install manifest katlosImage.localRef" "$manifest_local_ref"
    manifest_ref_path="$(real "$(dirname "$install_manifest")/$manifest_local_ref")"
    [[ "$manifest_ref_path" == "$katlos_image" ]] || fail "install manifest katlosImage.localRef resolves to $(rel "$manifest_ref_path"), not $(rel "$katlos_image")"
fi

"$repo_root/scripts/check-katlos-install-image" "$katlos_image" >/dev/null

work_dir="$state_dir/katlos-image"
index_file="$work_dir/image.json"
runtime_artifact="$work_dir/runtime-root.squashfs"
mkdir -p "$work_dir"
unsquashfs -cat "$katlos_image" katlos/image.json >"$index_file"
runtime_path="$(jq -er '.components[] | select(.role == "runtime-root") | .path' "$index_file")"
normal_image_path "runtime-root component path" "$runtime_path"
runtime_sha256="$(jq -er '.components[] | select(.role == "runtime-root") | .sha256' "$index_file")"
runtime_size="$(jq -er '.components[] | select(.role == "runtime-root") | .sizeBytes' "$index_file")"
validate_sha256 "runtime-root component SHA-256" "$runtime_sha256"
unsquashfs -cat "$katlos_image" "$runtime_path" >"$runtime_artifact"
actual_runtime_sha256="$(file_sha "$runtime_artifact")"
actual_runtime_size="$(stat -c %s "$runtime_artifact")"
[[ "$actual_runtime_sha256" == "$runtime_sha256" ]] || fail "runtime-root component sha256 does not match KatlOS image index"
[[ "$actual_runtime_size" == "$runtime_size" ]] || fail "runtime-root component size does not match KatlOS image index"

if [[ -n "$node_metadata" ]]; then
    actual_node_metadata_sha256="$(file_sha "$node_metadata")"
    if [[ -n "$node_metadata_sha256" && "$actual_node_metadata_sha256" != "$node_metadata_sha256" ]]; then
        fail "node metadata sha256 does not match $node_metadata"
    fi
else
    actual_node_metadata_sha256=""
fi

if [[ "$check_only" -eq 1 ]]; then
    echo "ok: first-install KatlOS image fixture inputs valid"
    exit 0
fi

resolver_args=(
    --runtime-artifact "$runtime_artifact"
    --runtime-artifact-sha256 "$runtime_sha256"
    --use-installed-esp
    --install-manifest "$install_manifest"
    --target-disk-size "$target_disk_size"
    --state-dir "$state_dir"
    --env-file "$env_file"
)
if [[ -n "$installer_kernel" ]]; then
    resolver_args+=(--installer-kernel "$installer_kernel" --installer-initrd "$installer_initrd")
else
    resolver_args+=(--installer-uki "$installer_uki" --installer-uki-sha256 "$installer_uki_sha256")
fi
if [[ -n "$node_metadata" ]]; then
    resolver_args+=(--node-metadata "$node_metadata")
    if [[ -n "$actual_node_metadata_sha256" ]]; then
        resolver_args+=(--node-metadata-sha256 "$actual_node_metadata_sha256")
    fi
fi
"$repo_root/scripts/resolve-first-install-runtime-fixture" "${resolver_args[@]}" >/dev/null
runtime_fixture_manifest="$(real "$state_dir/fixture.json")"
[[ -f "$runtime_fixture_manifest" ]] || fail "first-install runtime fixture manifest not found: $(rel "$runtime_fixture_manifest")"
published_runtime_dir="$(jq -er '.publishedInstalledRuntimeDir' "$runtime_fixture_manifest")"
published_node_name="$(jq -er '.publishedNodeName // ""' "$runtime_fixture_manifest")"
published_system_role="$(jq -er '.publishedSystemRole // ""' "$runtime_fixture_manifest")"

{
    if [[ -n "$artifact_index" ]]; then
        printf 'export KATL_MKOSI_ARTIFACT_INDEX=%q\n' "$artifact_index"
    fi
    printf 'export KATL_KATLOS_IMAGE=%q\n' "$katlos_image"
    printf 'export KATL_KATLOS_IMAGE_SHA256=%q\n' "$image_sha256"
    if [[ -n "$installer_kernel" ]]; then
        printf 'export KATL_INSTALLER_KERNEL=%q\n' "$installer_kernel"
        printf 'export KATL_INSTALLER_INITRD=%q\n' "$installer_initrd"
    fi
} >>"$env_file"

cat >"$manifest" <<EOF
{
  "apiVersion": "katl.dev/v1alpha1",
  "kind": "FirstInstallKatlOSImageFixtureResolution",
  "artifactIndex": "$(json "$artifact_index")",
  "installerUKI": "$(json "$installer_uki")",
  "installerUKISHA256": "$(json "$installer_uki_sha256")",
  "installerKernel": "$(json "$installer_kernel")",
  "installerInitrd": "$(json "$installer_initrd")",
  "katlosImage": "$(json "$katlos_image")",
  "katlosImageSHA256": "$(json "$image_sha256")",
  "katlosImageSizeBytes": $image_size,
  "runtimeArtifact": "$(json "$runtime_artifact")",
  "runtimeArtifactSHA256": "$(json "$runtime_sha256")",
  "runtimeArtifactSizeBytes": $runtime_size,
  "installManifest": "$(json "$install_manifest")",
  "nodeMetadata": "$(json "$node_metadata")",
  "nodeMetadataSHA256": "$(json "$actual_node_metadata_sha256")",
  "firstInstallRuntimeFixtureManifest": "$(json "$runtime_fixture_manifest")",
  "publishedInstalledRuntimeDir": "$(json "$published_runtime_dir")",
  "publishedNodeName": "$(json "$published_node_name")",
  "publishedSystemRole": "$(json "$published_system_role")",
  "envFile": "$(json "$env_file")",
  "serialRunScript": "$(json "$serial_run_script")",
  "runScript": "$(json "$run_script")"
}
EOF

{
    printf '#!/usr/bin/env bash\n'
    printf 'set -euo pipefail\n'
    printf 'cd %q\n' "$repo_root"
    printf 'source %q\n' "$env_file"
    printf 'recheck_dir=%q\n' "$state_dir/katlos-recheck"
    # shellcheck disable=SC2016
    printf 'recheck_args=(--katlos-image "$KATL_KATLOS_IMAGE" --katlos-image-sha256 "$KATL_KATLOS_IMAGE_SHA256" --install-manifest "$KATL_INSTALL_MANIFEST" --target-disk-size "${KATL_FIRST_INSTALL_TARGET_DISK_SIZE:-20G}" --state-dir "$recheck_dir" --check-only)\n'
    # shellcheck disable=SC2016
    printf 'if [[ -n "${KATL_INSTALLER_KERNEL:-}" ]]; then\n'
    # shellcheck disable=SC2016
    printf '    recheck_args+=(--installer-kernel "$KATL_INSTALLER_KERNEL" --installer-initrd "$KATL_INSTALLER_INITRD")\n'
    printf 'else\n'
    # shellcheck disable=SC2016
    printf '    recheck_args+=(--installer-uki "$KATL_INSTALLER_UKI" --installer-uki-sha256 "$KATL_FIRST_INSTALL_INSTALLER_UKI_SHA256")\n'
    printf 'fi\n'
    # shellcheck disable=SC2016
    printf 'if [[ -n "${KATL_MKOSI_ARTIFACT_INDEX:-}" ]]; then\n'
    # shellcheck disable=SC2016
    printf '    recheck_args+=(--artifact-index "$KATL_MKOSI_ARTIFACT_INDEX")\n'
    printf 'fi\n'
    # shellcheck disable=SC2016
    printf 'if [[ -n "${KATL_RUNTIME_NODE_METADATA:-}" ]]; then\n'
    # shellcheck disable=SC2016
    printf '    recheck_args+=(--node-metadata "$KATL_RUNTIME_NODE_METADATA")\n'
    # shellcheck disable=SC2016
    printf '    if [[ -n "${KATL_FIRST_INSTALL_NODE_METADATA_SHA256:-}" ]]; then\n'
    # shellcheck disable=SC2016
    printf '        recheck_args+=(--node-metadata-sha256 "$KATL_FIRST_INSTALL_NODE_METADATA_SHA256")\n'
    printf '    fi\n'
    printf 'fi\n'
    # shellcheck disable=SC2016
    printf '%q "${recheck_args[@]}"\n' "$repo_root/scripts/resolve-first-install-katlos-image-fixture"
    printf '%q\n' "$state_dir/run-first-install-target-disk-fixture.sh"
} >"$run_script"
chmod +x "$run_script"

{
    printf '#!/usr/bin/env bash\n'
    printf 'set -euo pipefail\n'
    printf 'cd %q\n' "$repo_root"
    printf 'source %q\n' "$env_file"
    printf 'recheck_dir=%q\n' "$state_dir/katlos-recheck-serial"
    # shellcheck disable=SC2016
    printf 'recheck_args=(--katlos-image "$KATL_KATLOS_IMAGE" --katlos-image-sha256 "$KATL_KATLOS_IMAGE_SHA256" --install-manifest "$KATL_INSTALL_MANIFEST" --target-disk-size "${KATL_FIRST_INSTALL_TARGET_DISK_SIZE:-20G}" --state-dir "$recheck_dir" --check-only)\n'
    # shellcheck disable=SC2016
    printf 'if [[ -n "${KATL_INSTALLER_KERNEL:-}" ]]; then\n'
    # shellcheck disable=SC2016
    printf '    recheck_args+=(--installer-kernel "$KATL_INSTALLER_KERNEL" --installer-initrd "$KATL_INSTALLER_INITRD")\n'
    printf 'else\n'
    # shellcheck disable=SC2016
    printf '    recheck_args+=(--installer-uki "$KATL_INSTALLER_UKI" --installer-uki-sha256 "$KATL_FIRST_INSTALL_INSTALLER_UKI_SHA256")\n'
    printf 'fi\n'
    # shellcheck disable=SC2016
    printf 'if [[ -n "${KATL_MKOSI_ARTIFACT_INDEX:-}" ]]; then\n'
    # shellcheck disable=SC2016
    printf '    recheck_args+=(--artifact-index "$KATL_MKOSI_ARTIFACT_INDEX")\n'
    printf 'fi\n'
    # shellcheck disable=SC2016
    printf 'if [[ -n "${KATL_RUNTIME_NODE_METADATA:-}" ]]; then\n'
    # shellcheck disable=SC2016
    printf '    recheck_args+=(--node-metadata "$KATL_RUNTIME_NODE_METADATA")\n'
    # shellcheck disable=SC2016
    printf '    if [[ -n "${KATL_FIRST_INSTALL_NODE_METADATA_SHA256:-}" ]]; then\n'
    # shellcheck disable=SC2016
    printf '        recheck_args+=(--node-metadata-sha256 "$KATL_FIRST_INSTALL_NODE_METADATA_SHA256")\n'
    printf '    fi\n'
    printf 'fi\n'
    # shellcheck disable=SC2016
    printf '%q "${recheck_args[@]}"\n' "$repo_root/scripts/resolve-first-install-katlos-image-fixture"
    printf '%q\n' "$state_dir/run-first-install-target-disk-serial-smoke.sh"
} >"$serial_run_script"
chmod +x "$serial_run_script"

echo "fixture env: $(rel "$env_file")"
echo "fixture manifest: $(rel "$manifest")"
echo "serial run script: $(rel "$serial_run_script")"
echo "run script: $(rel "$run_script")"
echo "next: source $(rel "$env_file")"
echo "next: $(rel "$serial_run_script")"
echo "next: $(rel "$run_script")"
